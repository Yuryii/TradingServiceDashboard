@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Cau hinh Thong bao";
}
<div class="row">
    <div class="col-12 mb-4">
        <h4 class="mb-0"><i class="icon-base bx bx-gear me-2 text-primary"></i>Cau hinh Thong bao</h4>
        <p class="text-muted">Quan ly cac thong bao tu dong he thong</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card border-primary shadow-none mb-0 h-100">
            <div class="card-body text-center">
                <h2 class="text-primary mb-1">@ViewBag.Total</h2>
                <p class="mb-0 text-muted small">Tong so thong bao</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-success shadow-none mb-0 h-100">
            <div class="card-body text-center">
                <h2 class="text-success mb-1">@ViewBag.Enabled</h2>
                <p class="mb-0 text-muted small">Da bat</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-secondary shadow-none mb-0 h-100">
            <div class="card-body text-center">
                <h2 class="text-secondary mb-1">@ViewBag.Disabled</h2>
                <p class="mb-0 text-muted small">Da tat</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Phan bo theo module</h5>
                    <div class="d-flex gap-2">
                        <a asp-action="List" class="btn btn-primary btn-sm">
                            <i class="icon-base bx bx-list-ul me-1"></i> Quan ly chi tiet
                        </a>
                        <form asp-action="Reset" method="post" onsubmit="return confirm('Ban co chac muon reset tat ca cau hinh ve mac dinh?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="icon-base bx bx-reset me-1"></i> Reset
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Module</th>
                                <th class="text-center">Tong so</th>
                                <th class="text-center">Da bat</th>
                                <th class="text-center">Da tat</th>
                                <th class="text-center">Ti le bat</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var categories = new[]
                                {
                                    "Finance", "Inventory", "HumanResources",
                                    "Sales", "CustomerService", "Marketing", "Executive"
                                };
                                var categoryIcons = new Dictionary<string, string>
                                {
                                    ["Finance"] = "bx-dollar",
                                    ["Inventory"] = "bx-box",
                                    ["HumanResources"] = "bx-user",
                                    ["Sales"] = "bx-shopping-bag",
                                    ["CustomerService"] = "bx-headphone",
                                    ["Marketing"] = "bx-trending-up",
                                    ["Executive"] = "bx-briefcase"
                                };
                                var categoryColors = new Dictionary<string, string>
                                {
                                    ["Finance"] = "danger",
                                    ["Inventory"] = "warning",
                                    ["HumanResources"] = "success",
                                    ["Sales"] = "primary",
                                    ["CustomerService"] = "info",
                                    ["Marketing"] = "dark",
                                    ["Executive"] = "secondary"
                                };
                            }
                            @foreach (var cat in ViewBag.ByCategory)
                            {
                                var catKey = cat.Category != null ? cat.Category.ToString() : "";
                                string iconVal, colorVal;
                                categoryIcons.TryGetValue(catKey, out iconVal);
                                iconVal ??= "bx-bell";
                                categoryColors.TryGetValue(catKey, out colorVal);
                                colorVal ??= "primary";
                                var pct = cat.Total > 0 ? (cat.Enabled * 100.0 / cat.Total) : 0;
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar avatar-sm bg-label-@colorVal">
                                                <span class="avatar-initial rounded-circle"><i class="icon-base @iconVal"></i></span>
                                            </div>
                                            <strong>@cat.Category</strong>
                                        </div>
                                    </td>
                                    <td class="text-center">@cat.Total</td>
                                    <td class="text-center"><span class="badge bg-success">@cat.Enabled</span></td>
                                    <td class="text-center"><span class="badge bg-secondary">@cat.Disabled</span></td>
                                    <td class="text-center">
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <div class="progress w-50" style="height: 6px;">
                                                <div class="progress-bar bg-@colorVal" style="width: @pct%"></div>
                                            </div>
                                            <small class="text-muted">@pct.ToString("N0")%</small>
                                        </div>
                                    </td>
                                    <td>
                                        <a asp-action="List" asp-route-category="@cat.Category" class="btn btn-outline-@colorVal btn-sm">
                                            <i class="icon-base bx bx-show"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
