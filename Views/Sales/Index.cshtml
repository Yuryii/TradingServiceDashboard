@model SalesDashboardViewModel
@{
  ViewData["Title"] = "Sales Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apexcharts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.SalesOverviewChart));
window.dashboardCharts.revenueChart = @Html.Raw(Json.Serialize(Model.SalesOverviewChart));
window.dashboardCharts.revenueBySalesperson = @Html.Raw(Json.Serialize(Model.RevenueBySalespersonChart));
window.dashboardCharts.revenueByChannel = @Html.Raw(Json.Serialize(Model.RevenueByChannelChart));
window.dashboardCharts.pipelineByStage = @Html.Raw(Json.Serialize(Model.PipelineByStageChart));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Sales Performance 🎉</h5>
            <p class="mb-6">Welcome to the Sales Dashboard. Track your revenue and orders.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Reports</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Sales Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="Sales" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalSales.Title</p>
            <h4 class="card-title mb-3">@Model.TotalSales.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalSales.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="Orders" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalOrders.Title</p>
            <h4 class="card-title mb-3">@Model.TotalOrders.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalOrders.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/Sales" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row">
  <div class="col-12 col-xxl-8 order-2 order-md-3 order-xxl-2 mb-6">
    <div class="card">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Sales Overview</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="salesChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="salesChart">
                <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.TargetAchievementPercent% Target Achievement</h6>
            </div>
            <div id="growthChart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-8 col-lg-12 col-xxl-4 order-3 order-md-2 mb-6">
    <div class="row">
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Revenue" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.NewCustomers.Title</p>
            <h4 class="card-title mb-3">@Model.NewCustomers.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.NewCustomers.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Deals" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu" aria-labelledby="cardOpt4">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.PendingDeals.Title</p>
            <h4 class="card-title mb-3">@Model.PendingDeals.Value</h4>
            <small class="text-warning fw-medium"><i class="icon-base bx bx-time"></i> @Model.PendingDeals.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/chart-success.png" alt="Win Rate" class="rounded" /></div>
              <div class="dropdown"><button class="btn p-0" type="button" id="cardWr" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div>
            </div>
            <p class="mb-1">@Model.WinRate.Title</p>
            <h4 class="card-title mb-3">@Model.WinRate.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-trophy"></i> @Model.WinRate.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/wallet-info.png" alt="AOV" class="rounded" /></div>
              <div class="dropdown"><button class="btn p-0" type="button" id="cardAov" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div>
            </div>
            <p class="mb-1">@Model.AverageOrderValue.Title</p>
            <h4 class="card-title mb-3">@Model.AverageOrderValue.Value</h4>
            <small class="text-primary fw-medium"><i class="icon-base bx bx-receipt"></i> Avg Order</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- KPI Cards Row 2 -->
<div class="row">
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/paypal.png" alt="GM" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardGm" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">@Model.GrossMargin.Title</p>
        <h4 class="card-title mb-2">@Model.GrossMargin.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-chart"></i> @Model.GrossMargin.TrendLabel</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/chart-success.png" alt="Target" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardTgt" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">@Model.SalesTargetAchievement.Title</p>
        <h4 class="card-title mb-2">@Model.SalesTargetAchievement.Value</h4>
        <small class="text-warning fw-medium"><i class="icon-base bx bx-target-lock"></i> @Model.SalesTargetAchievement.TrendLabel</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/wallet-info.png" alt="Sales Cycle" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardSc" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">Sales Cycle</p>
        <h4 class="card-title mb-2">28 days</h4>
        <small class="text-primary fw-medium"><i class="icon-base bx bx-time"></i> Average</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/cc-primary.png" alt="GM%" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardGmp" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">GM%</p>
        <h4 class="card-title mb-2">@Model.GrossMargin.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-trending-up"></i> Gross Margin</small>
      </div>
    </div>
  </div>
</div>

<!-- Charts Row 1: Pipeline Funnel + Forecast -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Pipeline Funnel</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="pipeOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="pipelineFunnelChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Sales Forecast</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="fcOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="forecastChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Charts Row 2: Salesperson Bar + Order Margin Scatter -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Revenue by Salesperson</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="spOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="salespersonBarChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Order Value vs Margin</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="scatterOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="orderMarginScatterChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Charts Row 3: Pareto + Sales Cycle Box Plot -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Pareto - Revenue by Customer (80/20)</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="paretoOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="paretoChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Revenue by Channel</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="chOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="revenueByChannelBarChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Chart Row 4: Salesperson x Product Heatmap -->
<div class="row">
  <div class="col-lg-12 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Salesperson x Product Heatmap</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="spmOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="salespersonProductHeatmap" style="min-height: 300px;"></div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6 col-lg-4 order-0 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Top Products</h5>
          <p class="card-subtitle">Best Selling Items</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.TopProducts.Any())
          {
            @foreach (var product in Model.TopProducts.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @product.IconBgClass"><i class="@product.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@product.Name</h6>
                    <small>@product.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0">@product.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-mobile-alt"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Electronics</h6>
                  <small>1,245 units</small>
                </div>
                <div class="user-progress"><h6 class="mb-0">$89,500</h6></div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-1 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Recent Orders</h5>
          <p class="card-subtitle">Latest Transactions</p>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="p-0 m-0">
          @if (Model.RecentOrders.Any())
          {
            @foreach (var order in Model.RecentOrders.Take(5))
            {
              <li class="d-flex align-items-center mb-6">
                <div class="avatar flex-shrink-0 me-3">
                  <img src="~/img/icons/unicons/wallet.png" alt="Order" class="rounded" />
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <small class="d-block">@order.Column1</small>
                    <h6 class="fw-normal mb-0">@order.Column3</h6>
                  </div>
                  <div class="user-progress d-flex align-items-center gap-2">
                    <h6 class="fw-normal mb-0">@order.Column4</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-6">
