@model SalesDashboardViewModel
@{
  ViewData["Title"] = "Sales Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Inject all charts *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
Object.assign(window.dashboardCharts, {
  orderChart: @Html.Raw(Json.Serialize(Model.SalesOverviewChart)),
  revenueChart: @Html.Raw(Json.Serialize(Model.SalesOverviewChart)),
  revenueBySalesperson: @Html.Raw(Json.Serialize(Model.RevenueBySalespersonChart)),
  revenueByChannel: @Html.Raw(Json.Serialize(Model.RevenueByChannelChart)),
  pipelineByStage: @Html.Raw(Json.Serialize(Model.PipelineByStageChart)),
  orderStatistics: { series: [], labels: [] },
  incomeChart: { series: [], categories: [] },
  expensesChart: { numericValue: 0 },
  profileReportChart: { series: [] }
});
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script src="~/js/dashboard-layout-manager.js"></script>
}

@* Layout Toolbar *@
<div class="d-flex align-items-center gap-2 mb-4">
  <a asp-action="ExportPdf" asp-route-from="@currentFrom" asp-route-to="@currentTo" class="btn btn-sm btn-danger" target="_blank">
    <i class="icon-base bx bxs-file-pdf me-1"></i> Export PDF
  </a>
  <button type="button" class="btn-layout-action" id="btn-layout-edit"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.toggleEditMode()">
    <i class="icon-base bx bx-palette me-1"></i> Customize Layout
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-save"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.saveLayout()">
    <i class="icon-base bx bx-check me-1"></i> Save
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-reset"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.resetLayout()">
    <i class="icon-base bx bx-refresh me-1"></i> Reset
  </button>
</div>

@* ============ DATE FILTER (outside grid — never resizable) ============ *@
<div id="sales-date-filter" class="card mb-4 sales-date-filter-card">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/Sales" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

@* ============ GRID ============ *@
<div id="sales-dashboard-grid-container" style="position: relative;">
  <div id="sales-dashboard-grid" class="grid-stack">

    @* ---- Row 0: Welcome (8) + Total Sales KPI (4) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-welcome"
         data-gs-x="0" data-gs-y="0" data-gs-width="8" data-gs-height="6">
      <div class="grid-stack-item-content card">
        <div class="d-flex align-items-start row">
          <div class="col-sm-7">
            <div class="card-body">
              <h5 class="card-title text-primary mb-3">Sales Performance 🎉</h5>
              <p class="mb-6">Welcome to the Sales Dashboard. Track your revenue and orders.</p>
              <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Reports</a>
            </div>
          </div>
          <div class="col-sm-5 text-center text-sm-left">
            <div class="card-body pb-0 px-0 px-md-6">
              <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Sales Dashboard" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-totalsales"
         data-gs-x="8" data-gs-y="0" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Sales" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.TotalSales.Title</p>
          <h4 class="card-title mb-3">@Model.TotalSales.Value</h4>
          <small class="text-@(Model.TotalSales.Trend == "up" ? "success" : Model.TotalSales.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.TotalSales.Trend == "up" ? "bx-up-arrow-alt" : Model.TotalSales.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.TotalSales.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-totalorders"
         data-gs-x="8" data-gs-y="3" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="Orders" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.TotalOrders.Title</p>
          <h4 class="card-title mb-3">@Model.TotalOrders.Value</h4>
          <small class="text-@(Model.TotalOrders.Trend == "up" ? "success" : Model.TotalOrders.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.TotalOrders.Trend == "up" ? "bx-up-arrow-alt" : Model.TotalOrders.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.TotalOrders.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Row 6: Sales Overview (8) + New Customers + Pending Deals (4) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-chart-overview"
         data-gs-x="0" data-gs-y="6" data-gs-width="8" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="row row-bordered g-0 h-100">
          <div class="col-lg-8">
            <div class="card-header d-flex align-items-center justify-content-between">
              <div class="card-title mb-0">
                <h5 class="m-0 me-2">Sales Overview</h5>
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="salesChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="salesChart">
                  <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                  <a class="dropdown-item" href="javascript:void(0);">This Month</a>
                </div>
              </div>
            </div>
            <div id="totalRevenueChart" class="px-3"></div>
          </div>
          <div class="col-lg-4">
            <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
              <div class="text-center mb-6">
                <h6 class="mb-0">@Model.TargetAchievementPercent% Target Achievement</h6>
              </div>
              <div id="growthChart"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-newcustomers"
         data-gs-x="8" data-gs-y="6" data-gs-width="4" data-gs-height="4">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/paypal.png" alt="Revenue" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.NewCustomers.Title</p>
          <h4 class="card-title mb-3">@Model.NewCustomers.Value</h4>
          <small class="text-@(Model.NewCustomers.Trend == "up" ? "success" : Model.NewCustomers.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.NewCustomers.Trend == "up" ? "bx-up-arrow-alt" : Model.NewCustomers.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.NewCustomers.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-pendingdeals"
         data-gs-x="8" data-gs-y="10" data-gs-width="4" data-gs-height="4">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/cc-primary.png" alt="Deals" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.PendingDeals.Title</p>
          <h4 class="card-title mb-3">@Model.PendingDeals.Value</h4>
          <small class="text-warning fw-medium"><i class="icon-base bx bx-time"></i> @Model.PendingDeals.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Row 14: Win Rate + AOV + Gross Margin + Sales Target (4 KPI cards, 3 each) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-kpi-winrate"
         data-gs-x="0" data-gs-y="14" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-3">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Win Rate" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.WinRate.Title</p>
          <h4 class="card-title mb-2">@Model.WinRate.Value</h4>
          <small class="text-@(Model.WinRate.Trend == "up" ? "success" : Model.WinRate.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx bx-trophy"></i> @Model.WinRate.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-aov"
         data-gs-x="3" data-gs-y="14" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-3">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="AOV" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.AverageOrderValue.Title</p>
          <h4 class="card-title mb-2">@Model.AverageOrderValue.Value</h4>
          <small class="text-primary fw-medium"><i class="icon-base bx bx-receipt"></i> Avg Order</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-grossmargin"
         data-gs-x="6" data-gs-y="14" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-3">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/paypal.png" alt="GM" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.GrossMargin.Title</p>
          <h4 class="card-title mb-2">@Model.GrossMargin.Value</h4>
          <small class="text-@(Model.GrossMargin.Trend == "up" ? "success" : Model.GrossMargin.Trend == "down" ? "danger" : Model.GrossMargin.Trend == "neutral" ? "primary" : "body-secondary") fw-medium"><i class="icon-base bx bx-chart"></i> @Model.GrossMargin.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-kpi-target"
         data-gs-x="9" data-gs-y="14" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-3">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Target" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.SalesTargetAchievement.Title</p>
          <h4 class="card-title mb-2">@Model.SalesTargetAchievement.Value</h4>
          <small class="text-warning fw-medium"><i class="icon-base bx bx-target-lock"></i> @Model.SalesTargetAchievement.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Row 20: Pipeline Funnel (6) + Forecast (6) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-chart-funnel"
         data-gs-x="0" data-gs-y="20" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Pipeline Funnel</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="pipeOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="pipelineFunnelChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-chart-forecast"
         data-gs-x="6" data-gs-y="20" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Sales Forecast</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="fcOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="forecastChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    @* ---- Row 28: Salesperson Bar (6) + Order Margin Scatter (6) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-chart-salesperson"
         data-gs-x="0" data-gs-y="28" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Revenue by Salesperson</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="spOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="salespersonBarChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-chart-ordermargin"
         data-gs-x="6" data-gs-y="28" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Order Value vs Margin</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="scatterOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="orderMarginScatterChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    @* ---- Row 36: Pareto (6) + Revenue by Channel (6) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-chart-pareto"
         data-gs-x="0" data-gs-y="36" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Pareto - Revenue by Customer (80/20)</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="paretoOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="paretoChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-chart-channel"
         data-gs-x="6" data-gs-y="36" data-gs-width="6" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Revenue by Channel</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="chOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="revenueByChannelBarChart" style="min-height: 280px;"></div>
        </div>
      </div>
    </div>

    @* ---- Row 44: Heatmap (full width 12) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-chart-heatmap"
         data-gs-x="0" data-gs-y="44" data-gs-width="12" data-gs-height="8">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Salesperson x Product Heatmap</h5>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="spmOpts" data-bs-toggle="dropdown">
              <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="salespersonProductHeatmap" style="min-height: 300px;"></div>
        </div>
      </div>
    </div>

    @* ---- Row 52: Top Products (4) + Recent Orders (4) + Sales Team (4) ---- *@
    <div class="grid-stack-item"
         data-widget-id="sales-top-products"
         data-gs-x="0" data-gs-y="52" data-gs-width="4" data-gs-height="10">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex justify-content-between">
          <div class="card-title mb-0">
            <h5 class="mb-1 me-2">Top Products</h5>
            <p class="card-subtitle">Best Selling Items</p>
          </div>
        </div>
        <div class="card-body">
          <ul class="p-0 m-0">
            @if (Model.TopProducts.Any())
            {
              @foreach (var product in Model.TopProducts.Take(5))
              {
                <li class="d-flex align-items-center mb-5">
                  <div class="avatar flex-shrink-0 me-3">
                    <span class="avatar-initial rounded @product.IconBgClass"><i class="@product.IconClass"></i></span>
                  </div>
                  <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                    <div class="me-2">
                      <h6 class="mb-0">@product.Name</h6>
                      <small>@product.Subtitle</small>
                    </div>
                    <div class="user-progress">
                      <h6 class="mb-0">@product.FormattedValue</h6>
                    </div>
                  </div>
                </li>
              }
            }
            else
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-mobile-alt"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">Electronics</h6>
                    <small>1,245 units</small>
                  </div>
                  <div class="user-progress"><h6 class="mb-0">$89,500</h6></div>
                </div>
              </li>
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="sales-recent-orders"
         data-gs-x="4" data-gs-y="52" data-gs-width="4" data-gs-height="10">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex justify-content-between">
