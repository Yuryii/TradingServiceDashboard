@model Dashboard.Models.ViewModels.DepartmentEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Department";
}

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Department</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Departments_Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="DepartmentID" />
          <input type="hidden" asp-for="CreatedAt" />

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="DepartmentCode" class="form-label">Department Code</label>
              <input asp-for="DepartmentCode" class="form-control" placeholder="e.g. D001" />
              <span asp-validation-for="DepartmentCode" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="DepartmentName" class="form-label">Department Name</label>
              <input asp-for="DepartmentName" class="form-control" placeholder="e.g. Human Resources" />
              <span asp-validation-for="DepartmentName" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Description" class="form-label">Description</label>
              <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description"></textarea>
              <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="IsActive" class="form-label">Status</label>
              <div class="form-check form-switch mb-2">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label class="form-check-label" for="IsActive">Active</label>
              </div>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="Departments_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
