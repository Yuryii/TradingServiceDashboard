@model IEnumerable<Dashboard.Models.ViewModels.DepartmentListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Departments";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Departments</h5>
        <div class="d-flex gap-1">
          <a asp-action="Department_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Department" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Departments_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Department
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Department Code</th>
              <th>Department Name</th>
              <th>Description</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  No departments found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var department in Model)
              {
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="avatar avatar-sm me-3">
                        <span class="avatar-initial rounded-circle bg-label-info">
                          @(department.DepartmentCode.Length > 0 ? department.DepartmentCode[0].ToString().ToUpper() : "?")
                        </span>
                      </div>
                      <div>
                        <strong>@department.DepartmentCode</strong>
                      </div>
                    </div>
                  </td>
                  <td><strong>@department.DepartmentName</strong></td>
                  <td>@(department.Description ?? "-")</td>
                  <td>
                    @if (department.IsActive)
                    {
                      <span class="badge bg-label-success me-1">Active</span>
                    }
                    else
                    {
                      <span class="badge bg-label-secondary me-1">Inactive</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Departments_Edit" asp-route-id="@department.DepartmentID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Departments_Delete" asp-route-id="@department.DepartmentID" method="post" onsubmit="return confirm('Are you sure you want to delete department: @department.DepartmentName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Department",
    EntityType = "Department",
    EntityName = "Department",
    EntityDisplayName = "Phong ban"
})
