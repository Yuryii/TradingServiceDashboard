@model IEnumerable<Dashboard.Models.ViewModels.RegionListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Regions";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Regions</h5>
        <div class="d-flex gap-1">
          <a asp-action="Region_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Region" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Regions_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Region
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Region Code</th>
              <th>Region Name</th>
              <th>Description</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  No regions found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var region in Model)
              {
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="avatar avatar-sm me-3">
                        <span class="avatar-initial rounded-circle bg-label-primary">
                          @(region.RegionCode.Length > 0 ? region.RegionCode[0].ToString().ToUpper() : "?")
                        </span>
                      </div>
                      <div>
                        <strong>@region.RegionCode</strong>
                      </div>
                    </div>
                  </td>
                  <td><strong>@region.RegionName</strong></td>
                  <td>@(region.Description ?? "-")</td>
                  <td>
                    @if (region.IsActive)
                    {
                      <span class="badge bg-label-success me-1">Active</span>
                    }
                    else
                    {
                      <span class="badge bg-label-secondary me-1">Inactive</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Regions_Edit" asp-route-id="@region.RegionID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Regions_Delete" asp-route-id="@region.RegionID" method="post" onsubmit="return confirm('Are you sure you want to delete region: @region.RegionName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Region",
    EntityType = "Region",
    EntityName = "Region",
    EntityDisplayName = "Khu vuc"
})
