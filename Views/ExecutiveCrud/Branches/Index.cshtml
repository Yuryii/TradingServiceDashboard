@model IEnumerable<Dashboard.Models.ViewModels.BranchListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Branches";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Branches</h5>
        <div class="d-flex gap-1">
          <a asp-action="Branch_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Branch" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Branches_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Branch
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Branch Code</th>
              <th>Branch Name</th>
              <th>Region</th>
              <th>City</th>
              <th>Type</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No branches found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var branch in Model)
              {
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="avatar avatar-sm me-3">
                        <span class="avatar-initial rounded-circle bg-label-success">
                          @(branch.BranchCode.Length > 0 ? branch.BranchCode[0].ToString().ToUpper() : "?")
                        </span>
                      </div>
                      <div>
                        <strong>@branch.BranchCode</strong>
                      </div>
                    </div>
                  </td>
                  <td><strong>@branch.BranchName</strong></td>
                  <td>@(branch.RegionName ?? "-")</td>
                  <td>@(branch.City ?? "-")</td>
                  <td>
                    @if (branch.IsHeadOffice)
                    {
                      <span class="badge bg-label-danger me-1">Head Office</span>
                    }
                    else
                    {
                      <span class="badge bg-label-secondary me-1">Branch</span>
                    }
                  </td>
                  <td>
                    @if (branch.IsActive)
                    {
                      <span class="badge bg-label-success me-1">Active</span>
                    }
                    else
                    {
                      <span class="badge bg-label-secondary me-1">Inactive</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Branches_Edit" asp-route-id="@branch.BranchID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Branches_Delete" asp-route-id="@branch.BranchID" method="post" onsubmit="return confirm('Are you sure you want to delete branch: @branch.BranchName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Branch",
    EntityType = "Branch",
    EntityName = "Branch",
    EntityDisplayName = "Chi nhanh"
})
