@model ExecutiveDashboardViewModel
@{
  ViewData["Title"] = "Executive Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.CompanyPerformanceChart));
window.dashboardCharts.profileReportChart = @Html.Raw(Json.Serialize(Model.ProfileReportChart));
window.dashboardCharts.revenueChart = @Html.Raw(Json.Serialize(Model.RevenueProfitAreaChart));
window.dashboardCharts.revenueProfitAreaChart = @Html.Raw(Json.Serialize(Model.RevenueProfitAreaChart));
window.dashboardCharts.bulletPlanChart = @Html.Raw(Json.Serialize(Model.BulletPlanChart));
window.dashboardCharts.profitBridgeChart = @Html.Raw(Json.Serialize(Model.ProfitBridgeChart));
window.dashboardCharts.topProductsBar = @Html.Raw(Json.Serialize(Model.TopProductsBarChart));
window.dashboardCharts.topCustomersBar = @Html.Raw(Json.Serialize(Model.TopCustomersBarChart));
window.dashboardCharts.salesFunnel = @Html.Raw(Json.Serialize(Model.SalesFunnelChart));
window.dashboardCharts.channelRegionHeatmap = @Html.Raw(Json.Serialize(Model.ChannelRegionHeatmap));
window.dashboardCharts.monthlyTargetVsActual = @Html.Raw(Json.Serialize(Model.MonthlyTargetVsActualChart));
window.dashboardCharts.revenueByBranch = @Html.Raw(Json.Serialize(Model.RevenueByBranchChart));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Executive Overview 🎉</h5>
            <p class="mb-6">Welcome to the Executive Dashboard. Here's your company-wide snapshot.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Reports</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Executive Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="Revenue" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                  <a class="dropdown-item" href="javascript:void(0);">Delete</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalRevenue.Title</p>
            <h4 class="card-title mb-3">@Model.TotalRevenue.Value</h4>
            <small class="text-@(Model.TotalRevenue.Trend == "up" ? "success" : "danger") fw-medium">
              <i class="icon-base bx @(Model.TotalRevenue.Trend == "up" ? "bx-up-arrow-alt" : "bx-down-arrow-alt")"></i> @Model.TotalRevenue.TrendLabel
            </small>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="Expenses" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                  <a class="dropdown-item" href="javascript:void(0);">Delete</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalExpenses.Title</p>
            <h4 class="card-title mb-3">@Model.TotalExpenses.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalExpenses.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/Executive?from=&to=" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row">
  <div class="col-12 col-xxl-8 order-2 order-md-3 order-xxl-2 mb-6">
    <div class="card">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Company Performance</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="performanceChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="performanceChart">
                <a class="dropdown-item" href="javascript:void(0);">Select All</a>
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.CompanyGrowthPercent% Company Growth</h6>
            </div>
            <div class="d-flex gap-11 justify-content-between">
              <div class="d-flex">
                <div class="avatar me-2">
                  <span class="avatar-initial rounded-2 bg-label-primary"><i class="icon-base bx bx-dollar icon-lg text-primary"></i></span>
                </div>
                <div class="d-flex flex-column">
                  <small>@(DateTime.Now.Year - 1)</small>
                  <h6 class="mb-0">@Model.LastYearRevenue.Value</h6>
                </div>
              </div>
              <div class="d-flex">
                <div class="avatar me-2">
                  <span class="avatar-initial rounded-2 bg-label-info"><i class="icon-base bx bx-wallet icon-lg text-info"></i></span>
                </div>
                <div class="d-flex flex-column">
                  <small>@(DateTime.Now.Year)</small>
                  <h6 class="mb-0">@Model.CurrentYearRevenue.Value</h6>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-8 col-lg-12 col-xxl-4 order-3 order-md-2 mb-6">
    <div class="row">
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Profit" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.NetProfit.Title</p>
            <h4 class="card-title mb-3">@Model.NetProfit.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.NetProfit.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Employees" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu" aria-labelledby="cardOpt4">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalEmployees.Title</p>
            <h4 class="card-title mb-3">@Model.TotalEmployees.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalEmployees.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="EBITDA" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOptEbitda" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptEbitda">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.Ebitda.Title</p>
            <h4 class="card-title mb-3">@Model.Ebitda.Value</h4>
            <small class="text-warning fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.Ebitda.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="DSO" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOptDso" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptDso">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.Dso.Title</p>
            <h4 class="card-title mb-3">@Model.Dso.Value</h4>
            <small class="text-primary fw-medium"><i class="icon-base bx bx-time"></i> @Model.Dso.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-12 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-sm-row flex-column gap-10 flex-wrap">
              <div class="d-flex flex-sm-column flex-row align-items-start justify-content-between">
                <div class="card-title mb-6">
                  <h5 class="text-nowrap mb-1">Yearly Summary</h5>
                  <span class="badge bg-label-warning">YEAR @DateTime.Now.Year</span>
                </div>
                <div class="mt-sm-auto">
                  <span class="text-success text-nowrap fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.CompanyGrowthPercent%</span>
                  <h4 class="mb-0">@Model.NetProfit.Value</h4>
                </div>
              </div>
              <div id="profileReportChart"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- KPI Cards Row -->
<div class="row">
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3">
          <div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/chart-success.png" alt="Gross Margin" class="rounded" /></div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardGm" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button>
            <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div>
          </div>
        </div>
        <p class="mb-1">@Model.GrossMargin.Title</p>
        <h4 class="card-title mb-2">@Model.GrossMargin.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.GrossMargin.TrendLabel</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3">
          <div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/wallet-info.png" alt="Cash Flow" class="rounded" /></div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardCf" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button>
            <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div>
          </div>
        </div>
