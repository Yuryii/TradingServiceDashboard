<!-- Charts Row 4: Sales Funnel + Channel x Region Heatmap -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Sales Funnel</h5>
        <div class="dropdown">
          <button class="btn p-0" type="button" id="funnelOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button>
          <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div>
        </div>
      </div>
      <div class="card-body">
        <div id="salesFunnelChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Channel x Region Heatmap</h5>
        <div class="dropdown">
          <button class="btn p-0" type="button" id="heatmapOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button>
          <div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div>
        </div>
      </div>
      <div class="card-body">
        <div id="channelRegionHeatmap" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Alerts Panel -->
@if (Model.Alerts.Any())
{
<div class="row">
  <div class="col-12 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Alerts & Warnings</h5>
        <span class="badge bg-label-danger">@Model.Alerts.Count active</span>
      </div>
      <div class="card-body">
        <div class="row g-3">
          @foreach (var alert in Model.Alerts)
          {
            <div class="col-md-6">
              <div class="alert alert-@alert.Type d-flex align-items-center" role="alert">
                <i class="icon-base bx @(alert.Severity == "red" ? "bx-error-circle text-danger" : alert.Severity == "yellow" ? "bx-warning text-warning" : "bx-info-circle text-info") me-2"></i>
                <div>
                  <strong>@alert.Message</strong>
                  <small class="d-block text-body-secondary">@alert.Source &middot; @alert.Timestamp.ToString("MMM dd, HH:mm")</small>
                </div>
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  </div>
</div>
}

<div class="row">
  <div class="col-md-6 col-lg-4 order-0 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Department Performance</h5>
          <p class="card-subtitle">All Departments Overview</p>
        </div>
        <div class="dropdown">
          <button class="btn text-body-secondary p-0" type="button" id="deptStats" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="icon-base bx bx-dots-vertical-rounded icon-lg"></i>
          </button>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="deptStats">
            <a class="dropdown-item" href="javascript:void(0);">Select All</a>
            <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
          </div>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @foreach (var dept in Model.DepartmentPerformance)
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded @dept.IconBgClass"><i class="@dept.IconClass"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">@dept.DepartmentName</h6>
                  <small>@dept.Description</small>
                </div>
                <div class="user-progress">
                  <h6 class="mb-0">@dept.PerformancePercent%</h6>
                </div>
              </div>
            </li>
          }
          @if (!Model.DepartmentPerformance.Any())
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-line-chart"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Sales</h6>
                  <small>Revenue Generation</small>
                </div>
                <div class="user-progress"><h6 class="mb-0">82.5%</h6></div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-1 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Quick Actions</h5>
        <div class="dropdown">
          <button class="btn text-body-secondary p-0" type="button" id="quickActions" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="icon-base bx bx-dots-vertical-rounded icon-lg"></i>
          </button>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="quickActions">
            <a class="dropdown-item" href="javascript:void(0);">Last 30 Days</a>
            <a class="dropdown-item" href="javascript:void(0);">Last Month</a>
          </div>
        </div>
      </div>
      <div class="card-body pt-4">
        <div class="d-grid gap-3">
          <a href="/Sales" class="btn btn-outline-primary">View Sales</a>
          <a href="/Marketing" class="btn btn-outline-success">View Marketing</a>
          <a href="/Finance" class="btn btn-outline-warning">View Finance</a>
          <a href="/Inventory" class="btn btn-outline-info">View Inventory</a>
          <a href="/HumanResources" class="btn btn-outline-secondary">View HR</a>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-2 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Recent Activity</h5>
        <div class="dropdown">
          <button class="btn text-body-secondary p-0" type="button" id="activity" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="icon-base bx bx-dots-vertical-rounded icon-lg"></i>
          </button>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="activity">
            <a class="dropdown-item" href="javascript:void(0);">View All</a>
          </div>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="p-0 m-0">
          @foreach (var activity in Model.RecentActivities)
          {
            <li class="d-flex align-items-center mb-6">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded @activity.IconBgClass"><i class="@activity.IconClass"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <small class="d-block">@activity.Category</small>
                  <h6 class="fw-normal mb-0">@activity.Description</h6>
                </div>
                <div class="user-progress d-flex align-items-center gap-2">
                  <small class="text-body-secondary">@activity.TimeAgo</small>
                </div>
              </div>
            </li>
          }
          @if (!Model.RecentActivities.Any())
          {
            <li class="d-flex align-items-center mb-6">
              <div class="avatar flex-shrink-0 me-3">
                <img src="~/img/icons/unicons/wallet.png" alt="User" class="rounded" />
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <small class="d-block">System</small>
                  <h6 class="fw-normal mb-0">No recent activity</h6>
                </div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>
</div>

@if (Model.RevenueProfitAreaChart?.Series?.Any() == true)
{
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Ensure config defaults are set before any chart uses them
  if (typeof config === 'undefined') window.config = {};
  if (!window.config.colors) window.config.colors = {};
  if (!window.config.fontFamily) window.config.fontFamily = 'Plus Jakarta Sans';
  var cardColor    = window.config.colors.cardColor    || '#ffffff';
  var headingColor = window.config.colors.headingColor || '#566a7f';
  var legendColor  = window.config.colors.bodyColor    || '#697a8d';
  var labelColor   = window.config.colors.textMuted   || '#a1acb8';
  var borderColor  = window.config.colors.borderColor  || '#eceef1';

  // Revenue & Profit Area Chart
  var revProfitData = @Html.Raw(Json.Serialize(Model.RevenueProfitAreaChart));
  var revProfitEl = document.querySelector('#revenueProfitAreaChart');
  if (revProfitEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(revProfitEl, {
      chart: { height: 280, type: 'area', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#71dd88', '#ff3e1d'],
      dataLabels: { enabled: false },
      stroke: { curve: 'smooth', width: 3 },
      legend: { show: true, position: 'top', horizontalAlign: 'left', fontSize: '13px', fontFamily: config.fontFamily, labels: { colors: legendColor }, markers: { size: 4, radius: 12, shape: 'circle' } },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: revProfitData.categories || [], labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 1000 ? '$' + (val/1000).toFixed(0) + 'K' : val) : val; } } },
      fill: { opacity: [0.85, 0.85], type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.5, gradientToColors: ['#71dd8844', '#ff3e1d44'], opacityFrom: 0.85, opacityTo: 0.55, stops: [0, 100] } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: revProfitData.series || []
    }).render();
  }

  // Monthly Target vs Actual Chart
  var targetData = @Html.Raw(Json.Serialize(Model.MonthlyTargetVsActualChart));
  var targetEl = document.querySelector('#monthlyTargetVsActualChart');
  if (targetEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(targetEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#6965fd', config.colors.secondary],
      dataLabels: { enabled: false },
      plotOptions: { bar: { horizontal: false, columnWidth: '35%', borderRadius: 6, borderRadiusApplication: 'around' } },
      legend: { show: true, position: 'top', horizontalAlign: 'left', fontSize: '13px', fontFamily: config.fontFamily, labels: { colors: legendColor }, markers: { size: 4, radius: 12, shape: 'circle' } },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: targetData.categories || [], labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 1000 ? '$' + (val/1000).toFixed(0) + 'K' : val) : val; } } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: targetData.series || []
    }).render();
  }

  // Top Products Bar Chart
  var topProdData = @Html.Raw(Json.Serialize(Model.TopProductsBarChart));
  var topProdEl = document.querySelector('#topProductsBar');
  if (topProdEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(topProdEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#6965fd'],
      dataLabels: { enabled: false },
      plotOptions: { bar: { horizontal: true, barHeight: '60%', borderRadius: 6, borderRadiusApplication: 'end' } },
      legend: { show: false },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: topProdData.categories || [], labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 1000 ? '$' + (val/1000).toFixed(0) + 'K' : val) : val; } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor } } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: topProdData.series || []
    }).render();
  }

  // Top Customers Bar Chart
  var topCustData = @Html.Raw(Json.Serialize(Model.TopCustomersBarChart));
  var topCustEl = document.querySelector('#topCustomersBar');
  if (topCustEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(topCustEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#03c3ec'],
      dataLabels: { enabled: false },
      plotOptions: { bar: { horizontal: true, barHeight: '60%', borderRadius: 6, borderRadiusApplication: 'end' } },
      legend: { show: false },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: topCustData.categories || [], labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 1000 ? '$' + (val/1000).toFixed(0) + 'K' : val) : val; } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor } } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: topCustData.series || []
    }).render();
  }

  // Profit Bridge Chart
  var bridgeData = @Html.Raw(Json.Serialize(Model.ProfitBridgeChart));
  var bridgeEl = document.querySelector('#profitBridgeChart');
  if (bridgeEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(bridgeEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: function(_val, opts) {
        var idx = opts.dataPointIndex;
        var cats = bridgeData.categories || [];
        if (cats[idx] && (cats[idx].includes('Profit') || cats[idx].includes('Period') || cats[idx].includes('Revenue'))) return '#71dd88';
        return '#ff3e1d';
      },
      dataLabels: { enabled: true, formatter: function(val, opts) { return typeof val === 'number' ? (val >= 0 ? '+$' + (val/1000).toFixed(0) + 'K' : '-$' + (Math.abs(val)/1000).toFixed(0) + 'K') : val; } },
      legend: { show: false },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: bridgeData.categories || [], labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor, rotate: -30 }, rotate: -30 }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 0 ? '+$' + (val/1000).toFixed(0) + 'K' : '-$' + (Math.abs(val)/1000).toFixed(0) + 'K') : val; } } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: bridgeData.series || []
    }).render();
  }

  // Revenue by Branch Chart
  var branchData = @Html.Raw(Json.Serialize(Model.RevenueByBranchChart));
  var branchEl = document.querySelector('#revenueByBranchChart');
  if (branchEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(branchEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: [config.colors.warning],
      dataLabels: { enabled: false },
      plotOptions: { bar: { horizontal: false, columnWidth: '40%', borderRadius: 6, borderRadiusApplication: 'around' } },
      legend: { show: false },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: branchData.categories || [], labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor }, formatter: function(val) { return typeof val === 'number' ? (val >= 1000 ? '$' + (val/1000).toFixed(0) + 'K' : val) : val; } } },
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } },
      series: branchData.series || []
    }).render();
  }

  // Sales Funnel Chart
  var funnelData = @Html.Raw(Json.Serialize(Model.SalesFunnelChart));
  var funnelEl = document.querySelector('#salesFunnelChart');
  if (funnelEl && typeof ApexCharts !== 'undefined') {
    new ApexCharts(funnelEl, {
      chart: { height: 280, type: 'bar', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#6965fd', '#03c3ec', '#71dd88', config.colors.warning, config.colors.secondary, '#ff3e1d'],
      dataLabels: { enabled: true, formatter: function(val, opts) { return typeof val === 'number' ? (val >= 1000 ? (val/1000).toFixed(0) + 'K' : val) : val; } },
      plotOptions: { bar: { horizontal: false, columnWidth: '60%', borderRadius: 6, borderRadiusApplication: 'end' } },
      legend: { show: true, position: 'top', horizontalAlign: 'left', fontSize: '12px', fontFamily: config.fontFamily, labels: { colors: legendColor } },
      grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { categories: funnelData.categories || [], labels: { style: { fontSize: '12px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } } },
      tooltip: { theme: 'dark' },
      series: funnelData.series || []
    }).render();
  }

  // Channel x Region Heatmap
  var heatmapData = @Html.Raw(Json.Serialize(Model.ChannelRegionHeatmap));
  var heatmapEl = document.querySelector('#channelRegionHeatmap');
  if (heatmapEl && typeof ApexCharts !== 'undefined') {
    var yCats = heatmapData.yCategories || [];
    new ApexCharts(heatmapEl, {
      chart: { height: 280, type: 'heatmap', toolbar: { show: false }, fontFamily: config.fontFamily, foreColor: labelColor },
      colors: ['#6965fd'],
      dataLabels: { enabled: false },
      stroke: { width: 1, colors: [cardColor] },
      legend: { show: true, position: 'top', horizontalAlign: 'left', fontSize: '12px', fontFamily: config.fontFamily, labels: { colors: legendColor } },
      grid: { padding: { top: -10, bottom: -10, left: 10, right: 10 } },
      xaxis: { labels: { style: { fontSize: '11px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false }, categories: heatmapData.xCategories || [] },
      yaxis: { labels: { style: { fontSize: '11px', fontFamily: config.fontFamily, colors: labelColor } } },
      plotOptions: { heatmap: { radius: 3, colorScale: { ranges: [{ from: 0, to: 0, name: 'None', color: '#f3f4f6' }, { from: 1, to: 50000, name: 'Low', color: '#dce6ff' }, { from: 50001, to: 200000, name: 'Medium', color: '#0984e3' }, { from: 200001, to: 1000000, name: 'High', color: '#012874' }] } } },
      series: yCats.map(function(yCat, i) { return { name: yCat, data: (heatmapData.data || []).filter(function(d) { return d.y === yCat; }).map(function(d) { return d.value || 0; }) }; }),
      tooltip: { theme: 'dark', y: { formatter: function(val) { return typeof val === 'number' ? '$' + val.toLocaleString() : val; } } }
    }).render();
  }
});
</script>
}

@if (Model.CompanyPerformanceChart?.Series?.Any() == true)
{
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var chartData = @Html.Raw(Json.Serialize(Model.CompanyPerformanceChart));
      var chartEl = document.querySelector('#totalRevenueChart');
      if (chartEl && typeof ApexCharts !== 'undefined') {
        var options = {
          chart: { height: 300, stacked: true, type: 'bar', toolbar: { show: false } },
          plotOptions: { bar: { horizontal: false, columnWidth: '30%', borderRadius: 8, borderRadiusApplication: 'around' } },
          colors: ['#6965fd', '#03c3ec'],
          dataLabels: { enabled: false },
          stroke: { curve: 'smooth', width: 6, lineCap: 'round', colors: [cardColor] },
          legend: { show: true, horizontalAlign: 'left', position: 'top', markers: { size: 4, radius: 12, shape: 'circle', strokeWidth: 0 }, fontSize: '13px', fontFamily: config.fontFamily, fontWeight: 400, labels: { colors: legendColor, useSeriesColors: false }, itemMargin: { horizontal: 10 } },
          grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: 0, bottom: -8, left: 20, right: 20 } },
          fill: { opacity: [1, 1] },
          xaxis: { categories: chartData.categories || [], labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
          yaxis: { labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } } },
          states: { hover: { filter: { type: 'none' } }, active: { filter: { type: 'none' } } },
          series: chartData.series || []
        };
        new ApexCharts(chartEl, options).render();
      }
    });
  </script>
}

