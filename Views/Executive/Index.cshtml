@if (Model.CompanyPerformanceChart?.Series?.Any() == true)
{
<script>
document.addEventListener('DOMContentLoaded', function () {
  var chartData = @Html.Raw(Json.Serialize(Model.CompanyPerformanceChart));
  var chartEl = document.querySelector('#totalRevenueChart');
  if (chartEl && typeof ApexCharts !== 'undefined') {
    var options = {
      chart: { height: 200, stacked: true, type: 'bar', toolbar: { show: false } },
      plotOptions: { bar: { horizontal: false, columnWidth: '30%', borderRadius: 8, borderRadiusApplication: 'around' } },
      colors: ['#6965fd', '#03c3ec'],
      dataLabels: { enabled: false },
      stroke: { curve: 'smooth', width: 6, lineCap: 'round', colors: ['#ffffff'] },
      legend: { show: true, horizontalAlign: 'left', position: 'top', markers: { size: 4, radius: 12, shape: 'circle', strokeWidth: 0 }, fontSize: '13px', fontFamily: 'Plus Jakarta Sans', fontWeight: 400, labels: { colors: '#697a8d', useSeriesColors: false }, itemMargin: { horizontal: 10 } },
      grid: { strokeDashArray: 7, borderColor: '#eceef1', padding: { top: 0, bottom: -8, left: 20, right: 20 } },
      fill: { opacity: [1, 1] },
      xaxis: { categories: chartData.categories || [], labels: { style: { fontSize: '13px', fontFamily: 'Plus Jakarta Sans', colors: '#a1acb8' } }, axisTicks: { show: false }, axisBorder: { show: false } },
      yaxis: { labels: { style: { fontSize: '13px', fontFamily: 'Plus Jakarta Sans', colors: '#a1acb8' } } },
      states: { hover: { filter: { type: 'none' } }, active: { filter: { type: 'none' } } },
      series: chartData.series || []
    };
    var chart = new ApexCharts(chartEl, options);
    chart.render().then(function() {
      var widgetId = chartEl.closest('.grid-stack-item')?.getAttribute('data-widget-id');
      if (widgetId) {
        window.dashboardChartInstances = window.dashboardChartInstances || {};
        window.dashboardChartInstances[widgetId] = chart;
      }
    });
  }
});
</script>
}

