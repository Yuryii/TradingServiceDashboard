@* ============================================================
   PART 4: GridStack Layout Manager Init
   ============================================================ *@
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Initialize the Dashboard Layout Manager
  window.dashboardLayoutManager = new DashboardLayoutManager('dashboard-grid', {
    storageKey: 'executive-dashboard-layout-v3',
    editMode: false,
    animate: true,
    gap: 20,
    onLayoutChange: function(layout) {
      console.log('Layout changed:', layout);
    }
  });

  // Override toggle to also update UI buttons
  var originalToggle = window.dashboardLayoutManager.toggleEditMode.bind(window.dashboardLayoutManager);
  window.dashboardLayoutManager.toggleEditMode = function() {
    var isEditing = originalToggle();
    var editBtn = document.getElementById('btn-layout-edit');
    var resetBtn = document.getElementById('btn-layout-reset');
    var saveBtn = document.getElementById('btn-layout-save');
    var container = document.getElementById('dashboard-grid-container');

    if (isEditing) {
      if (editBtn) {
        editBtn.classList.add('editing');
        editBtn.innerHTML = '<i class="icon-base bx bx-check"></i> Done Editing';
      }
      if (resetBtn) resetBtn.style.display = '';
      if (saveBtn) saveBtn.style.display = '';
      if (container) container.classList.add('grid-edit-mode');
    } else {
      if (editBtn) {
        editBtn.classList.remove('editing');
        editBtn.innerHTML = '<i class="icon-base bx bx-edit-alt"></i> Customize Layout';
      }
      if (resetBtn) resetBtn.style.display = 'none';
      if (saveBtn) saveBtn.style.display = 'none';
      if (container) container.classList.remove('grid-edit-mode');
    }
  };

  // Override save to show notification
  var originalSave = window.dashboardLayoutManager.saveToStorage.bind(window.dashboardLayoutManager);
  window.dashboardLayoutManager.saveLayout = function() {
    originalSave();
    // Show toast notification if toastr is available
    if (typeof toastr !== 'undefined') {
      toastr.success('Layout saved successfully!', '', { timeOut: 2000 });
    } else {
      var editBtn = document.getElementById('btn-layout-edit');
      if (editBtn) {
        editBtn.innerHTML = '<i class="icon-base bx bx-check-circle"></i> Saved!';
        setTimeout(function() {
          editBtn.innerHTML = '<i class="icon-base bx bx-edit-alt"></i> Customize Layout';
        }, 2000);
      }
    }
  };
});

function setRange(type) {
    var today = new Date();
    var toInput = document.querySelector('form[method="get"] input[name="to"]');
    var fromInput = document.querySelector('form[method="get"] input[name="from"]');
    if (!fromInput || !toInput) return;

    var to = new Date(today);
    var from = new Date(today);

    if (type === 'today') {
        from = new Date(today.getFullYear(), today.getMonth(), today.getDate());
        to = from;
    } else if (type === 'week') {
        var day = today.getDay();
        var diff = today.getDate() - day + (day === 0 ? -6 : 1);
        from = new Date(today.getFullYear(), today.getMonth(), diff);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    } else if (type === 'month') {
        from = new Date(today.getFullYear(), today.getMonth(), 1);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    } else if (type === 'ytd') {
        from = new Date(today.getFullYear(), 0, 1);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    }

    fromInput.value = from.toISOString().split('T')[0];
    toInput.value = to.toISOString().split('T')[0];
    fromInput.closest('form').submit();
}
</script>

