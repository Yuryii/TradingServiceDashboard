@model IEnumerable<Dashboard.Models.ViewModels.SupportTicketListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Support Tickets";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Support Tickets</h5>
        <div class="d-flex gap-1">
          <a asp-action="SupportTicket_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-SupportTicket" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="SupportTickets_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Ticket
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Ticket #</th>
              <th>Subject</th>
              <th>Customer</th>
              <th>Priority</th>
              <th>Status</th>
              <th>Created Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No support tickets found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.TicketNumber</strong></td>
                  <td>@item.Subject</td>
                  <td>@(item.CustomerName ?? "-")</td>
                  <td>
                    @{
                      var priorityClass = item.Priority switch
                      {
                        "Low" => "bg-label-secondary",
                        "Medium" => "bg-label-info",
                        "High" => "bg-label-warning",
                        "Critical" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @priorityClass">@item.Priority</span>
                  </td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Open" => "bg-label-info",
                        "InProgress" => "bg-label-warning",
                        "Resolved" => "bg-label-success",
                        "Closed" => "bg-label-secondary",
                        "Pending" => "bg-label-warning",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="SupportTickets_Edit" asp-route-id="@item.TicketID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="SupportTickets_Delete" asp-route-id="@item.TicketID" method="post" onsubmit="return confirm('Are you sure you want to delete this support ticket?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "SupportTicket",
    EntityType = "SupportTicket",
    EntityName = "SupportTicket",
    EntityDisplayName = "Phieu ho tro"
})
