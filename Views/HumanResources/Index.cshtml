@model HumanResourcesDashboardViewModel
@{
  ViewData["Title"] = "Human Resources Dashboard";
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.WorkforceOverviewChart));
window.dashboardCharts.headcountTrendArea = @Html.Raw(Json.Serialize(Model.HeadcountTrendAreaChart));
window.dashboardCharts.headcountStacked = @Html.Raw(Json.Serialize(Model.HeadcountStackedChart));
window.dashboardCharts.turnoverTrend = @Html.Raw(Json.Serialize(Model.TurnoverTrendChart));
window.dashboardCharts.recruitmentFunnel = @Html.Raw(Json.Serialize(Model.RecruitmentFunnelChart));
window.dashboardCharts.recruitmentMetrics = @Html.Raw(Json.Serialize(Model.RecruitmentMetricsChart));
window.dashboardCharts.salaryDistribution = @Html.Raw(Json.Serialize(Model.SalaryDistributionChart));
window.dashboardCharts.training = @Html.Raw(Json.Serialize(Model.TrainingChart));
window.dashboardCharts.engagementTrend = @Html.Raw(Json.Serialize(Model.EngagementTrendChart));
window.dashboardCharts.attritionHeatmap = @Html.Raw(Json.Serialize(Model.AttritionHeatmap));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script src="~/js/dashboard-layout-manager.js"></script>
}

<!-- Layout Toolbar -->
<div class="d-flex align-items-center gap-2 mb-4">
  <button type="button" class="btn-layout-action" id="btn-layout-edit"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.toggleEditMode()">
    <i class="icon-base bx bx-palette me-1"></i> Customize Layout
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-save"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.saveLayout()">
    <i class="icon-base bx bx-check me-1"></i> Save
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-reset"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.resetLayout()">
    <i class="icon-base bx bx-refresh me-1"></i> Reset
  </button>
</div>

<div id="hr-dashboard-grid-container" style="position: relative;">
<div id="hr-dashboard-grid" class="grid-stack">
  <!-- HR Welcome Card -->
  <div class="grid-stack-item" data-widget-id="hr-welcome" data-gs-x="0" data-gs-y="0" data-gs-width="8" data-gs-height="6">
    <div class="grid-stack-item-content card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">HR Overview 👥</h5>
            <p class="mb-6">Welcome to the Human Resources Dashboard. Manage your workforce.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Employees</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="HR Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Total Employees KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-employees" data-gs-x="8" data-gs-y="0" data-gs-width="4" data-gs-height="3">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/chart-success.png" alt="Employees" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">@Model.TotalEmployees.Title</p>
        <h4 class="card-title mb-3">@Model.TotalEmployees.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalEmployees.TrendLabel</small>
      </div>
    </div>
  </div>

  <!-- Departments KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-departments" data-gs-x="8" data-gs-y="3" data-gs-width="4" data-gs-height="3">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/wallet-info.png" alt="Departments" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">@Model.Departments.Title</p>
        <h4 class="card-title mb-3">@Model.Departments.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-buildings"></i> @Model.Departments.TrendLabel</small>
      </div>
    </div>
  </div>

  <!-- Avg Salary KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-avg-salary" data-gs-x="0" data-gs-y="6" data-gs-width="3" data-gs-height="6">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/dollar.png" alt="Avg Salary" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="kpiOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="kpiOpt1">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">Avg Salary</p>
        <h4 class="card-title mb-3">@Model.AvgSalary.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.AvgSalary.TrendLabel</small>
      </div>
    </div>
  </div>

  <!-- Absenteeism KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-absenteeism" data-gs-x="3" data-gs-y="6" data-gs-width="3" data-gs-height="6">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/chart-warning.png" alt="Absenteeism" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="kpiOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="kpiOpt2">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">Absenteeism</p>
        <h4 class="card-title mb-3">3.2%</h4>
        <small class="text-danger fw-medium"><i class="icon-base bx bx-down-arrow-alt"></i> -0.3% vs last month</small>
      </div>
    </div>
  </div>

  <!-- OT Hours KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-ot-hours" data-gs-x="6" data-gs-y="6" data-gs-width="3" data-gs-height="6">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/clock.png" alt="OT Hours" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="kpiOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="kpiOpt3">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">OT Hours</p>
        <h4 class="card-title mb-3">45h</h4>
        <small class="text-warning fw-medium"><i class="icon-base bx bx-time"></i> Avg 2.5h/week</small>
      </div>
    </div>
  </div>

  <!-- Revenue per Employee KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-revenue-per-employee" data-gs-x="9" data-gs-y="6" data-gs-width="3" data-gs-height="6">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/chart-success.png" alt="Revenue per Employee" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="kpiOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="kpiOpt4">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">Revenue per Employee</p>
        <h4 class="card-title mb-3">$85K</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> +12% YoY</small>
      </div>
    </div>
  </div>

  <!-- Workforce Overview Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-workforce" data-gs-x="0" data-gs-y="12" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Workforce Overview</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="hrChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="hrChart">
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
                <a class="dropdown-item" href="javascript:void(0);">This Year</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.RetentionRatePercent% Retention Rate</h6>
            </div>
            <div id="growthChart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- New Hires KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-new-hires" data-gs-x="6" data-gs-y="12" data-gs-width="3" data-gs-height="4">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/paypal.png" alt="New Hires" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">@Model.NewHires.Title</p>
        <h4 class="card-title mb-3">@Model.NewHires.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.NewHires.TrendLabel</small>
      </div>
    </div>
  </div>

  <!-- Open Positions KPI -->
  <div class="grid-stack-item" data-widget-id="hr-kpi-open-positions" data-gs-x="9" data-gs-y="12" data-gs-width="3" data-gs-height="4">
    <div class="grid-stack-item-content card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/cc-primary.png" alt="Open Positions" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu" aria-labelledby="cardOpt4">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
        <p class="mb-1">@Model.OpenPositions.Title</p>
        <h4 class="card-title mb-3">@Model.OpenPositions.Value</h4>
        <small class="text-warning fw-medium"><i class="icon-base bx bx-time"></i> @Model.OpenPositions.TrendLabel</small>
      </div>
    </div>
  </div>

  <!-- Headcount Trend Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-headcount" data-gs-x="0" data-gs-y="20" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Headcount Trend</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="headcountTrendAreaChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Turnover Trend Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-turnover" data-gs-x="6" data-gs-y="20" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Turnover Trend</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="turnoverTrendChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Recruitment Funnel Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-recruitment-funnel" data-gs-x="0" data-gs-y="28" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Recruitment Funnel</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="recruitmentFunnelChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Recruitment Metrics Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-recruitment-metrics" data-gs-x="6" data-gs-y="28" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Time-to-Hire & Cost-per-Hire</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="recruitmentMetricsChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Salary Distribution Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-salary" data-gs-x="0" data-gs-y="36" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Salary Distribution</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="salaryDistributionChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Training Chart -->
  <div class="grid-stack-item" data-widget-id="hr-chart-training" data-gs-x="6" data-gs-y="36" data-gs-width="6" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Training Hours</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="trainingChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Engagement Trend Chart (Full Width) -->
  <div class="grid-stack-item" data-widget-id="hr-chart-engagement" data-gs-x="0" data-gs-y="44" data-gs-width="12" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Engagement & eNPS Trend</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="engagementTrendChart" class="apex-charts" style="height: 280px;"></div>
      </div>
    </div>
  </div>

  <!-- Attrition Heatmap Chart (Full Width) -->
  <div class="grid-stack-item" data-widget-id="hr-chart-attrition" data-gs-x="0" data-gs-y="52" data-gs-width="12" data-gs-height="8">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Attrition by Department & Tenure</h5>
        </div>
      </div>
      <div class="card-body">
        <div id="attritionHeatmapChart" class="apex-charts" style="height: 320px;"></div>
      </div>
    </div>
  </div>

  <!-- Department Distribution Card -->
  <div class="grid-stack-item" data-widget-id="hr-card-department-dist" data-gs-x="0" data-gs-y="60" data-gs-width="4" data-gs-height="10">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Department Distribution</h5>
          <p class="card-subtitle">Employees by Department</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.DepartmentDistribution.Any())
          {
            @foreach (var dept in Model.DepartmentDistribution.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @dept.IconBgClass"><i class="@dept.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@dept.Name</h6>
                    <small>@dept.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0">@dept.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-line-chart"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Sales</h6>
                  <small>52 employees</small>
                </div>
                <div class="user-progress">
                  <h6 class="mb-0">21%</h6>
                </div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- Recent Hires Card -->
  <div class="grid-stack-item" data-widget-id="hr-card-recent-hires" data-gs-x="4" data-gs-y="60" data-gs-width="4" data-gs-height="10">
    <div class="grid-stack-item-content card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Recent Hires</h5>
          <p class="card-subtitle">New Employees</p>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="p-0 m-0">
          @if (Model.RecentHires.Any())
          {
            @foreach (var hire in Model.RecentHires.Take(5))
            {
              <li class="d-flex align-items-center mb-6">
                <div class="avatar flex-shrink-0 me-3">
                  <img src="~/img/icons/unicons/wallet.png" alt="@hire.Column1" class="rounded" />
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <small class="d-block">@hire.Column1</small>
                    <h6 class="fw-normal mb-0">@hire.Column3</h6>
                  </div>
                  <div class="user-progress d-flex align-items-center gap-2">
                    <span class="badge @hire.BadgeClass">@hire.Column4</span>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-6">
              <div class="avatar flex-shrink-0 me-3">
