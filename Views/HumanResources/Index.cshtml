<!-- Dashboard Layout Manager Initialization -->
<script>
document.addEventListener('DOMContentLoaded', function () {
  var el = document.getElementById('hr-dashboard-grid');
  if (el && typeof DashboardLayoutManager !== 'undefined') {
    window.dashboardLayoutManager = new DashboardLayoutManager('hr-dashboard-grid', {
      storageKey: 'hr-dashboard-layout-v2',
      editMode: false,
      gap: 20,
      cellHeight: 60
    });

    var origToggle = window.dashboardLayoutManager.toggleEditMode.bind(window.dashboardLayoutManager);
    window.dashboardLayoutManager.toggleEditMode = function () {
      var editing = origToggle();
      var editBtn = document.getElementById('btn-layout-edit');
      if (editBtn) editBtn.classList.toggle('editing', editing);
    };

    var origSave = window.dashboardLayoutManager.saveLayout.bind(window.dashboardLayoutManager);
    window.dashboardLayoutManager.saveLayout = function () {
      origSave();
      if (typeof toastr !== 'undefined') toastr.success('Dashboard layout saved.');
    };
  }
});
</script>

