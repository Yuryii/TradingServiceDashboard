@model IEnumerable<Dashboard.Models.ViewModels.UserListVM>
@{
  ViewData["Title"] = "User Management";
}
<div class="row">  <div class="col-12">    <div class="card">      <div class="card-header d-flex justify-content-between align-items-center">        <h5 class="mb-0">All Users</h5>        <a asp-action="Create" class="btn btn-primary">          <i class="icon-base bx bx-plus me-1"></i> Create New User        </a>      </div>      <div class="table-responsive text-nowrap">        <table class="table">          <thead>            <tr>              <th>Full Name</th>              <th>Email</th>              <th>Phone</th>              <th>Roles</th>              <th>Actions</th>            </tr>          </thead>          <tbody class="table-border-bottom-0">            @if (!Model.Any())            {              <tr>                <td colspan="5" class="text-center text-muted py-4">                  No users found.                </td>              </tr>            }            else            {              @foreach (var user in Model)              {                <tr>                  <td>                    <div class="d-flex align-items-center">                      <div class="avatar avatar-sm me-3">                        <span class="avatar-initial rounded-circle bg-label-primary">                          @(user.FullName?.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?")                        </span>                      </div>                      <div>                        <strong>@(user.FullName ?? "-")</strong>                        <div class="text-muted" style="font-size:0.75rem;">@@@(user.UserName)</div>                      </div>                    </div>                  </td>                  <td>@user.Email</td>                  <td>@(user.PhoneNumber ?? "-")</td>                  <td>                    @if (user.Roles.Any())                    {                      @foreach (var role in user.Roles)                      {                        var badgeClass = role switch                        {                          "Executive" => "bg-label-danger",                          "Sales" => "bg-label-success",                          "Marketing" => "bg-label-info",                          "Finance" => "bg-label-warning",                          "Inventory" => "bg-label-secondary",                          "HumanResources" => "bg-label-primary",                          "CustomerService" => "bg-label-dark",                          _ => "bg-label-secondary"                        };                        <span class="badge @badgeClass me-1 mb-1">@role</span>                      }                    }                    else                    {                      <span class="text-muted">No role</span>                    }                  </td>                  <td>                    <div class="dropdown">                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">                        <i class="icon-base bx bx-dots-vertical-rounded"></i>                      </button>                      <div class="dropdown-menu">                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@user.Id">                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit                        </a>                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete user: @user.Email?');" style="display:inline;">                          @Html.AntiForgeryToken()                          <button type="submit" class="dropdown-item text-danger">                            <i class="icon-base bx bx-trash me-1"></i> Delete                          </button>                        </form>                      </div>                    </div>                  </td>                </tr>              }            }          </tbody>        </table>      </div>    </div>  </div></div>