@model IEnumerable<Dashboard.Models.ViewModels.MarketingCampaignListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Marketing Campaigns";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Marketing /</span> Marketing Campaigns
    </h4>
  </div>
</div>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Campaigns</h5>
        <div class="d-flex gap-1">
          <a asp-action="MarketingCampaign_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-MarketingCampaign" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="MarketingCampaignsCreate" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Campaign
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Code</th>
              <th>Campaign Name</th>
              <th>Channel</th>
              <th>Budget</th>
              <th>Actual Spend</th>
              <th>Status</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Active</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="10" class="text-center text-muted py-4">
                  No campaigns found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.CampaignCode</strong></td>
                  <td>@item.CampaignName</td>
                  <td>@item.Channel</td>
                  <td>@item.Budget.ToString("N2")</td>
                  <td>@item.ActualSpend.ToString("N2")</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Planned" => "bg-label-secondary",
                        "Active" => "bg-label-success",
                        "Completed" => "bg-label-primary",
                        "Cancelled" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                  <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    @if (item.IsActive)
                    {
                      <span class="badge bg-label-success">Yes</span>
                    }
                    else
                    {
                      <span class="badge bg-label-danger">No</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="MarketingCampaignsEdit" asp-route-id="@item.CampaignID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="MarketingCampaignsDelete" asp-route-id="@item.CampaignID" method="post" onsubmit="return confirm('Are you sure you want to delete campaign: @item.CampaignName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@{
    var mcModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "MarketingCampaign",
        EntityType = "MarketingCampaign",
        EntityName = "MarketingCampaign",
        EntityDisplayName = "Chien dich marketing"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="mcModal" />
