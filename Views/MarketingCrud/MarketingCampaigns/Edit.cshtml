@model Dashboard.Models.ViewModels.MarketingCampaignEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Marketing Campaign";
}

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Marketing Campaign</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="MarketingCampaignsEdit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="CampaignID" />
          <input type="hidden" asp-for="CreatedAt" />

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="CampaignCode" class="form-label">Campaign Code</label>
              <input asp-for="CampaignCode" class="form-control" />
              <span asp-validation-for="CampaignCode" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CampaignName" class="form-label">Campaign Name</label>
              <input asp-for="CampaignName" class="form-control" />
              <span asp-validation-for="CampaignName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Channel" class="form-label">Channel</label>
              <input asp-for="Channel" class="form-control" />
              <span asp-validation-for="Channel" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Planned">Planned</option>
                <option value="Active">Active</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="StartDate" class="form-label">Start Date</label>
              <input asp-for="StartDate" class="form-control" type="date" />
              <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="EndDate" class="form-label">End Date</label>
              <input asp-for="EndDate" class="form-control" type="date" />
              <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Budget" class="form-label">Budget</label>
              <input asp-for="Budget" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="Budget" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ActualSpend" class="form-label">Actual Spend</label>
              <input asp-for="ActualSpend" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="ActualSpend" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Objective" class="form-label">Objective</label>
              <textarea asp-for="Objective" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Objective" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <div class="form-check form-switch mb-2">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
              </div>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="MarketingCampaignsIndex" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
