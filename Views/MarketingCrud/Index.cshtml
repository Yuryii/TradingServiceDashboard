@model Dashboard.Controllers.MarketingCrudDashboardVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Marketing CRUD";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Marketing /</span> Data Management
    </h4>
  </div>
</div>
<div class="row">
  <!-- Marketing Campaigns -->
  <div class="col-lg-4 col-md-6 mb-4">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="icon-base bx bx megaphone text-info me-1"></i> Marketing Campaigns</h5>
        <span class="badge bg-info rounded-pill">@Model.TotalCampaigns total</span>
      </div>
      <div class="card-body">
        <p class="card-text">
          <span class="fw-semibold">@Model.ActiveCampaigns</span> active campaigns
        </p>
        <a asp-action="MarketingCampaignsIndex" class="btn btn-outline-info btn-sm mt-2">
          <i class="icon-base bx bx-list-ul me-1"></i> Manage Campaigns
        </a>
        <a asp-action="MarketingCampaignsCreate" class="btn btn-info btn-sm mt-2 ms-2">
          <i class="icon-base bx bx-plus me-1"></i> Create
        </a>
      </div>
    </div>
  </div>
  <!-- Marketing Leads -->
  <div class="col-lg-4 col-md-6 mb-4">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="icon-base bx bx-user-pin text-success me-1"></i> Marketing Leads</h5>
        <span class="badge bg-success rounded-pill">@Model.TotalLeads total</span>
      </div>
      <div class="card-body">
        <p class="card-text">
          Track and manage your marketing leads pipeline.
        </p>
        <a asp-action="MarketingLeadsIndex" class="btn btn-outline-success btn-sm mt-2">
          <i class="icon-base bx bx-list-ul me-1"></i> Manage Leads
        </a>
        <a asp-action="MarketingLeadsCreate" class="btn btn-success btn-sm mt-2 ms-2">
          <i class="icon-base bx bx-plus me-1"></i> Create
        </a>
      </div>
    </div>
  </div>
  <!-- Marketing Spend Daily -->
  <div class="col-lg-4 col-md-12 mb-4">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="icon-base bx bx-money text-warning me-1"></i> Marketing Spend Daily</h5>
        <span class="badge bg-warning rounded-pill text-dark">@Model.TotalSpend.ToString("N0") spent</span>
      </div>
      <div class="card-body">
        <p class="card-text">
          Track daily marketing spend and performance metrics.
        </p>
        <a asp-action="MarketingSpendDailiesIndex" class="btn btn-outline-warning btn-sm mt-2">
          <i class="icon-base bx bx-list-ul me-1"></i> Manage Spend
        </a>
        <a asp-action="MarketingSpendDailiesCreate" class="btn btn-warning btn-sm mt-2 ms-2 text-white">
          <i class="icon-base bx bx-plus me-1"></i> Create
        </a>
      </div>
    </div>
  </div>
</div>
