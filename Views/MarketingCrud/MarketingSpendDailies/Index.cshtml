@model IEnumerable<Dashboard.Models.ViewModels.MarketingSpendDailyListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Marketing Spend Daily";
}
<div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Marketing Spend Daily</h5>
        <div class="d-flex gap-1">
          <a asp-action="MarketingSpendDailies_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-MarketingSpendDaily" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="MarketingSpendDailies_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Campaign</th>
              <th>Amount</th>
              <th>Impressions</th>
              <th>Clicks</th>
              <th>Conversions</th>
              <th>CPM</th>
              <th>CPC</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @foreach (var item in Model)
            {
              <tr>
                <td>@item.CampaignName</td>
                <td>@item.Amount.ToString("N0")</td>
                <td>@(item.Impressions?.ToString("N0") ?? "-")</td>
                <td>@(item.Clicks?.ToString("N0") ?? "-")</td>
                <td>@(item.Conversions?.ToString("N0") ?? "-")</td>
                <td>@(item.CPM?.ToString("N2") ?? "-")</td>
                <td>@(item.CPC?.ToString("N2") ?? "-")</td>
                <td>@item.SpendDate.ToString("yyyy-MM-dd")</td>
                <td>
                  <div class="dropdown">
                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                      <i class="icon-base bx bx-dots-vertical-rounded"></i>
                    </button>
                    <div class="dropdown-menu">
                      <a class="dropdown-item" asp-action="MarketingSpendDailies_Edit" asp-route-id="@item.SpendID">
                        <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                      </a>
                      <form asp-action="MarketingSpendDailies_Delete" asp-route-id="@item.SpendID" method="post" onsubmit="return confirm('Are you sure?');" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger">
                          <i class="icon-base bx bx-trash me-1"></i> Delete
                        </button>
                      </form>
                    </div>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
    </div>
  </div>
</div>
@{
    var msdModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "MarketingSpendDaily",
        EntityType = "MarketingSpendDaily",
        EntityName = "MarketingSpendDaily",
        EntityDisplayName = "Chi phi marketing hang ngay"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="msdModal" />
