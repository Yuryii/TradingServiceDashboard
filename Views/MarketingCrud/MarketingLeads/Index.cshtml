@model IEnumerable<Dashboard.Models.ViewModels.MarketingLeadListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Marketing Leads";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Marketing /</span> Marketing Leads
    </h4>
  </div>
</div>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Leads</h5>
        <div class="d-flex gap-1">
          <a asp-action="MarketingLead_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-MarketingLead" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="MarketingLeadsCreate" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Lead
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Lead Code</th>
              <th>Lead Name</th>
              <th>Company</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Status</th>
              <th>Score</th>
              <th>Campaign</th>
              <th>Created Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="10" class="text-center text-muted py-4">
                  No leads found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.LeadCode</strong></td>
                  <td>@item.LeadName</td>
                  <td>@item.CompanyName</td>
                  <td>@item.Phone</td>
                  <td>@item.Email</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "New" => "bg-label-info",
                        "Contacted" => "bg-label-primary",
                        "Qualified" => "bg-label-success",
                        "Negotiating" => "bg-label-warning",
                        "Converted" => "bg-label-success",
                        "Lost" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>
                    @{
                      var scoreClass = item.LeadScore >= 80 ? "bg-label-success" :
                                       item.LeadScore >= 50 ? "bg-label-warning" : "bg-label-danger";
                    }
                    <span class="badge @scoreClass">@item.LeadScore</span>
                  </td>
                  <td>@item.CampaignName</td>
                  <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="MarketingLeadsEdit" asp-route-id="@item.LeadID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="MarketingLeadsDelete" asp-route-id="@item.LeadID" method="post" onsubmit="return confirm('Are you sure you want to delete lead: @item.LeadName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@{
    var mlModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "MarketingLead",
        EntityType = "MarketingLead",
        EntityName = "MarketingLead",
        EntityDisplayName = "Lead marketing"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="mlModal" />
