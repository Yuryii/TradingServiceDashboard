@model Dashboard.Models.ViewModels.JobOpeningEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Job Opening";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Job Opening</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="JobOpenings_Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="JobOpeningID" />
          <input type="hidden" asp-for="CreatedAt" />

          <h6 class="mb-4">Job Details</h6>
          <div class="row g-6">
            <div class="col-12">
              <label asp-for="Title" class="form-label">Job Title</label>
              <input asp-for="Title" class="form-control" />
              <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="DepartmentID" class="form-label">Department</label>
              <select asp-for="DepartmentID" class="form-select">
                <option value="">-- Select Department --</option>
                @if (ViewBag.Departments != null)
                {
                  @foreach (var dept in ViewBag.Departments)
                  {
                    <option value="@dept.DepartmentID" selected="@(dept.DepartmentID == Model.DepartmentID)">@dept.DepartmentName</option>
                  }
                }
              </select>
              <span asp-validation-for="DepartmentID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var branch in ViewBag.Branches)
                  {
                    <option value="@branch.BranchID" selected="@(branch.BranchID == Model.BranchID)">@branch.BranchName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="EmploymentType" class="form-label">Employment Type</label>
              <select asp-for="EmploymentType" class="form-select">
                <option value="FullTime" selected="@(Model.EmploymentType == "FullTime")">Full Time</option>
                <option value="PartTime" selected="@(Model.EmploymentType == "PartTime")">Part Time</option>
                <option value="Contract" selected="@(Model.EmploymentType == "Contract")">Contract</option>
                <option value="Intern" selected="@(Model.EmploymentType == "Intern")">Intern</option>
              </select>
              <span asp-validation-for="EmploymentType" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Location" class="form-label">Location</label>
              <input asp-for="Location" class="form-control" />
              <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="NumberOfPositions" class="form-label">Number of Positions</label>
              <input asp-for="NumberOfPositions" class="form-control" type="number" min="1" />
              <span asp-validation-for="NumberOfPositions" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Open" selected="@(Model.Status == "Open")">Open</option>
                <option value="OnHold" selected="@(Model.Status == "OnHold")">On Hold</option>
                <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
                <option value="Filled" selected="@(Model.Status == "Filled")">Filled</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
          </div>

          <hr class="my-6 mx-n4" />
          <h6 class="mb-4">Salary & Dates</h6>
          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="SalaryMin" class="form-label">Minimum Salary</label>
              <input asp-for="SalaryMin" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="SalaryMin" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="SalaryMax" class="form-label">Maximum Salary</label>
              <input asp-for="SalaryMax" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="SalaryMax" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="PostedDate" class="form-label">Posted Date</label>
              <input asp-for="PostedDate" class="form-control" type="date" />
              <span asp-validation-for="PostedDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ClosingDate" class="form-label">Closing Date</label>
              <input asp-for="ClosingDate" class="form-control" type="date" />
              <span asp-validation-for="ClosingDate" class="text-danger"></span>
            </div>
          </div>

          <hr class="my-6 mx-n4" />
          <h6 class="mb-4">Job Description & Requirements</h6>
          <div class="row g-6">
            <div class="col-12">
              <label asp-for="JobDescription" class="form-label">Job Description</label>
              <textarea asp-for="JobDescription" class="form-control" rows="4"></textarea>
              <span asp-validation-for="JobDescription" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Requirements" class="form-label">Requirements</label>
              <textarea asp-for="Requirements" class="form-control" rows="4"></textarea>
              <span asp-validation-for="Requirements" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="JobOpenings_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
