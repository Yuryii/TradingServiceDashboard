@model IEnumerable<Dashboard.Models.ViewModels.JobOpeningListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Job Openings";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Job Openings</h5>
        <div class="d-flex gap-1">
          <a asp-action="JobOpening_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-JobOpening" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="JobOpenings_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Job Opening
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Department</th>
              <th>Type</th>
              <th>Location</th>
              <th>Positions</th>
              <th>Status</th>
              <th>Posted</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  No job openings found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.Title</strong></td>
                  <td>@(item.DepartmentName ?? "-")</td>
                  <td>@item.EmploymentType</td>
                  <td>@(item.Location ?? "-")</td>
                  <td>@item.NumberOfPositions</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Open" => "bg-label-success",
                        "Closed" => "bg-label-secondary",
                        "OnHold" => "bg-label-warning",
                        "Filled" => "bg-label-info",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>@item.PostedDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="JobOpenings_Edit" asp-route-id="@item.JobOpeningID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="JobOpenings_Delete" asp-route-id="@item.JobOpeningID" method="post" onsubmit="return confirm('Are you sure you want to delete job opening: @item.Title?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "JobOpening",
    EntityType = "JobOpening",
    EntityName = "JobOpening",
    EntityDisplayName = "Tin tuyen dung"
})
