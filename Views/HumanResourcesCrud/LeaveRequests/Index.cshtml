@model IEnumerable<Dashboard.Models.ViewModels.LeaveRequestListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Leave Requests";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Leave Requests</h5>
        <div class="d-flex gap-1">
          <a asp-action="LeaveRequest_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-LeaveRequest" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="LeaveRequests_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Leave Request
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Leave Type</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Total Days</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No leave requests found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@(item.EmployeeName ?? "-")</strong></td>
                  <td>@item.LeaveType</td>
                  <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                  <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                  <td>@item.TotalDays</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Approved" => "bg-label-success",
                        "Rejected" => "bg-label-danger",
                        "Pending" => "bg-label-warning",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="LeaveRequests_Edit" asp-route-id="@item.LeaveRequestID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="LeaveRequests_Delete" asp-route-id="@item.LeaveRequestID" method="post" onsubmit="return confirm('Are you sure you want to delete this leave request?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "LeaveRequest",
    EntityType = "LeaveRequest",
    EntityName = "LeaveRequest",
    EntityDisplayName = "Nghi phep"
})
