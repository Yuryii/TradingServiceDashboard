@model IEnumerable<Dashboard.Models.ViewModels.PerformanceReviewListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Performance Reviews";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Performance Reviews</h5>
        <div class="d-flex gap-1">
          <a asp-action="PerformanceReview_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-PerformanceReview" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="PerformanceReviews_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Review
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Reviewed By</th>
              <th>Review Date</th>
              <th>Rating</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  No performance reviews found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@(item.EmployeeName ?? "-")</strong></td>
                  <td>@(item.ReviewedByName ?? "-")</td>
                  <td>@item.ReviewDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    @if (item.OverallRating.HasValue)
                    {
                      var ratingClass = item.OverallRating >= 4 ? "bg-label-success" : item.OverallRating >= 3 ? "bg-label-warning" : "bg-label-danger";
                      <span class="badge @ratingClass">@item.OverallRating.Value.ToString("F1") / 5.0</span>
                    }
                    else
                    {
                      <span class="text-muted">N/A</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="PerformanceReviews_Edit" asp-route-id="@item.ReviewID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="PerformanceReviews_Delete" asp-route-id="@item.ReviewID" method="post" onsubmit="return confirm('Are you sure you want to delete this performance review?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "PerformanceReview",
    EntityType = "PerformanceReview",
    EntityName = "PerformanceReview",
    EntityDisplayName = "Danh gia cong viec"
})
