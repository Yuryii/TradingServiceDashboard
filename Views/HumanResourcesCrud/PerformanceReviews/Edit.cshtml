@model Dashboard.Models.ViewModels.PerformanceReviewEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Performance Review";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Performance Review</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="PerformanceReviews_Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="ReviewID" />
          <input type="hidden" asp-for="CreatedAt" />

          <h6 class="mb-4">Review Details</h6>
          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="EmployeeID" class="form-label">Employee</label>
              <select asp-for="EmployeeID" class="form-select">
                <option value="">-- Select Employee --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var emp in ViewBag.Employees)
                  {
                    <option value="@emp.EmployeeID" selected="@(emp.EmployeeID == Model.EmployeeID)">@emp.FullName</option>
                  }
                }
              </select>
              <span asp-validation-for="EmployeeID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ReviewedByEmployeeID" class="form-label">Reviewed By</label>
              <select asp-for="ReviewedByEmployeeID" class="form-select">
                <option value="">-- Select Reviewer --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var emp in ViewBag.Employees)
                  {
                    <option value="@emp.EmployeeID" selected="@(emp.EmployeeID == Model.ReviewedByEmployeeID)">@emp.FullName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="ReviewDate" class="form-label">Review Date</label>
              <input asp-for="ReviewDate" class="form-control" type="date" />
              <span asp-validation-for="ReviewDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ReviewPeriodStart" class="form-label">Review Period Start</label>
              <input asp-for="ReviewPeriodStart" class="form-control" type="date" />
              <span asp-validation-for="ReviewPeriodStart" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ReviewPeriodEnd" class="form-label">Review Period End</label>
              <input asp-for="ReviewPeriodEnd" class="form-control" type="date" />
              <span asp-validation-for="ReviewPeriodEnd" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="OverallRating" class="form-label">Overall Rating (1-5)</label>
              <input asp-for="OverallRating" class="form-control" type="number" step="0.1" min="1" max="5" />
              <span asp-validation-for="OverallRating" class="text-danger"></span>
            </div>
          </div>

          <hr class="my-6 mx-n4" />
          <h6 class="mb-4">Review Content</h6>
          <div class="row g-6">
            <div class="col-12">
              <label asp-for="Strengths" class="form-label">Strengths</label>
              <textarea asp-for="Strengths" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Strengths" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="AreasForImprovement" class="form-label">Areas for Improvement</label>
              <textarea asp-for="AreasForImprovement" class="form-control" rows="3"></textarea>
              <span asp-validation-for="AreasForImprovement" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Comments" class="form-label">Comments</label>
              <textarea asp-for="Comments" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Comments" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Goals" class="form-label">Goals</label>
              <textarea asp-for="Goals" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Goals" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="PerformanceReviews_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
