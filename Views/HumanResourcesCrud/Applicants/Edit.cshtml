@model Dashboard.Models.ViewModels.ApplicantEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Applicant";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Applicant</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Applicants_Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="ApplicantID" />
          <input type="hidden" asp-for="AppliedDate" />

          <h6 class="mb-4">Applicant Details</h6>
          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="JobOpeningID" class="form-label">Job Opening</label>
              <select asp-for="JobOpeningID" class="form-select">
                <option value="">-- Select Job Opening --</option>
                @if (ViewBag.JobOpenings != null)
                {
                  @foreach (var job in ViewBag.JobOpenings)
                  {
                    <option value="@job.JobOpeningID" selected="@(job.JobOpeningID == Model.JobOpeningID)">@job.Title</option>
                  }
                }
              </select>
              <span asp-validation-for="JobOpeningID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="FullName" class="form-label">Full Name</label>
              <input asp-for="FullName" class="form-control" />
              <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Email" class="form-label">Email</label>
              <input asp-for="Email" class="form-control" type="email" />
              <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Phone" class="form-label">Phone</label>
              <input asp-for="Phone" class="form-control" />
              <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Gender" class="form-label">Gender</label>
              <select asp-for="Gender" class="form-select">
                <option value="">-- Select --</option>
                <option value="Male" selected="@(Model.Gender == "Male")">Male</option>
                <option value="Female" selected="@(Model.Gender == "Female")">Female</option>
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
              <input asp-for="DateOfBirth" class="form-control" type="date" />
            </div>
            <div class="col-12">
              <label asp-for="Address" class="form-label">Address</label>
              <input asp-for="Address" class="form-control" />
              <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Applied" selected="@(Model.Status == "Applied")">Applied</option>
                <option value="Screening" selected="@(Model.Status == "Screening")">Screening</option>
                <option value="Interview" selected="@(Model.Status == "Interview")">Interview</option>
                <option value="Offer" selected="@(Model.Status == "Offer")">Offer</option>
                <option value="Hired" selected="@(Model.Status == "Hired")">Hired</option>
                <option value="Rejected" selected="@(Model.Status == "Rejected")">Rejected</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="InterviewDate" class="form-label">Interview Date</label>
              <input asp-for="InterviewDate" class="form-control" type="date" />
              <span asp-validation-for="InterviewDate" class="text-danger"></span>
            </div>
          </div>

          <hr class="my-6 mx-n4" />
          <h6 class="mb-4">Additional Information</h6>
          <div class="row g-6">
            <div class="col-12">
              <label asp-for="ResumePath" class="form-label">Resume Path</label>
              <input asp-for="ResumePath" class="form-control" />
              <span asp-validation-for="ResumePath" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="CoverLetter" class="form-label">Cover Letter</label>
              <textarea asp-for="CoverLetter" class="form-control" rows="4"></textarea>
              <span asp-validation-for="CoverLetter" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="LinkedInProfile" class="form-label">LinkedIn Profile</label>
              <input asp-for="LinkedInProfile" class="form-control" />
              <span asp-validation-for="LinkedInProfile" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Notes" class="form-label">Notes</label>
              <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="Applicants_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
