@model IEnumerable<Dashboard.Models.ViewModels.EmployeeListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Employees";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Employees</h5>
        <div class="d-flex gap-1">
          <a asp-action="Employee_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Employee" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Employees_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Employee
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Department</th>
              <th>Position</th>
              <th>Email</th>
              <th>Type</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No employees found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="avatar avatar-sm me-3">
                        <span class="avatar-initial rounded-circle bg-label-primary">
                          @(item.FullName?.Length > 0 ? item.FullName[0].ToString().ToUpper() : "?")
                        </span>
                      </div>
                      <div>
                        <strong>@item.FullName</strong>
                        <div class="text-muted" style="font-size:0.75rem;">@item.EmployeeCode</div>
                      </div>
                    </div>
                  </td>
                  <td>@(item.DepartmentName ?? "-")</td>
                  <td>@(item.PositionName ?? "-")</td>
                  <td>@(item.Email ?? "-")</td>
                  <td>@item.EmploymentType</td>
                  <td>
                    @{
                      var statusClass = item.IsActive ? "bg-label-success" : "bg-label-secondary";
                      var statusText = item.IsActive ? "Active" : "Inactive";
                    }
                    <span class="badge @statusClass">@statusText</span>
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Employees_Edit" asp-route-id="@item.EmployeeID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Employees_Delete" asp-route-id="@item.EmployeeID" method="post" onsubmit="return confirm('Are you sure you want to delete employee: @item.FullName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Employee",
    EntityType = "Employee",
    EntityName = "Employee",
    EntityDisplayName = "Nhan vien"
})
