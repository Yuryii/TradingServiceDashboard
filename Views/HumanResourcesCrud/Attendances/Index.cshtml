@model IEnumerable<Dashboard.Models.ViewModels.AttendanceListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Attendances";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Attendances</h5>
        <div class="d-flex gap-1">
          <a asp-action="Attendance_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Attendance" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Attendances_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Attendance
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Date</th>
              <th>Check In</th>
              <th>Check Out</th>
              <th>Status</th>
              <th>Notes</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No attendances found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@(item.EmployeeName ?? "-")</strong></td>
                  <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                  <td>@(item.CheckInTime?.ToString("HH:mm") ?? "-")</td>
                  <td>@(item.CheckOutTime?.ToString("HH:mm") ?? "-")</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Present" => "bg-label-success",
                        "Absent" => "bg-label-danger",
                        "Late" => "bg-label-warning",
                        "OnLeave" => "bg-label-info",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>@(item.Notes ?? "-")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Attendances_Edit" asp-route-id="@item.AttendanceID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Attendances_Delete" asp-route-id="@item.AttendanceID" method="post" onsubmit="return confirm('Are you sure you want to delete this attendance record?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Attendance",
    EntityType = "Attendance",
    EntityName = "Attendance",
    EntityDisplayName = "Cham cong"
})
