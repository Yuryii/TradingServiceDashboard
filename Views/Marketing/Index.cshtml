<div class="row">
  <div class="col-md-6 col-lg-4 order-0 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Active Campaigns</h5>
          <p class="card-subtitle">Running Marketing Campaigns</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.ActiveCampaigns.Any())
          {
            @foreach (var campaign in Model.ActiveCampaigns.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @campaign.IconBgClass"><i class="@campaign.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@campaign.Name</h6>
                    <small>@campaign.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0">@campaign.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-bulb"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Brand Awareness</h6>
                  <small>Social Media</small>
                </div>
                <div class="user-progress"><h6 class="mb-0">85%</h6></div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-1 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
