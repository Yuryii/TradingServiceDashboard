@model MarketingDashboardViewModel
@{
  ViewData["Title"] = "Marketing Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.CampaignPerformanceChart));
window.dashboardCharts.revenueChart = @Html.Raw(Json.Serialize(Model.CampaignPerformanceChart));
window.dashboardCharts.leadTrend = @Html.Raw(Json.Serialize(Model.LeadTrendChart));
window.dashboardCharts.marketingFunnel = @Html.Raw(Json.Serialize(Model.MarketingFunnelChart));
window.dashboardCharts.channelSpendRevenue = @Html.Raw(Json.Serialize(Model.ChannelSpendRevenueChart));
window.dashboardCharts.cplVsConversion = @Html.Raw(Json.Serialize(Model.CplVsConversionScatterChart));
window.dashboardCharts.landingPage = @Html.Raw(Json.Serialize(Model.LandingPageChart));
window.dashboardCharts.cohortRetention = @Html.Raw(Json.Serialize(Model.CohortRetentionChart));
window.dashboardCharts.timeSlotHeatmap = @Html.Raw(Json.Serialize(Model.TimeSlotHeatmap));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Marketing Performance 🎯</h5>
            <p class="mb-6">Welcome to the Marketing Dashboard. Track campaigns and engagement.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Campaigns</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Marketing Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="Reach" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalReach.Title</p>
            <h4 class="card-title mb-3">@Model.TotalReach.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalReach.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="Engagement" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.EngagementRate.Title</p>
            <h4 class="card-title mb-3">@Model.EngagementRate.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.EngagementRate.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/Marketing" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row">
  <div class="col-12 col-xxl-8 order-2 order-md-3 order-xxl-2 mb-6">
    <div class="card">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Campaign Performance</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="campaignChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="campaignChart">
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
                <a class="dropdown-item" href="javascript:void(0);">Last Month</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.RoiAchievementPercent% ROI Achievement</h6>
            </div>
            <div id="growthChart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-8 col-lg-12 col-xxl-4 order-3 order-md-2 mb-6">
    <div class="row">
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Leads" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.NewLeads.Title</p>
            <h4 class="card-title mb-3">@Model.NewLeads.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.NewLeads.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Conversions" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu" aria-labelledby="cardOpt4">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.Conversions.Title</p>
            <h4 class="card-title mb-3">@Model.Conversions.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.Conversions.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

