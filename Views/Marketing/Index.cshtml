@model MarketingDashboardViewModel
@{
  ViewData["Title"] = "Marketing Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;

  bool hasLeadTrend     = Model.LeadTrendChart?.Series?.Any() == true;
  bool hasFunnel       = Model.MarketingFunnelChart?.Series?.Any() == true;
  bool hasChannel      = Model.ChannelSpendRevenueChart?.Series?.Any() == true;
  bool hasCplScatter   = Model.CplVsConversionScatterChart?.Series?.Any() == true;
  bool hasLanding      = Model.LandingPageChart?.Series?.Any() == true;
  bool hasCohort       = Model.CohortRetentionChart?.Series?.Any() == true;
  bool hasTimeSlot     = Model.TimeSlotHeatmap?.Data != null && Model.TimeSlotHeatmap.Data.Any();
  bool hasCampaignChart = Model.CampaignPerformanceChart?.Series?.Any() == true;

  int chartRow1 = 12;
  int chartRow2 = chartRow1 + 8;
  int chartRow3 = chartRow2 + 8;
  int chartRow4 = hasTimeSlot ? chartRow3 + 8 : chartRow3;
  int bottomRow = chartRow4 + 8;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Inject all charts *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
Object.assign(window.dashboardCharts, {
  orderChart: @Html.Raw(Json.Serialize(Model.CampaignPerformanceChart)),
  revenueChart: @Html.Raw(Json.Serialize(Model.CampaignPerformanceChart)),
  leadTrend: @Html.Raw(Json.Serialize(Model.LeadTrendChart)),
  marketingFunnel: @Html.Raw(Json.Serialize(Model.MarketingFunnelChart)),
  channelSpendRevenue: @Html.Raw(Json.Serialize(Model.ChannelSpendRevenueChart)),
  cplVsConversion: @Html.Raw(Json.Serialize(Model.CplVsConversionScatterChart)),
  landingPage: @Html.Raw(Json.Serialize(Model.LandingPageChart)),
  cohortRetention: @Html.Raw(Json.Serialize(Model.CohortRetentionChart)),
  timeSlotHeatmap: @Html.Raw(Json.Serialize(Model.TimeSlotHeatmap))
});
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script src="~/js/dashboard-layout-manager.js"></script>
}

@* Layout Toolbar *@
<div class="d-flex align-items-center gap-2 mb-4">
  <button type="button" class="btn-layout-action" id="btn-layout-edit"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.toggleEditMode()">
    <i class="icon-base bx bx-palette me-1"></i> Customize Layout
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-save"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.saveLayout()">
    <i class="icon-base bx bx-check me-1"></i> Save
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-reset"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.resetLayout()">
    <i class="icon-base bx bx-refresh me-1"></i> Reset
  </button>
</div>

@* ============ DATE FILTER (outside grid — never resizable) ============ *@
<div id="marketing-date-filter" class="card mb-4 marketing-date-filter-card">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/Marketing" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

@* ============ GRID ============ *@
<div id="marketing-dashboard-grid-container" style="position: relative;">
  <div id="marketing-dashboard-grid" class="grid-stack">

    @* ---- Row 0: Welcome (8) + Total Reach KPI (4) ---- *@
    <div class="grid-stack-item"
         data-widget-id="marketing-welcome"
         data-gs-x="0" data-gs-y="0" data-gs-width="8" data-gs-height="6">
      <div class="grid-stack-item-content card">
        <div class="d-flex align-items-start row">
          <div class="col-sm-7">
            <div class="card-body">
              <h5 class="card-title text-primary mb-3">Marketing Performance 🎯</h5>
              <p class="mb-6">Welcome to the Marketing Dashboard. Track campaigns and engagement.</p>
              <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Campaigns</a>
            </div>
          </div>
          <div class="col-sm-5 text-center text-sm-left">
            <div class="card-body pb-0 px-0 px-md-6">
              <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Marketing Dashboard" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-reach"
         data-gs-x="8" data-gs-y="0" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Reach" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.TotalReach.Title</p>
          <h4 class="card-title mb-3">@Model.TotalReach.Value</h4>
          <small class="text-@(Model.TotalReach.Trend == "up" ? "success" : Model.TotalReach.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.TotalReach.Trend == "up" ? "bx-up-arrow-alt" : Model.TotalReach.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.TotalReach.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-engagement"
         data-gs-x="8" data-gs-y="3" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="Engagement" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.EngagementRate.Title</p>
          <h4 class="card-title mb-3">@Model.EngagementRate.Value</h4>
          <small class="text-@(Model.EngagementRate.Trend == "up" ? "success" : Model.EngagementRate.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.EngagementRate.Trend == "up" ? "bx-up-arrow-alt" : Model.EngagementRate.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.EngagementRate.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Row 6: Campaign Overview (8) + New Leads (4) + Conversions (4) ---- *@
    @if (hasCampaignChart)
    {
      <div class="grid-stack-item"
           data-widget-id="marketing-chart-campaign"
           data-gs-x="0" data-gs-y="6" data-gs-width="8" data-gs-height="6">
        <div class="grid-stack-item-content card h-100">
          <div class="row row-bordered g-0 h-100">
            <div class="col-lg-8">
              <div class="card-header d-flex align-items-center justify-content-between">
                <div class="card-title mb-0">
                  <h5 class="m-0 me-2">Campaign Performance</h5>
                </div>
                <div class="dropdown">
                  <button class="btn p-0" type="button" id="campaignChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end" aria-labelledby="campaignChart">
                    <a class="dropdown-item" href="javascript:void(0);">This Month</a>
                    <a class="dropdown-item" href="javascript:void(0);">Last Month</a>
                  </div>
                </div>
              </div>
              <div id="totalRevenueChart" class="px-3"></div>
            </div>
            <div class="col-lg-4">
              <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
                <div class="text-center mb-6">
                  <h6 class="mb-0">@Model.RoiAchievementPercent% ROI Achievement</h6>
                </div>
                <div id="growthChart"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="marketing-kpi-leads"
           data-gs-x="8" data-gs-y="6" data-gs-width="4" data-gs-height="3">
        <div class="grid-stack-item-content card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Leads" class="rounded" />
              </div>
            </div>
            <p class="mb-1">@Model.NewLeads.Title</p>
            <h4 class="card-title mb-3">@Model.NewLeads.Value</h4>
            <small class="text-@(Model.NewLeads.Trend == "up" ? "success" : Model.NewLeads.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.NewLeads.Trend == "up" ? "bx-up-arrow-alt" : Model.NewLeads.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.NewLeads.TrendLabel</small>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="marketing-kpi-conversions"
           data-gs-x="8" data-gs-y="9" data-gs-width="4" data-gs-height="3">
        <div class="grid-stack-item-content card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Conversions" class="rounded" />
              </div>
            </div>
            <p class="mb-1">@Model.Conversions.Title</p>
            <h4 class="card-title mb-3">@Model.Conversions.Value</h4>
            <small class="text-@(Model.Conversions.Trend == "up" ? "success" : Model.Conversions.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.Conversions.Trend == "up" ? "bx-up-arrow-alt" : Model.Conversions.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.Conversions.TrendLabel</small>
          </div>
        </div>
      </div>
    }

    @* ---- Row 12: 4 KPI cards: CPL + ROAS + Marketing ROI + CAC ---- *@
    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-cpl"
         data-gs-x="0" data-gs-y="@chartRow1" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/credit-card.png" alt="CPL" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Cpl.Title</p>
          <h4 class="card-title mb-3">@Model.Cpl.Value</h4>
          <small class="text-@(Model.Cpl.Trend == "up" ? "success" : Model.Cpl.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.Cpl.Trend == "up" ? "bx-up-arrow-alt" : Model.Cpl.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.Cpl.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-roas"
         data-gs-x="3" data-gs-y="@chartRow1" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-line.png" alt="ROAS" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Roas.Title</p>
          <h4 class="card-title mb-3">@Model.Roas.Value</h4>
          <small class="text-@(Model.Roas.Trend == "up" ? "success" : Model.Roas.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.Roas.Trend == "up" ? "bx-up-arrow-alt" : Model.Roas.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.Roas.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-roi"
         data-gs-x="6" data-gs-y="@chartRow1" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Marketing ROI" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Roi.Title</p>
          <h4 class="card-title mb-3">@Model.Roi.Value</h4>
          <small class="text-@(Model.Roi.Trend == "up" ? "success" : Model.Roi.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.Roi.Trend == "up" ? "bx-up-arrow-alt" : Model.Roi.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.Roi.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="marketing-kpi-cac"
         data-gs-x="9" data-gs-y="@chartRow1" data-gs-width="3" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="CAC" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Cac.Title</p>
          <h4 class="card-title mb-3">@Model.Cac.Value</h4>
          <small class="text-@(Model.Cac.Trend == "up" ? "success" : Model.Cac.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.Cac.Trend == "up" ? "bx-up-arrow-alt" : Model.Cac.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.Cac.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Chart Row 1: Lead Trend + Marketing Funnel ---- *@
    @if (hasLeadTrend || hasFunnel)
    {
      <div class="grid-stack-item"
           data-widget-id="marketing-chart-leadtrend"
           data-gs-x="0" data-gs-y="@chartRow2" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Lead Trend (Leads & SQL)</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="leadTrendOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="leadTrendChart"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="marketing-chart-funnel"
           data-gs-x="6" data-gs-y="@chartRow2" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Marketing Funnel</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="marketingFunnelOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="marketingFunnelChart"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 2: Channel Spend vs Revenue + CPL Scatter ---- *@
    @if (hasChannel || hasCplScatter)
    {
      <div class="grid-stack-item"
           data-widget-id="marketing-chart-channel"
           data-gs-x="0" data-gs-y="@chartRow3" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Channel Spend vs Revenue</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="channelSpendOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="channelSpendRevenueChart"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="marketing-chart-cpl-scatter"
           data-gs-x="6" data-gs-y="@chartRow3" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">CPL vs Lead-to-Sale Rate</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cplConversionOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="cplVsConversionScatterChart"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 3: Landing Page + Cohort Retention ---- *@
    @if (hasLanding || hasCohort)
    {
      <div class="grid-stack-item"
           data-widget-id="marketing-chart-landing"
           data-gs-x="0" data-gs-y="@(chartRow3 + 8)" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Landing Page Performance</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="landingPageOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="landingPageChart"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="marketing-chart-cohort"
           data-gs-x="6" data-gs-y="@(chartRow3 + 8)" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Cohort Retention</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cohortRetentionOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="cohortRetentionChart"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 4: TimeSlot Heatmap (full width) ---- *@
    @if (hasTimeSlot)
    {
      <div class="grid-stack-item"
           data-widget-id="marketing-chart-timeslot"
           data-gs-x="0" data-gs-y="@chartRow4" data-gs-width="12" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Ad Performance by Time Slot</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="timeSlotHeatmapOpt" data-bs-toggle="dropdown">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end">
                <a class="dropdown-item" href="javascript:void(0);">Refresh</a>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="timeSlotHeatmapChart"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Bottom row: Active Campaigns (4) + Social Media (4) + Budget (4) ---- *@
    <div class="grid-stack-item"
         data-widget-id="marketing-active-campaigns"
