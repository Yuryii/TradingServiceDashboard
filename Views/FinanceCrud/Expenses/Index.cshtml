@model IEnumerable<Dashboard.Models.ViewModels.ExpenseListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Expenses";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Expenses</h5>
        <div class="d-flex gap-1">
          <a asp-action="Expense_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Expense" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Expenses_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Expense
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Expense Number</th>
              <th>Employee</th>
              <th>Category</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No expenses found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.ExpenseNumber</strong></td>
                  <td>@(item.EmployeeName ?? "-")</td>
                  <td>@(item.CategoryName ?? "-")</td>
                  <td>@item.Amount.ToString("N2")</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Approved" => "bg-label-success",
                        "Rejected" => "bg-label-danger",
                        "Pending" => "bg-label-warning",
                        "Paid" => "bg-label-info",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass">@item.Status</span>
                  </td>
                  <td>@item.ExpenseDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Expenses_Edit" asp-route-id="@item.ExpenseID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Expenses_Delete" asp-route-id="@item.ExpenseID" method="post" onsubmit="return confirm('Are you sure you want to delete expense: @item.ExpenseNumber?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "Expense",
    EntityType = "Expense",
    EntityName = "Expense",
    EntityDisplayName = "Chi phi"
})
