@model Dashboard.Models.ViewModels.ExpenseCreateVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Create Expense";
}

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Create New Expense</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Expenses_Create" method="post">
          @Html.AntiForgeryToken()

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="ExpenseNumber" class="form-label">Expense Number</label>
              <input asp-for="ExpenseNumber" class="form-control" placeholder="EXP-001" />
              <span asp-validation-for="ExpenseNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="EmployeeID" class="form-label">Employee</label>
              <select asp-for="EmployeeID" class="form-select">
                <option value="">-- Select Employee --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var emp in ViewBag.Employees)
                  {
                    <option value="@emp.EmployeeID">@emp.FullName</option>
                  }
                }
              </select>
              <span asp-validation-for="EmployeeID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CategoryID" class="form-label">Category</label>
              <select asp-for="CategoryID" class="form-select">
                <option value="">-- Select Category --</option>
                @if (ViewBag.Categories != null)
                {
                  @foreach (var cat in ViewBag.Categories)
                  {
                    <option value="@cat.ExpenseCategoryID">@cat.CategoryName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var branch in ViewBag.Branches)
                  {
                    <option value="@branch.BranchID">@branch.BranchName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="ExpenseDate" class="form-label">Expense Date</label>
              <input asp-for="ExpenseDate" class="form-control" type="date" />
              <span asp-validation-for="ExpenseDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Amount" class="form-label">Amount</label>
              <input asp-for="Amount" class="form-control" type="number" step="0.01" placeholder="0.00" />
              <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
                <option value="Paid">Paid</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ApprovedByEmployeeID" class="form-label">Approved By</label>
              <select asp-for="ApprovedByEmployeeID" class="form-select">
                <option value="">-- Select Approver --</option>
                @if (ViewBag.Approvers != null)
                {
                  @foreach (var appr in ViewBag.Approvers)
                  {
                    <option value="@appr.EmployeeID">@appr.FullName</option>
                  }
                }
              </select>
            </div>
            <div class="col-12">
              <label asp-for="Description" class="form-label">Description</label>
              <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter expense description"></textarea>
              <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="ReceiptPath" class="form-label">Receipt Path</label>
              <input asp-for="ReceiptPath" class="form-control" placeholder="/uploads/receipts/..." />
              <span asp-validation-for="ReceiptPath" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Create Expense
            </button>
            <a asp-action="Expenses_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
