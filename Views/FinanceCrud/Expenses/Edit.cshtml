@model Dashboard.Models.ViewModels.ExpenseEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Expense";
}

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Expense</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Expenses_Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="ExpenseID" />
          <input type="hidden" asp-for="CreatedAt" />

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="ExpenseNumber" class="form-label">Expense Number</label>
              <input asp-for="ExpenseNumber" class="form-control" />
              <span asp-validation-for="ExpenseNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="EmployeeID" class="form-label">Employee</label>
              <select asp-for="EmployeeID" class="form-select">
                <option value="">-- Select Employee --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var emp in ViewBag.Employees)
                  {
                    <option value="@emp.EmployeeID" selected="@(emp.EmployeeID == Model.EmployeeID)">@emp.FullName</option>
                  }
                }
              </select>
              <span asp-validation-for="EmployeeID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CategoryID" class="form-label">Category</label>
              <select asp-for="CategoryID" class="form-select">
                <option value="">-- Select Category --</option>
                @if (ViewBag.Categories != null)
                {
                  @foreach (var cat in ViewBag.Categories)
                  {
                    <option value="@cat.ExpenseCategoryID" selected="@(cat.ExpenseCategoryID == Model.CategoryID)">@cat.CategoryName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var branch in ViewBag.Branches)
                  {
                    <option value="@branch.BranchID" selected="@(branch.BranchID == Model.BranchID)">@branch.BranchName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="ExpenseDate" class="form-label">Expense Date</label>
              <input asp-for="ExpenseDate" class="form-control" type="date" />
              <span asp-validation-for="ExpenseDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Amount" class="form-label">Amount</label>
              <input asp-for="Amount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                <option value="Approved" selected="@(Model.Status == "Approved")">Approved</option>
                <option value="Rejected" selected="@(Model.Status == "Rejected")">Rejected</option>
                <option value="Paid" selected="@(Model.Status == "Paid")">Paid</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ApprovedByEmployeeID" class="form-label">Approved By</label>
              <select asp-for="ApprovedByEmployeeID" class="form-select">
                <option value="">-- Select Approver --</option>
                @if (ViewBag.Approvers != null)
                {
                  @foreach (var appr in ViewBag.Approvers)
                  {
                    <option value="@appr.EmployeeID" selected="@(appr.EmployeeID == Model.ApprovedByEmployeeID)">@appr.FullName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-6">
              <label asp-for="ApprovedDate" class="form-label">Approved Date</label>
              <input asp-for="ApprovedDate" class="form-control" type="date" />
              <span asp-validation-for="ApprovedDate" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Description" class="form-label">Description</label>
              <textarea asp-for="Description" class="form-control" rows="3"></textarea>
              <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="ReceiptPath" class="form-label">Receipt Path</label>
              <input asp-for="ReceiptPath" class="form-control" />
              <span asp-validation-for="ReceiptPath" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="RejectionReason" class="form-label">Rejection Reason</label>
              <textarea asp-for="RejectionReason" class="form-control" rows="2"></textarea>
              <span asp-validation-for="RejectionReason" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="Expenses_Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
