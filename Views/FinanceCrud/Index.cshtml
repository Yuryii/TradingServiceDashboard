@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Finance CRUD";
}

<div class="row">
  <div class="col-12 mb-4">
    <h4 class="mb-0">Finance Management</h4>
    <p class="text-muted">Manage expenses and expense categories</p>
  </div>
</div>

<div class="row">
  <div class="col-md-6 col-lg-4">
    <div class="card border border-primary shadow-none mb-4">
      <div class="card-body text-center py-5">
        <div class="avatar avatar-md mx-auto mb-3">
          <span class="avatar-initial rounded-circle bg-label-primary">
            <i class="icon-base bx bx-receipt fs-3"></i>
          </span>
        </div>
        <h5 class="mb-2">Expenses</h5>
        <p class="mb-3 text-muted small">Track and manage employee expenses</p>
        <a asp-action="Expenses_Index" class="btn btn-primary btn-sm">
          <i class="icon-base bx bx-list-ul me-1"></i> View Expenses
        </a>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4">
    <div class="card border border-success shadow-none mb-4">
      <div class="card-body text-center py-5">
        <div class="avatar avatar-md mx-auto mb-3">
          <span class="avatar-initial rounded-circle bg-label-success">
            <i class="icon-base bx bx-category fs-3"></i>
          </span>
        </div>
        <h5 class="mb-2">Expense Categories</h5>
        <p class="mb-3 text-muted small">Manage expense categories and types</p>
        <a asp-action="ExpenseCategories_Index" class="btn btn-success btn-sm">
          <i class="icon-base bx bx-list-ul me-1"></i> View Categories
        </a>
      </div>
    </div>
  </div>
</div>
