@model IEnumerable<Dashboard.Models.ViewModels.ExpenseCategoryListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Expense Categories";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Expense Categories</h5>
        <div class="d-flex gap-1">
          <a asp-action="ExpenseCategory_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-ExpenseCategory" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="ExpenseCategories_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Category
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Code</th>
              <th>Category Name</th>
              <th>Description</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  No categories found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.CategoryCode</strong></td>
                  <td>@item.CategoryName</td>
                  <td>@(item.Description ?? "-")</td>
                  <td>
                    @{
                      var statusClass = item.IsActive ? "bg-label-success" : "bg-label-secondary";
                      var statusText = item.IsActive ? "Active" : "Inactive";
                    }
                    <span class="badge @statusClass">@statusText</span>
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="ExpenseCategories_Edit" asp-route-id="@item.ExpenseCategoryID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="ExpenseCategories_Delete" asp-route-id="@item.ExpenseCategoryID" method="post" onsubmit="return confirm('Are you sure you want to delete category: @item.CategoryName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml", new Dashboard.Models.ViewModels.ExcelImportModalVM
{
    ModalId = "ExpenseCategory",
    EntityType = "ExpenseCategory",
    EntityName = "ExpenseCategory",
    EntityDisplayName = "Loai chi phi"
})
