@model AIChatWidgetModel

@{
    var department = Model?.Department ?? "sales";
    var departmentName = department.ToLower() switch
    {
        "sales" => "Sales Assistant",
        "finance" => "Finance Assistant",
        "marketing" => "Marketing Assistant",
        "inventory" => "Inventory Assistant",
        "hr" => "HR Assistant",
        "cskh" => "CSKH Assistant",
        "executive" => "Executive Assistant",
        _ => "AI Assistant"
    };

    var iconClass = department.ToLower() switch
    {
        "sales" => "bx-trending-up",
        "finance" => "bx-wallet",
        "marketing" => "bx-megaphone",
        "inventory" => "bx-package",
        "hr" => "bx-user",
        "cskh" => "bx-headphone",
        "executive" => "bx-bar-chart-alt-2",
        _ => "bx-bot"
    };

    var accentColor = department.ToLower() switch
    {
        "sales" => "#28c76f",
        "finance" => "#00cfe8",
        "marketing" => "#ffab00",
        "inventory" => "#7367f0",
        "hr" => "#ea5455",
        "cskh" => "#9c9cb0",
        "executive" => "#6965fd",
        _ => "#7367f0"
    };

    var quickActions = department.ToLower() switch
    {
        "sales" => new[] {
            new { label = "Doanh số tuần này?", icon = "bx-line-chart" },
            new { label = "Top 5 khách hàng", icon = "bx-star" },
            new { label = "Cơ hội chậm trễ", icon = "bx-alarm-exclamation" },
            new { label = "Pipeline hiện tại", icon = "bx-filter-alt" }
        },
        "finance" => new[] {
            new { label = "Chi phí tháng này?", icon = "bx-coin-stack" },
            new { label = "Dòng tiền", icon = "bx-trending-down" },
            new { label = "AR/AP aging", icon = "bx-time-five" },
            new { label = "Lợi nhuận ròng", icon = "bx-dollar" }
        },
        "marketing" => new[] {
            new { label = "Hiệu suất chiến dịch?", icon = "bx-megaphone" },
            new { label = "Top leads", icon = "bx-user-plus" },
            new { label = "ROI chiến dịch", icon = "bx-trending-up" },
            new { label = "Chi phí CPL", icon = "bx-coin" }
        },
        "inventory" => new[] {
            new { label = "Tồn kho hiện tại?", icon = "bx-package" },
            new { label = "Sản phẩm sắp hết", icon = "bx-alert-circle" },
            new { label = "Nhập kho gần đây", icon = "bx-log-in" },
            new { label = "Vòng quay kho", icon = "bx-refresh" }
        },
        "hr" => new[] {
            new { label = "Tổng nhân sự?", icon = "bx-group" },
            new { label = "Tỷ lệ nghỉ việc", icon = "bx-user-x" },
            new { label = "Vị trí đang tuyển", icon = "bx-briefcase" },
            new { label = "Đơn nghỉ phép", icon = "bx-calendar-x" }
        },
        "cskh" => new[] {
            new { label = "Tickets đang mở?", icon = "bx-ticket" },
            new { label = "CSAT score", icon = "bx-star" },
            new { label = "SLA compliance", icon = "bx-check-circle" },
            new { label = "Top agent", icon = "bx-medal" }
        },
        "executive" => new[] {
            new { label = "Tổng quan công ty?", icon = "bx-bar-chart" },
            new { label = "Top phòng ban", icon = "bx-building" },
            new { label = "Cảnh báo", icon = "bx-alert-triangle" },
            new { label = "Các hoạt động gần đây", icon = "bx-activity" }
        },
        _ => new[] {
            new { label = "Tổng quan", icon = "bx-pie-chart-alt" },
            new { label = "Top KPIs", icon = "bx-trending-up" },
            new { label = "Dữ liệu gần đây", icon = "bx-history" }
        }
    };
}

<style>
    /* Above .layout-navbar at z-index 1080 on smaller breakpoints (theme) */
    #ai-chat-fab {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 1090;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, @accentColor 0%, #7367f0 100%);
        border: none;
        box-shadow: 0 4px 20px rgba(115, 103, 240, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        color: white;
    }

    #ai-chat-fab:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 28px rgba(115, 103, 240, 0.5);
    }

    #ai-chat-fab .fab-badge {
        position: absolute;
        top: -2px;
        right: -2px;
        width: 14px;
        height: 14px;
        background: #ea5455;
        border-radius: 50%;
        border: 2px solid white;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.2); opacity: 0.7; }
    }

    #ai-chat-panel {
        position: fixed;
        bottom: 90px;
        right: 24px;
        z-index: 1091;
        width: 400px;
        max-width: calc(100vw - 48px);
        height: 600px;
        max-height: calc(100vh - 120px);
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform: scale(0.8) translateY(20px);
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    #ai-chat-panel.open {
        transform: scale(1) translateY(0);
        opacity: 1;
        pointer-events: all;
    }

    .ai-chat-header {
        background: linear-gradient(135deg, @accentColor 0%, #7367f0 100%);
        color: white;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .ai-chat-header-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ai-chat-header-info .ai-avatar {
        width: 38px;
        height: 38px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ai-chat-header-actions {
        display: flex;
        gap: 4px;
    }

    .ai-chat-header-actions button {
        background: rgba(255,255,255,0.15);
        border: none;
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
    }

    .ai-chat-header-actions button:hover {
        background: rgba(255,255,255,0.3);
    }

    .ai-chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #f5f5f5;
    }

    .ai-msg {
        display: flex;
        gap: 8px;
        max-width: 85%;
        animation: msgIn 0.3s ease;
    }

    /* Fill chat width so the text column is not squeezed to min-content (vertical letters) */
    .ai-msg.assistant {
        align-self: stretch;
        max-width: 100%;
        width: 100%;
        box-sizing: border-box;
    }

    .ai-msg.assistant > div:not(.ai-msg-avatar) {
        flex: 1 1 0;
        min-width: 0;
    }

    @@keyframes msgIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .ai-msg.user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }


    .ai-msg-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .ai-msg.user .ai-msg-avatar {
        background: linear-gradient(135deg, #7367f0 0%, #9e95f5 100%);
        color: white;
    }

    .ai-msg.assistant .ai-msg-avatar {
        background: linear-gradient(135deg, @accentColor 0%, #7367f0 100%);
        color: white;
    }

    .ai-msg-bubble {
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 13.5px;
        line-height: 1.5;
        overflow-wrap: break-word;
        word-break: normal;
        width: 100%;
        box-sizing: border-box;
    }

    .ai-msg.user .ai-msg-bubble {
        background: linear-gradient(135deg, #7367f0 0%, #9e95f5 100%);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .ai-msg.assistant .ai-msg-bubble {
        background: white;
        color: #333;
        border-bottom-left-radius: 4px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        writing-mode: horizontal-tb;
        white-space: normal;
        display: block;
    }

    .ai-msg-bubble p { margin: 0 0 8px; white-space: normal; }
    .ai-msg-bubble p:last-child { margin-bottom: 0; }
    .ai-msg-bubble ul, .ai-msg-bubble ol { margin: 4px 0; padding-left: 18px; }
    .ai-msg-bubble code {
        background: rgba(0,0,0,0.06);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 12px;
    }
    .ai-msg-bubble pre {
        background: #1e1e2e;
        color: #cdd6f4;
        padding: 10px;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 12px;
        margin: 6px 0;
    }
    .ai-msg-bubble strong { color: inherit; }
    .ai-msg.user .ai-msg-bubble strong { color: #fff; }

    .ai-msg-typing {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        background: white;
        border-radius: 14px;
        border-bottom-left-radius: 4px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        width: fit-content;
    }

    .ai-msg-typing span {
        width: 6px;
        height: 6px;
        background: #999;
        border-radius: 50%;
        animation: typingBounce 1.4s infinite ease-in-out;
    }

    .ai-msg-typing span:nth-child(2) { animation-delay: 0.2s; }
    .ai-msg-typing span:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes typingBounce {
        0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; }
        40% { transform: scale(1.2); opacity: 1; }
    }

    .ai-quick-actions {
        padding: 8px 12px;
        border-top: 1px solid #f0f0f0;
        background: white;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .ai-quick-action {
        font-size: 11.5px;
        padding: 4px 10px;
        border: 1px solid #e0e0e0;
        border-radius: 20px;
        background: #fafafa;
        cursor: pointer;
        transition: all 0.2s;
        color: #555;
        white-space: nowrap;
    }

    .ai-quick-action:hover {
        background: @accentColor;
        border-color: @accentColor;
        color: white;
    }

    .ai-chat-input-area {
        padding: 12px 16px;
        background: white;
        border-top: 1px solid #f0f0f0;
        display: flex;
        gap: 8px;
        align-items: flex-end;
    }

    .ai-chat-input {
        flex: 1;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 13.5px;
        outline: none;
        resize: none;
        max-height: 100px;
        min-height: 42px;
        transition: border-color 0.2s;
        font-family: inherit;
    }

    .ai-chat-input:focus {
        border-color: @accentColor;
    }

    .ai-chat-send {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, @accentColor 0%, #7367f0 100%);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .ai-chat-send:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(115, 103, 240, 0.35);
    }

    .ai-chat-send:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .ai-chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        text-align: center;
        color: #888;
        gap: 12px;
    }

    .ai-chat-empty i { font-size: 48px; color: #ccc; }
    .ai-chat-empty h6 { font-size: 15px; font-weight: 600; color: #555; margin: 0; }
    .ai-chat-empty p { font-size: 13px; margin: 0; }

    .ai-welcome-msg {
        background: white;
        border-radius: 14px;
        border-bottom-left-radius: 4px;
        padding: 14px 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        max-width: 85%;
    }

    .ai-welcome-msg .welcome-title {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 6px;
        color: #333;
    }

    .ai-welcome-msg .welcome-desc {
        font-size: 13px;
        color: #666;
        margin-bottom: 10px;
    }

    .ai-welcome-msg .welcome-suggestions {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .ai-welcome-msg .welcome-suggestion {
        font-size: 12.5px;
        padding: 6px 10px;
        border-radius: 8px;
        cursor: pointer;
        background: #f5f5f5;
        transition: background 0.2s;
        color: #555;
    }

    .ai-welcome-msg .welcome-suggestion:hover {
        background: @accentColor;
        color: white;
    }

    .ai-msg-time {
        font-size: 10px;
        color: #aaa;
        margin-top: 2px;
        text-align: right;
    }

    .ai-msg.user .ai-msg-time { text-align: left; }

    .ai-session-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 12px 10px 10px;
        border-bottom: 1px solid #f0f0f0;
        background: white;
        max-height: 140px;
        overflow-y: auto;
    }

    .ai-session-list .session-item {
        padding: 6px 10px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 12.5px;
        color: #555;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background 0.15s;
    }

    .ai-session-list .session-item:hover,
    .ai-session-list .session-item.active {
        background: #f0f0ff;
        color: #7367f0;
    }

    .ai-session-list .session-item.active {
        background: linear-gradient(135deg, rgba(115,103,240,0.1) 0%, rgba(115,103,240,0.05) 100%);
    }

    .ai-session-new-btn {
        font-size: 12px;
        padding: 6px 10px;
        margin: 0 0 2px;
        border: 1px dashed #ccc;
        border-radius: 8px;
        cursor: pointer;
        color: #888;
        background: transparent;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        align-self: flex-start;
        flex-shrink: 0;
    }

    .ai-session-new-btn:hover {
        border-color: @accentColor;
        color: @accentColor;
    }

    .ai-session-list .cgpt-session-item-icon {
        font-size: 14px;
        flex-shrink: 0;
    }

    .ai-session-list .cgpt-session-item-title {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ai-session-list .cgpt-session-item-time {
        font-size: 10px;
        color: #aaa;
        flex-shrink: 0;
        white-space: nowrap;
    }

    .ai-session-list .cgpt-session-empty {
        font-size: 12px;
        color: #888;
        padding: 8px 10px;
        line-height: 1.4;
    }
</style>

<div id="ai-chat-fab" onclick="toggleAIPanel()" title="AI Assistant">
    <i class="icon-base bx @iconClass" style="font-size: 24px;"></i>
    <span class="fab-badge" id="aiFabBadge"></span>
</div>

<div id="ai-chat-panel">
    <div class="ai-chat-header">
        <div class="ai-chat-header-info">
            <div class="ai-avatar">
                <i class="icon-base bx @iconClass"></i>
            </div>
            <div>
                <div style="font-weight: 600; font-size: 14px;">@departmentName</div>
                <div style="font-size: 11px; opacity: 0.8;">
                    <span class="status-dot" id="aiStatusDot" style="display:inline-block;width:6px;height:6px;background:#4ade80;border-radius:50%;margin-right:4px;"></span>
                    <span id="aiStatusText">Online</span>
                </div>
            </div>
        </div>
        <div class="ai-chat-header-actions">
            <button onclick="createNewSession()" title="Phiên mới">
                <i class="icon-base bx bx-plus"></i>
            </button>
            <button onclick="toggleAIPanel()" title="Dong">
                <i class="icon-base bx bx-x"></i>
            </button>
        </div>
    </div>

    <div class="ai-session-list" id="aiSessionList">
        <span class="ai-session-new-btn" onclick="createNewSession()">
            <i class="icon-base bx bx-plus"></i> New session
        </span>
    </div>

    <div class="ai-chat-messages" id="aiChatMessages">
        <div class="ai-chat-empty" id="aiEmptyState">
            <i class="icon-base bx @iconClass"></i>
            <h6>Chao ban!</h6>
            <p>Toi la @departmentName. Ban can ho tro gi?</p>
        </div>
    </div>

    <div class="ai-quick-actions" id="aiQuickActions">
        @foreach (var action in quickActions)
        {
            <button class="ai-quick-action" onclick="sendQuickMessage('@action.label')">
                <i class="icon-base @action.icon" style="margin-right: 4px;"></i>
                @action.label
            </button>
        }
    </div>

    <div class="ai-chat-input-area">
        <textarea
            id="aiChatInput"
            class="ai-chat-input"
            placeholder="Nhap cau hoi..."
            rows="1"
            onkeydown="handleInputKeydown(event)"
            oninput="autoResizeInput(this)"></textarea>
        <button class="ai-chat-send" id="aiSendBtn" onclick="sendMessage()" disabled>
            <i class="icon-base bx bx-send"></i>
        </button>
    </div>
</div>

<script>
    window.AI_CHAT_DEPARTMENT = "@department";
</script>
