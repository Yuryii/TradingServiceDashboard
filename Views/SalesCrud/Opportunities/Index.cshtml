@model IEnumerable<Dashboard.Models.ViewModels.OpportunityListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Opportunities";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Opportunities</h5>
                <div class="d-flex gap-1">
                    <a asp-action="Opportunities_Export" class="btn btn-success btn-sm" title="Export Excel">
                        <i class="icon-base bx bx-download me-1"></i> Export
                    </a>
                    <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Opportunity" title="Import Excel">
                        <i class="icon-base bx bx-upload me-1"></i> Import
                    </button>
                    <a asp-action="Opportunities_Create" class="btn btn-primary btn-sm">
                        <i class="icon-base bx bx-plus me-1"></i> Create New
                    </a>
                </div>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Opportunity Code</th>
                            <th>Customer</th>
                            <th>Stage</th>
                            <th>Status</th>
                            <th>Estimated Value</th>
                            <th>Probability</th>
                            <th>Expected Close</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.OpportunityCode</strong></td>
                                <td>@item.CustomerName</td>
                                <td>@item.StageName</td>
                                <td>
                                    @{
                                        var statusClass = item.Status?.ToLower() switch
                                        {
                                            "open" => "primary",
                                            "won" => "success",
                                            "lost" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-label-@statusClass">@item.Status</span>
                                </td>
                                <td>@item.EstimatedValue.ToString("N0")</td>
                                <td>@item.Probability%</td>
                                <td>@item.ExpectedCloseDate?.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="Opportunities_Edit" asp-route-id="@item.OpportunityID">
                                                <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            <form asp-action="Opportunities_Delete" asp-route-id="@item.OpportunityID" method="post" onsubmit="return confirm('Are you sure you want to delete this opportunity?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="icon-base bx bx-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@{
    var oppModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "Opportunity",
        EntityType = "Opportunity",
        EntityName = "Opportunity",
        EntityDisplayName = "Co hoi ban hang"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="oppModal" />
