@model IEnumerable<Dashboard.Models.ViewModels.CustomerGroupListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Customer Groups";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Customer Groups</h5>
                <div class="d-flex gap-1">
                    <a asp-action="CustomerGroups_Export" class="btn btn-success btn-sm" title="Export Excel">
                        <i class="icon-base bx bx-download me-1"></i> Export
                    </a>
                    <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-CustomerGroup" title="Import Excel">
                        <i class="icon-base bx bx-upload me-1"></i> Import
                    </button>
                    <a asp-action="CustomerGroups_Create" class="btn btn-primary btn-sm">
                        <i class="icon-base bx bx-plus me-1"></i> Create New
                    </a>
                </div>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Group Code</th>
                            <th>Group Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.GroupCode</strong></td>
                                <td>@item.GroupName</td>
                                <td>@item.Description</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-label-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="CustomerGroups_Edit" asp-route-id="@item.CustomerGroupID">
                                                <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            <form asp-action="CustomerGroups_Delete" asp-route-id="@item.CustomerGroupID" method="post" onsubmit="return confirm('Are you sure you want to delete this customer group?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="icon-base bx bx-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@{
    var cgModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "CustomerGroup",
        EntityType = "CustomerGroup",
        EntityName = "CustomerGroup",
        EntityDisplayName = "Nhom khach hang"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="cgModal" />
