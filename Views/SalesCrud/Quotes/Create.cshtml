@model Dashboard.Models.ViewModels.QuoteCreateVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Create Quote";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Create New Quote</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Quotes_Create" method="post">
          @Html.AntiForgeryToken()

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="QuoteNumber" class="form-label">Quote Number <span class="text-danger">*</span></label>
              <input asp-for="QuoteNumber" class="form-control" placeholder="e.g., QT001" />
              <span asp-validation-for="QuoteNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Status" class="form-label">Status <span class="text-danger">*</span></label>
              <select asp-for="Status" class="form-select">
                <option value="Draft">Draft</option>
                <option value="Sent">Sent</option>
                <option value="Accepted">Accepted</option>
                <option value="Rejected">Rejected</option>
                <option value="Expired">Expired</option>
              </select>
              <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CustomerID" class="form-label">Customer</label>
              <select asp-for="CustomerID" class="form-select">
                <option value="">-- Select Customer --</option>
                @if (ViewBag.Customers != null)
                {
                  @foreach (var item in ViewBag.Customers)
                  {
                    <option value="@item.CustomerID">@item.CustomerName</option>
                  }
                }
              </select>
              <span asp-validation-for="CustomerID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="OpportunityID" class="form-label">Opportunity</label>
              <select asp-for="OpportunityID" class="form-select">
                <option value="">-- Select Opportunity --</option>
                @if (ViewBag.Opportunities != null)
                {
                  @foreach (var item in ViewBag.Opportunities)
                  {
                    <option value="@item.OpportunityID">@item.OpportunityCode</option>
                  }
                }
              </select>
              <span asp-validation-for="OpportunityID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var item in ViewBag.Branches)
                  {
                    <option value="@item.BranchID">@item.BranchName</option>
                  }
                }
              </select>
              <span asp-validation-for="BranchID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="SalesEmployeeID" class="form-label">Sales Employee</label>
              <select asp-for="SalesEmployeeID" class="form-select">
                <option value="">-- Select Employee --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var item in ViewBag.Employees)
                  {
                    <option value="@item.EmployeeID">@item.FullName</option>
                  }
                }
              </select>
              <span asp-validation-for="SalesEmployeeID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="QuoteDate" class="form-label">Quote Date <span class="text-danger">*</span></label>
              <input asp-for="QuoteDate" class="form-control" type="date" />
              <span asp-validation-for="QuoteDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ValidUntilDate" class="form-label">Valid Until Date</label>
              <input asp-for="ValidUntilDate" class="form-control" type="date" />
              <span asp-validation-for="ValidUntilDate" class="text-danger"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="SubTotal" class="form-label">Sub Total</label>
              <input asp-for="SubTotal" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="SubTotal" class="text-danger"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="TaxAmount" class="form-label">Tax Amount</label>
              <input asp-for="TaxAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="TaxAmount" class="text-danger"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="DiscountPercent" class="form-label">Discount (%)</label>
              <input asp-for="DiscountPercent" class="form-control" type="number" step="0.01" min="0" max="100" />
              <span asp-validation-for="DiscountPercent" class="text-danger"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="TotalAmount" class="form-label">Total Amount</label>
              <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="TotalAmount" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="TermsAndConditions" class="form-label">Terms and Conditions</label>
              <textarea asp-for="TermsAndConditions" class="form-control" rows="3" placeholder="Enter terms and conditions"></textarea>
              <span asp-validation-for="TermsAndConditions" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Create Quote
            </button>
            <a asp-action="Quotes" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
