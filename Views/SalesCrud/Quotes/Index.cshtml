@model IEnumerable<Dashboard.Models.ViewModels.QuoteListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Quotes";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Quotes</h5>
        <div class="d-flex gap-1">
          <a asp-action="Quotes_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Quote" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Quotes_Create" class="btn btn-primary btn-sm">
            <i class="icon-base bx bx-plus me-1"></i> Create New Quote
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Quote Number</th>
              <th>Customer</th>
              <th>Opportunity</th>
              <th>Total Amount</th>
              <th>Status</th>
              <th>Quote Date</th>
              <th>Valid Until</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  No quotes found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.QuoteNumber</strong></td>
                  <td>@(item.CustomerName ?? "-")</td>
                  <td>@(item.OpportunityCode ?? "-")</td>
                  <td>@item.TotalAmount.ToString("N2")</td>
                  <td>
                    @{
                      var statusClass = item.Status switch
                      {
                        "Draft" => "bg-label-secondary",
                        "Sent" => "bg-label-info",
                        "Accepted" => "bg-label-success",
                        "Rejected" => "bg-label-danger",
                        "Expired" => "bg-label-warning",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusClass me-1">@item.Status</span>
                  </td>
                  <td>@item.QuoteDate.ToString("yyyy-MM-dd")</td>
                  <td>@(item.ValidUntilDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Quotes_Edit" asp-route-id="@item.QuoteID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Quotes_Delete" asp-route-id="@item.QuoteID" method="post" onsubmit="return confirm('Are you sure you want to delete quote: @item.QuoteNumber?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@{
    var quoteModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "Quote",
        EntityType = "Quote",
        EntityName = "Quote",
        EntityDisplayName = "Bao gia"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="quoteModal" />
