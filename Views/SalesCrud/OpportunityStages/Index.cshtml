@model IEnumerable<Dashboard.Models.ViewModels.OpportunityStageListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Opportunity Stages";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Opportunity Stages</h5>
                <div class="d-flex gap-1">
                    <a asp-action="OpportunityStages_Export" class="btn btn-success btn-sm" title="Export Excel">
                        <i class="icon-base bx bx-download me-1"></i> Export
                    </a>
                    <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-OpportunityStage" title="Import Excel">
                        <i class="icon-base bx bx-upload me-1"></i> Import
                    </button>
                    <a asp-action="OpportunityStages_Create" class="btn btn-primary btn-sm">
                        <i class="icon-base bx bx-plus me-1"></i> Create New
                    </a>
                </div>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Stage Code</th>
                            <th>Stage Name</th>
                            <th>Stage Order</th>
                            <th>Closed</th>
                            <th>Won</th>
                            <th>Lost</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.StageCode</strong></td>
                                <td>@item.StageName</td>
                                <td>@item.StageOrder</td>
                                <td>
                                    @if (item.IsClosedStage)
                                    {
                                        <span class="badge bg-label-success"><i class="icon-base bx bx-check"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary"><i class="icon-base bx bx-x"></i></span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsWonStage)
                                    {
                                        <span class="badge bg-label-success"><i class="icon-base bx bx-check"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary"><i class="icon-base bx bx-x"></i></span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsLostStage)
                                    {
                                        <span class="badge bg-label-danger"><i class="icon-base bx bx-check"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-secondary"><i class="icon-base bx bx-x"></i></span>
                                    }
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="OpportunityStages_Edit" asp-route-id="@item.StageID">
                                                <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            <form asp-action="OpportunityStages_Delete" asp-route-id="@item.StageID" method="post" onsubmit="return confirm('Are you sure you want to delete this stage?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="icon-base bx bx-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@{
    var osModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "OpportunityStage",
        EntityType = "OpportunityStage",
        EntityName = "OpportunityStage",
        EntityDisplayName = "Giai doan co hoi"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="osModal" />
