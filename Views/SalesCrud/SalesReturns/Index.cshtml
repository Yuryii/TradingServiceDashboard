@model IEnumerable<Dashboard.Models.ViewModels.SalesReturnListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Sales Returns";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Sales Returns</h5>
                <div class="d-flex gap-1">
                    <a asp-action="SalesReturns_Export" class="btn btn-success btn-sm" title="Export Excel">
                        <i class="icon-base bx bx-download me-1"></i> Export
                    </a>
                    <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-SalesReturn" title="Import Excel">
                        <i class="icon-base bx bx-upload me-1"></i> Import
                    </button>
                    <a asp-action="SalesReturns_Create" class="btn btn-primary btn-sm">
                        <i class="icon-base bx bx-plus me-1"></i> Create New
                    </a>
                </div>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Return Number</th>
                            <th>Customer</th>
                            <th>Sales Order</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Return Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ReturnNumber</strong></td>
                                <td>@item.CustomerName</td>
                                <td>@item.SalesOrderNumber</td>
                                <td>@item.TotalAmount.ToString("N0")</td>
                                <td>
                                    @{
                                        var statusClass = item.Status?.ToLower() switch
                                        {
                                            "approved" => "success",
                                            "pending" => "warning",
                                            "rejected" => "danger",
                                            "processed" => "info",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-label-@statusClass">@item.Status</span>
                                </td>
                                <td>@item.ReturnDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="SalesReturns_Edit" asp-route-id="@item.ReturnID">
                                                <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            <form asp-action="SalesReturns_Delete" asp-route-id="@item.ReturnID" method="post" onsubmit="return confirm('Are you sure you want to delete this sales return?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="icon-base bx bx-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@{
    var srModal = new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "SalesReturn",
        EntityType = "SalesReturn",
        EntityName = "SalesReturn",
        EntityDisplayName = "Tra hang"
    };
}
<partial name="~/Views/Shared/Partials/_ExcelImportModal.cshtml" model="srModal" />
