@model Dashboard.Models.ViewModels.SalesInvoiceCreateVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Create Sales Invoice";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Create New Sales Invoice</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="SalesInvoices_Create" method="post">
          @Html.AntiForgeryToken()

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="InvoiceNumber" class="form-label">Invoice Number <span class="text-danger">*</span></label>
              <input asp-for="InvoiceNumber" class="form-control" placeholder="e.g., INV001" />
              <span asp-validation-for="InvoiceNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="InvoiceDate" class="form-label">Invoice Date <span class="text-danger">*</span></label>
              <input asp-for="InvoiceDate" class="form-control" type="date" />
              <span asp-validation-for="InvoiceDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="DueDate" class="form-label">Due Date</label>
              <input asp-for="DueDate" class="form-control" type="date" />
              <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="SalesOrderID" class="form-label">Sales Order</label>
              <select asp-for="SalesOrderID" class="form-select">
                <option value="">-- Select Sales Order --</option>
                @if (ViewBag.SalesOrders != null)
                {
                  @foreach (var item in ViewBag.SalesOrders)
                  {
                    <option value="@item.SalesOrderID">@item.OrderNumber</option>
                  }
                }
              </select>
              <span asp-validation-for="SalesOrderID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CustomerID" class="form-label">Customer</label>
              <select asp-for="CustomerID" class="form-select">
                <option value="">-- Select Customer --</option>
                @if (ViewBag.Customers != null)
                {
                  @foreach (var item in ViewBag.Customers)
                  {
                    <option value="@item.CustomerID">@item.CustomerName</option>
                  }
                }
              </select>
              <span asp-validation-for="CustomerID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var item in ViewBag.Branches)
                  {
                    <option value="@item.BranchID">@item.BranchName</option>
                  }
                }
              </select>
              <span asp-validation-for="BranchID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="SalesEmployeeID" class="form-label">Sales Employee</label>
              <select asp-for="SalesEmployeeID" class="form-select">
                <option value="">-- Select Employee --</option>
                @if (ViewBag.Employees != null)
                {
                  @foreach (var item in ViewBag.Employees)
                  {
                    <option value="@item.EmployeeID">@item.FullName</option>
                  }
                }
              </select>
              <span asp-validation-for="SalesEmployeeID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="PaymentStatus" class="form-label">Payment Status <span class="text-danger">*</span></label>
              <select asp-for="PaymentStatus" class="form-select">
                <option value="Unpaid">Unpaid</option>
                <option value="Partial">Partial</option>
                <option value="Paid">Paid</option>
                <option value="Overdue">Overdue</option>
              </select>
              <span asp-validation-for="PaymentStatus" class="text-danger"></span>
            </div>
            <div class="col-md-3">
              <label asp-for="SubTotal" class="form-label">Sub Total</label>
              <input asp-for="SubTotal" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="SubTotal" class="text-danger"></span>
            </div>
            <div class="col-md-3">
              <label asp-for="TaxAmount" class="form-label">Tax Amount</label>
              <input asp-for="TaxAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="TaxAmount" class="text-danger"></span>
            </div>
            <div class="col-md-3">
              <label asp-for="DiscountAmount" class="form-label">Discount</label>
              <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="DiscountAmount" class="text-danger"></span>
            </div>
            <div class="col-md-3">
              <label asp-for="TotalAmount" class="form-label">Total Amount</label>
              <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="TotalAmount" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="PaidAmount" class="form-label">Paid Amount</label>
              <input asp-for="PaidAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="PaidAmount" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="OutstandingAmount" class="form-label">Outstanding Amount</label>
              <input asp-for="OutstandingAmount" class="form-control" type="number" step="0.01" />
              <span asp-validation-for="OutstandingAmount" class="text-danger"></span>
            </div>
            <div class="col-12">
              <label asp-for="Notes" class="form-label">Notes</label>
              <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional notes"></textarea>
              <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Create Invoice
            </button>
            <a asp-action="SalesInvoices" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
