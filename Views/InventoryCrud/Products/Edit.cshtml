@model Dashboard.Models.ViewModels.ProductEditVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Edit Product";
}

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Edit Product</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="ProductID" />
          <input type="hidden" asp-for="CreatedAt" />

          <div class="row g-6">
            <div class="col-md-6">
              <label asp-for="ProductCode" class="form-label">Product Code</label>
              <input asp-for="ProductCode" class="form-control" placeholder="Enter product code" />
              <span asp-validation-for="ProductCode" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ProductName" class="form-label">Product Name</label>
              <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
              <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CategoryID" class="form-label">Category</label>
              <select asp-for="CategoryID" class="form-select">
                <option value="">-- Select Category --</option>
                @if (ViewBag.Categories != null)
                {
                  @foreach (var category in ViewBag.Categories)
                  {
                    <option value="@category.CategoryID">@category.CategoryName</option>
                  }
                }
              </select>
              <span asp-validation-for="CategoryID" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ProductType" class="form-label">Product Type</label>
              <input asp-for="ProductType" class="form-control" placeholder="e.g., Finished Goods, Raw Material" />
              <span asp-validation-for="ProductType" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="UnitOfMeasure" class="form-label">Unit of Measure</label>
              <input asp-for="UnitOfMeasure" class="form-control" placeholder="e.g., PCS, KG, BOX" />
              <span asp-validation-for="UnitOfMeasure" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Brand" class="form-label">Brand</label>
              <input asp-for="Brand" class="form-control" placeholder="Enter brand name" />
              <span asp-validation-for="Brand" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="SalePrice" class="form-label">Sale Price</label>
              <input asp-for="SalePrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
              <span asp-validation-for="SalePrice" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="CostPrice" class="form-label">Cost Price</label>
              <input asp-for="CostPrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
              <span asp-validation-for="CostPrice" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="ReorderLevel" class="form-label">Reorder Level</label>
              <input asp-for="ReorderLevel" class="form-control" type="number" placeholder="0" />
              <span asp-validation-for="ReorderLevel" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="MaxStockLevel" class="form-label">Max Stock Level</label>
              <input asp-for="MaxStockLevel" class="form-control" type="number" placeholder="0" />
              <span asp-validation-for="MaxStockLevel" class="text-danger"></span>
            </div>
            <div class="col-md-6">
              <div class="form-check mt-6">
                <input asp-for="IsStockItem" class="form-check-input" type="checkbox" />
                <label asp-for="IsStockItem" class="form-check-label">Is Stock Item</label>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-check mt-6">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Is Active</label>
              </div>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
