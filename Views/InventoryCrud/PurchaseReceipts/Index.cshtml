@model IEnumerable<Dashboard.Models.ViewModels.PurchaseReceiptListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Purchase Receipts";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Inventory /</span> Purchase Receipts
    </h4>
  </div>
</div>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Purchase Receipts</h5>
        <div class="d-flex gap-1">
          <a asp-action="PurchaseReceipt_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-PurchaseReceipt" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="PurchaseReceiptsCreate" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Receipt Number</th>
              <th>Supplier</th>
              <th>Purchase Order</th>
              <th>Total Amount</th>
              <th>Status</th>
              <th>Receipt Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No purchase receipts found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.ReceiptNumber</strong></td>
                  <td>@item.SupplierName</td>
                  <td>@(item.PurchaseOrderNumber ?? "-")</td>
                  <td>@item.TotalAmount.ToString("N2")</td>
                  <td>
                    @{
                      var statusBadgeClass = item.Status switch
                      {
                        "Completed" => "bg-label-success",
                        "Partial" => "bg-label-warning",
                        "Pending" => "bg-label-info",
                        "Cancelled" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusBadgeClass">@item.Status</span>
                  </td>
                  <td>@item.ReceiptDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="PurchaseReceiptsEdit" asp-route-id="@item.ReceiptID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="PurchaseReceiptsDelete" asp-route-id="@item.ReceiptID" method="post" onsubmit="return confirm('Are you sure you want to delete this purchase receipt: @item.ReceiptNumber?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "PurchaseReceipt",
        EntityType = "PurchaseReceipt",
        EntityName = "PurchaseReceipt",
        EntityDisplayName = "Phieu nhap hang"
    })
