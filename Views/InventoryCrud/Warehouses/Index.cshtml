@model IEnumerable<Dashboard.Models.ViewModels.WarehouseListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Warehouses";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Warehouses</h5>
        <div class="d-flex gap-1">
          <a asp-action="Warehouse_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Warehouse" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Create" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Warehouse Code</th>
              <th>Warehouse Name</th>
              <th>Branch</th>
              <th>City</th>
              <th>Province</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No warehouses found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.WarehouseCode</strong></td>
                  <td>@item.WarehouseName</td>
                  <td>@(item.BranchName ?? "-")</td>
                  <td>@(item.City ?? "-")</td>
                  <td>@(item.Province ?? "-")</td>
                  <td>
                    @if (item.IsActive)
                    {
                      <span class="badge bg-label-success me-1">Active</span>
                    }
                    else
                    {
                      <span class="badge bg-label-secondary me-1">Inactive</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.WarehouseID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.WarehouseID" method="post" onsubmit="return confirm('Are you sure you want to delete this warehouse?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "Warehouse",
        EntityType = "Warehouse",
        EntityName = "Warehouse",
        EntityDisplayName = "Kho"
    })
