@model Dashboard.Models.ViewModels.PurchaseInvoiceCreateVM
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Create Purchase Invoice";
}

<div class="row">
  <div class="col-12 col-lg-10">
    <div class="card mb-6">
      <div class="card-header">
        <h5 class="mb-0">Create New Purchase Invoice</h5>
      </div>
      <div class="card-body pt-4">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
          <div class="alert alert-danger" role="alert">
            <div asp-validation-summary="ModelOnly"></div>
          </div>
        }

        <form asp-action="PurchaseInvoicesCreate" method="post">
          @Html.AntiForgeryToken()

          <div class="row g-6">
            <div class="col-md-4">
              <label asp-for="InvoiceNumber" class="form-label">Invoice Number</label>
              <input asp-for="InvoiceNumber" class="form-control" placeholder="Enter invoice number" />
            </div>
            <div class="col-md-4">
              <label asp-for="PurchaseOrderID" class="form-label">Purchase Order</label>
              <select asp-for="PurchaseOrderID" class="form-select">
                <option value="">-- Select Purchase Order --</option>
                @if (ViewBag.PurchaseOrders != null)
                {
                  @foreach (var po in ViewBag.PurchaseOrders)
                  {
                    <option value="@po.PurchaseOrderID">@po.OrderNumber</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-4">
              <label asp-for="SupplierID" class="form-label">Supplier</label>
              <select asp-for="SupplierID" class="form-select">
                <option value="">-- Select Supplier --</option>
                @if (ViewBag.Suppliers != null)
                {
                  @foreach (var supplier in ViewBag.Suppliers)
                  {
                    <option value="@supplier.SupplierID">@supplier.SupplierName</option>
                  }
                }
              </select>
              <span asp-validation-for="SupplierID" class="text-danger"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="WarehouseID" class="form-label">Warehouse</label>
              <select asp-for="WarehouseID" class="form-select">
                <option value="">-- Select Warehouse --</option>
                @if (ViewBag.Warehouses != null)
                {
                  @foreach (var warehouse in ViewBag.Warehouses)
                  {
                    <option value="@warehouse.WarehouseID">@warehouse.WarehouseName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-4">
              <label asp-for="BranchID" class="form-label">Branch</label>
              <select asp-for="BranchID" class="form-select">
                <option value="">-- Select Branch --</option>
                @if (ViewBag.Branches != null)
                {
                  @foreach (var branch in ViewBag.Branches)
                  {
                    <option value="@branch.BranchID">@branch.BranchName</option>
                  }
                }
              </select>
            </div>
            <div class="col-md-4">
              <label asp-for="InvoiceDate" class="form-label">Invoice Date</label>
              <input asp-for="InvoiceDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
              <label asp-for="DueDate" class="form-label">Due Date</label>
              <input asp-for="DueDate" class="form-control" type="date" />
            </div>
            <div class="col-md-2">
              <label asp-for="SubTotal" class="form-label">Sub Total</label>
              <input asp-for="SubTotal" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="TaxAmount" class="form-label">Tax Amount</label>
              <input asp-for="TaxAmount" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="DiscountAmount" class="form-label">Discount</label>
              <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="TotalAmount" class="form-label">Total Amount</label>
              <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="AmountPaid" class="form-label">Amount Paid</label>
              <input asp-for="AmountPaid" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="AmountDue" class="form-label">Amount Due</label>
              <input asp-for="AmountDue" class="form-control" type="number" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-2">
              <label asp-for="PaymentStatus" class="form-label">Payment Status</label>
              <select asp-for="PaymentStatus" class="form-select">
                <option value="Pending">Pending</option>
                <option value="Partial">Partial</option>
                <option value="Paid">Paid</option>
                <option value="Overdue">Overdue</option>
              </select>
            </div>
            <div class="col-md-2">
              <label asp-for="Status" class="form-label">Status</label>
              <select asp-for="Status" class="form-select">
                <option value="Draft">Draft</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Cancelled">Cancelled</option>
              </select>
            </div>
            <div class="col-12">
              <label asp-for="Notes" class="form-label">Notes</label>
              <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Enter any notes..."></textarea>
            </div>
          </div>

          <div class="mt-6 d-flex gap-3">
            <button type="submit" class="btn btn-primary">
              <i class="icon-base bx bx-save me-1"></i> Create Purchase Invoice
            </button>
            <a asp-action="PurchaseInvoicesIndex" class="btn btn-outline-secondary">
              <i class="icon-base bx bx-x me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
