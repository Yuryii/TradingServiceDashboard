@model IEnumerable<Dashboard.Models.ViewModels.PurchaseInvoiceListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Purchase Invoices";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Inventory /</span> Purchase Invoices
    </h4>
  </div>
</div>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Purchase Invoices</h5>
        <div class="d-flex gap-1">
          <a asp-action="PurchaseInvoice_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-PurchaseInvoice" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="PurchaseInvoicesCreate" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Invoice Number</th>
              <th>Supplier</th>
              <th>Total Amount</th>
              <th>Payment Status</th>
              <th>Status</th>
              <th>Invoice Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No purchase invoices found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.InvoiceNumber</strong></td>
                  <td>@item.SupplierName</td>
                  <td>@item.TotalAmount.ToString("N2")</td>
                  <td>
                    @{
                      var paymentBadgeClass = item.PaymentStatus switch
                      {
                        "Paid" => "bg-label-success",
                        "Partial" => "bg-label-warning",
                        "Overdue" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @paymentBadgeClass">@item.PaymentStatus</span>
                  </td>
                  <td>
                    @{
                      var statusBadgeClass = item.Status switch
                      {
                        "Approved" => "bg-label-success",
                        "Pending" => "bg-label-warning",
                        "Cancelled" => "bg-label-danger",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @statusBadgeClass">@item.Status</span>
                  </td>
                  <td>@item.InvoiceDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="PurchaseInvoicesEdit" asp-route-id="@item.InvoiceID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="PurchaseInvoicesDelete" asp-route-id="@item.InvoiceID" method="post" onsubmit="return confirm('Are you sure you want to delete this purchase invoice: @item.InvoiceNumber?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "PurchaseInvoice",
        EntityType = "PurchaseInvoice",
        EntityName = "PurchaseInvoice",
        EntityDisplayName = "Hoa don mua hang"
    })
