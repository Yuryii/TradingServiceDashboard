@model IEnumerable<Dashboard.Models.ViewModels.SupplierPaymentListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Supplier Payments";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Supplier Payments</h5>
                <div class="d-flex gap-1">
                    <a asp-action="SupplierPayment_Export" class="btn btn-success btn-sm" title="Export Excel">
                        <i class="icon-base bx bx-download me-1"></i> Export
                    </a>
                    <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-SupplierPayment" title="Import Excel">
                        <i class="icon-base bx bx-upload me-1"></i> Import
                    </button>
                    <a asp-action="SupplierPayments_Create" class="btn btn-primary">
                        <i class="icon-base bx bx-plus me-1"></i> Create New
                    </a>
                </div>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Payment Number</th>
                            <th>Supplier</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Payment Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.PaymentNumber</strong></td>
                                <td>@item.SupplierName</td>
                                <td>@item.Amount.ToString("N0")</td>
                                <td>@item.PaymentMethod</td>
                                <td>@item.PaymentDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="SupplierPayments_Edit" asp-route-id="@item.PaymentID">
                                                <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            <form asp-action="SupplierPayments_Delete" asp-route-id="@item.PaymentID" method="post" onsubmit="return confirm('Are you sure you want to delete this supplier payment?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="icon-base bx bx-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "SupplierPayment",
        EntityType = "SupplierPayment",
        EntityName = "SupplierPayment",
        EntityDisplayName = "Thanh toan nha cung cap"
    })
