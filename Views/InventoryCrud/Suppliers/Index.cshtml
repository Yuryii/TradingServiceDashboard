@model IEnumerable<Dashboard.Models.ViewModels.SupplierListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Suppliers";
}
<div class="row">
  <div class="col-12 mb-4">
    <h4 class="fw-bold py-3 mb-2">
      <span class="text-muted fw-light">Inventory /</span> Suppliers
    </h4>
  </div>
</div>
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Suppliers</h5>
        <div class="d-flex gap-1">
          <a asp-action="Supplier_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-Supplier" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="SuppliersCreate" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Supplier Code</th>
              <th>Supplier Name</th>
              <th>Type</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Active</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No suppliers found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.SupplierCode</strong></td>
                  <td>@item.SupplierName</td>
                  <td>@item.SupplierType</td>
                  <td>@(item.Phone ?? "-")</td>
                  <td>@(item.Email ?? "-")</td>
                  <td>
                    @if (item.IsActive)
                    {
                      <span class="badge bg-label-success">Yes</span>
                    }
                    else
                    {
                      <span class="badge bg-label-danger">No</span>
                    }
                  </td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="SuppliersEdit" asp-route-id="@item.SupplierID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="SuppliersDelete" asp-route-id="@item.SupplierID" method="post" onsubmit="return confirm('Are you sure you want to delete supplier: @item.SupplierName?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "Supplier",
        EntityType = "Supplier",
        EntityName = "Supplier",
        EntityDisplayName = "Nha cung cap"
    })
