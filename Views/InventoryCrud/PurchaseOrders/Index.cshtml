@model IEnumerable<Dashboard.Models.ViewModels.PurchaseOrderListVM>
@{
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    ViewData["Title"] = "Purchase Orders";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Purchase Orders</h5>
        <div class="d-flex gap-1">
          <a asp-action="PurchaseOrder_Export" class="btn btn-success btn-sm" title="Export Excel">
            <i class="icon-base bx bx-download me-1"></i> Export
          </a>
          <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#excelImportModal-PurchaseOrder" title="Import Excel">
            <i class="icon-base bx bx-upload me-1"></i> Import
          </button>
          <a asp-action="Create" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Create New
          </a>
        </div>
      </div>
      <div class="table-responsive text-nowrap">
        <table class="table">
          <thead>
            <tr>
              <th>Order Number</th>
              <th>Supplier</th>
              <th>Total Amount</th>
              <th>Payment Status</th>
              <th>Delivery Status</th>
              <th>Status</th>
              <th>Order Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody class="table-border-bottom-0">
            @if (!Model.Any())
            {
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  No purchase orders found.
                </td>
              </tr>
            }
            else
            {
              @foreach (var item in Model)
              {
                <tr>
                  <td><strong>@item.OrderNumber</strong></td>
                  <td>@(item.SupplierName ?? "-")</td>
                  <td>@item.TotalAmount.ToString("N2")</td>
                  <td>
                    @{
                      var paymentBadgeClass = item.PaymentStatus switch
                      {
                        "Paid" => "bg-label-success",
                        "Partial" => "bg-label-warning",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @paymentBadgeClass me-1">@item.PaymentStatus</span>
                  </td>
                  <td>
                    @{
                      var deliveryBadgeClass = item.DeliveryStatus switch
                      {
                        "Delivered" => "bg-label-success",
                        "Partial" => "bg-label-warning",
                        _ => "bg-label-secondary"
                      };
                    }
                    <span class="badge @deliveryBadgeClass me-1">@item.DeliveryStatus</span>
                  </td>
                  <td>
                    @{
                      var statusBadgeClass = item.Status switch
                      {
                        "Approved" => "bg-label-success",
                        "Rejected" => "bg-label-danger",
                        "Draft" => "bg-label-secondary",
                        _ => "bg-label-info"
                      };
                    }
                    <span class="badge @statusBadgeClass me-1">@item.Status</span>
                  </td>
                  <td>@item.OrderDate.ToString("yyyy-MM-dd")</td>
                  <td>
                    <div class="dropdown">
                      <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                      </button>
                      <div class="dropdown-menu">
                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.PurchaseOrderID">
                          <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.PurchaseOrderID" method="post" onsubmit="return confirm('Are you sure you want to delete this purchase order?');" style="display:inline;">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="dropdown-item text-danger">
                            <i class="icon-base bx bx-trash me-1"></i> Delete
                          </button>
                        </form>
                      </div>
                    </div>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_ExcelImportModal.cshtml",
    new Dashboard.Models.ViewModels.ExcelImportModalVM
    {
        ModalId = "PurchaseOrder",
        EntityType = "PurchaseOrder",
        EntityName = "PurchaseOrder",
        EntityDisplayName = "Don dat hang"
    })
