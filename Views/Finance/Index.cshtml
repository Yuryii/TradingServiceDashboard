      </div>
    </div>
  </div>
  <div class="col-md-6 col-lg-4 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/chart-bar.png" alt="DPO" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardDpo" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
