@* Chart Section 4 (full width): Customer Profit Scatter *@
<div class="row">
  <div class="col-12 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Customer Revenue vs Profit</h5>
          <p class="card-subtitle">Scatter plot of customer profitability</p>
        </div>
      </div>
      <div class="card-body">
        <div id="customerProfitScatterChart" class="apex-charts" style="height: 300px;"></div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12 col-xxl-8 order-2 order-md-3 order-xxl-2 mb-6">
    <div class="card">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Financial Overview</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="financeChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="financeChart">
                <a class="dropdown-item" href="javascript:void(0);">This Quarter</a>
                <a class="dropdown-item" href="javascript:void(0);">This Year</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.ProfitMarginPercent% Profit Margin</h6>
            </div>
            <div id="growthChart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-8 col-lg-12 col-xxl-4 order-3 order-md-2 mb-6">
    <div class="row">
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Net Profit" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.NetProfit.Title</p>
            <h4 class="card-title mb-3">@Model.NetProfit.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.NetProfit.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Cash Flow" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu" aria-labelledby="cardOpt4">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.CashFlow.Title</p>
            <h4 class="card-title mb-3">@Model.CashFlow.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.CashFlow.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6 col-lg-4 order-0 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Expense Breakdown</h5>
          <p class="card-subtitle">By Category</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.ExpenseBreakdown.Any())
          {
            @foreach (var expense in Model.ExpenseBreakdown.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @expense.IconBgClass"><i class="@expense.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@expense.Name</h6>
                    <small>@expense.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0">@expense.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-building"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Operations</h6>
                  <small>35% of expenses</small>
                </div>
                <div class="user-progress"><h6 class="mb-0">$404,600</h6></div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-1 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Recent Transactions</h5>
          <p class="card-subtitle">Latest Financial Activity</p>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="p-0 m-0">
          @if (Model.RecentTransactions.Any())
          {
            @foreach (var tx in Model.RecentTransactions.Take(5))
            {
              <li class="d-flex align-items-center mb-6">
                <div class="avatar flex-shrink-0 me-3">
                  <img src="~/img/icons/unicons/wallet.png" alt="Transaction" class="rounded" />
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <small class="d-block">@tx.Column1</small>
                    <h6 class="fw-normal mb-0">@tx.Column3</h6>
                  </div>
                  <div class="user-progress d-flex align-items-center gap-2">
                    <h6 class="fw-normal mb-0 @tx.TrendClass">@tx.Column4</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-6">
              <div class="avatar flex-shrink-0 me-3">
                <img src="~/img/icons/unicons/wallet.png" alt="Transaction" class="rounded" />
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <small class="d-block">Invoice #2845</small>
                  <h6 class="fw-normal mb-0">Client Payment</h6>
                </div>
                <div class="user-progress d-flex align-items-center gap-2">
                  <h6 class="fw-normal mb-0 text-success">+$12,500</h6>
                </div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-2 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Monthly Budget</h5>
          <p class="card-subtitle">Budget vs Actual</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.MonthlyBudgetStatus.Any())
          {
            @foreach (var budget in Model.MonthlyBudgetStatus.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @budget.IconBgClass"><i class="@budget.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@budget.Name</h6>
                    <small>@budget.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0 @budget.IconBgClass.Replace("bg-label-", "text-").Replace("bg-", "")">@budget.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-success"><i class="icon-base bx bx-check-circle"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Revenue</h6>
                  <small>105% of target</small>
                </div>
                <div class="user-progress"><h6 class="mb-0 text-success">On Track</h6></div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>
</div>

@if (Model.FinancialOverviewChart.Series.Any())
{
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof config === 'undefined') window.config = {};
      if (!window.config.colors) window.config.colors = {};
      if (!window.config.fontFamily) window.config.fontFamily = 'Plus Jakarta Sans';
      var cardColor    = window.config.colors.cardColor    || '#ffffff';
      var headingColor = window.config.colors.headingColor || '#566a7f';
      var legendColor  = window.config.colors.bodyColor    || '#697a8d';
      var labelColor   = window.config.colors.textMuted   || '#a1acb8';
      var borderColor  = '#eceef1';

      var chartData = @Html.Raw(Json.Serialize(Model.FinancialOverviewChart));
      var chartEl = document.querySelector('#totalRevenueChart');
      if (chartEl && typeof ApexCharts !== 'undefined') {
        var options = {
          chart: { height: 300, stacked: true, type: 'bar', toolbar: { show: false } },
          plotOptions: { bar: { horizontal: false, columnWidth: '30%', borderRadius: 8, borderRadiusApplication: 'around' } },
          colors: ['#6965fd', '#03c3ec'],
          dataLabels: { enabled: false },
          stroke: { curve: 'smooth', width: 6, lineCap: 'round', colors: [cardColor] },
          legend: { show: true, horizontalAlign: 'left', position: 'top', markers: { size: 4, radius: 12, shape: 'circle', strokeWidth: 0 }, fontSize: '13px', fontFamily: config.fontFamily, labels: { colors: legendColor, useSeriesColors: false }, itemMargin: { horizontal: 10 } },
          grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: 0, bottom: -8, left: 20, right: 20 } },
          fill: { opacity: [1, 1] },
          xaxis: { categories: chartData.categories || [], labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }, axisTicks: { show: false }, axisBorder: { show: false } },
