@model FinanceDashboardViewModel
@{
  ViewData["Title"] = "Finance Dashboard";
  bool hasWaterfall = Model.ProfitWaterfallChart?.Series?.Any() == true;
  bool hasCashflow  = Model.CashflowTrendAreaChart?.Series?.Any() == true;
  bool hasDsoDpo    = Model.DsoDpoTrendChart?.Series?.Any() == true;
  bool hasArAp      = Model.ArApAgingStackedChart?.Series?.Any() == true;
  bool hasCollPerf  = Model.CollectionsPerformanceChart?.Series?.Any() == true;
  bool hasUnitEcon  = Model.UnitEconomicsChart?.Series?.Any() == true;
  bool hasScatter   = Model.CustomerProfitScatterChart?.Series?.Any() == true;
  bool hasOverview  = Model.FinancialOverviewChart?.Series?.Any() == true;

  int chartRow1 = 12;
  int chartRow2 = chartRow1 + 8;
  int chartRow3 = chartRow2 + 8;
  int chartRow4 = chartRow3 + 8;
  int chartRow5 = hasScatter ? chartRow4 + 8 : chartRow4;
  int bottomRow = chartRow5 + 8;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Inject all charts so dashboards-analytics.js doesn't throw ReferenceError *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
Object.assign(window.dashboardCharts, {
  incomeChart: @Html.Raw(Json.Serialize(Model.FinancialOverviewChart)),
  expensesChart: @Html.Raw(Json.Serialize(Model.FinancialOverviewChart)),
  profitWaterfall: @Html.Raw(Json.Serialize(Model.ProfitWaterfallChart)),
  cashflowTrendArea: @Html.Raw(Json.Serialize(Model.CashflowTrendAreaChart)),
  dsoDpoTrend: @Html.Raw(Json.Serialize(Model.DsoDpoTrendChart)),
  collectionsPerf: @Html.Raw(Json.Serialize(Model.CollectionsPerformanceChart)),
  expenseTreemap: @Html.Raw(Json.Serialize(Model.ExpenseTreemapChart)),
  unitEconomics: @Html.Raw(Json.Serialize(Model.UnitEconomicsChart)),
  customerProfitScatter: @Html.Raw(Json.Serialize(Model.CustomerProfitScatterChart)),
  arApAgingStacked: @Html.Raw(Json.Serialize(Model.ArApAgingStackedChart))
});
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script src="~/js/dashboard-layout-manager.js"></script>
}

@* Layout Toolbar *@
<div class="d-flex align-items-center gap-2 mb-4">
  <a asp-action="ExportPdf" class="btn btn-sm btn-danger" target="_blank">
    <i class="icon-base bx bxs-file-pdf me-1"></i> Export PDF
  </a>
  <button type="button" class="btn-layout-action" id="btn-layout-edit"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.toggleEditMode()">
    <i class="icon-base bx bx-palette me-1"></i> Customize Layout
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-save"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.saveLayout()">
    <i class="icon-base bx bx-check me-1"></i> Save
  </button>
  <button type="button" class="btn-layout-action" id="btn-layout-reset"
    onclick="window.dashboardLayoutManager && window.dashboardLayoutManager.resetLayout()">
    <i class="icon-base bx bx-refresh me-1"></i> Reset
  </button>
</div>

@* ============ GRID ============ *@
<div id="finance-dashboard-grid-container" style="position: relative;">
  <div id="finance-dashboard-grid" class="grid-stack">

    @* ---- Row 0: Welcome + 2 KPI cards ---- *@
    <div class="grid-stack-item"
         data-widget-id="finance-welcome"
         data-gs-x="0" data-gs-y="0" data-gs-width="8" data-gs-height="6">
      <div class="grid-stack-item-content card">
        <div class="d-flex align-items-start row">
          <div class="col-sm-7">
            <div class="card-body">
              <h5 class="card-title text-primary mb-3">Finance Overview 💰</h5>
              <p class="mb-6">Welcome to the Finance Dashboard. Track expenses and financial health.</p>
              <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Reports</a>
            </div>
          </div>
          <div class="col-sm-5 text-center text-sm-left">
            <div class="card-body pb-0 px-0 px-md-6">
              <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Finance Dashboard" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-kpi-income"
         data-gs-x="8" data-gs-y="0" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Income" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.TotalIncome.Title</p>
          <h4 class="card-title mb-3">@Model.TotalIncome.Value</h4>
          <small class="text-@(Model.TotalIncome.Trend == "up" ? "success" : Model.TotalIncome.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.TotalIncome.Trend == "up" ? "bx-up-arrow-alt" : Model.TotalIncome.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.TotalIncome.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-kpi-expenses"
         data-gs-x="8" data-gs-y="3" data-gs-width="4" data-gs-height="3">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="Expenses" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.TotalExpenses.Title</p>
          <h4 class="card-title mb-3">@Model.TotalExpenses.Value</h4>
          <small class="text-@(Model.TotalExpenses.Trend == "up" ? "success" : Model.TotalExpenses.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.TotalExpenses.Trend == "up" ? "bx-up-arrow-alt" : Model.TotalExpenses.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.TotalExpenses.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Row 6: DSO + DPO + AR Balance KPI ---- *@
    <div class="grid-stack-item"
         data-widget-id="finance-kpi-dso"
         data-gs-x="0" data-gs-y="6" data-gs-width="4" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-line.png" alt="DSO" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Dso.Title</p>
          <h4 class="card-title mb-3">@Model.Dso.Value</h4>
          <small class="text-primary fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.Dso.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-kpi-dpo"
         data-gs-x="4" data-gs-y="6" data-gs-width="4" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-bar.png" alt="DPO" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.Dpo.Title</p>
          <h4 class="card-title mb-3">@Model.Dpo.Value</h4>
          <small class="text-primary fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.Dpo.TrendLabel</small>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-kpi-arbalance"
         data-gs-x="8" data-gs-y="6" data-gs-width="4" data-gs-height="6">
      <div class="grid-stack-item-content card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet.png" alt="AR Balance" class="rounded" />
            </div>
          </div>
          <p class="mb-1">@Model.ArBalance.Title</p>
          <h4 class="card-title mb-3">@Model.ArBalance.Value</h4>
          <small class="text-@(Model.ArBalance.Trend == "up" ? "success" : Model.ArBalance.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.ArBalance.Trend == "up" ? "bx-up-arrow-alt" : Model.ArBalance.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.ArBalance.TrendLabel</small>
        </div>
      </div>
    </div>

    @* ---- Chart Row 1: Profit Waterfall + Cash Flow ---- *@
    @if (hasWaterfall || hasCashflow)
    {
      <div class="grid-stack-item"
           data-widget-id="finance-chart-waterfall"
           data-gs-x="0" data-gs-y="@chartRow1" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Profit Waterfall</h5>
              <p class="card-subtitle">Revenue to Net Profit</p>
            </div>
          </div>
          <div class="card-body">
            <div id="profitWaterfallChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="finance-chart-cashflow"
           data-gs-x="6" data-gs-y="@chartRow1" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Cash Flow Trend</h5>
              <p class="card-subtitle">Inflows vs Outflows</p>
            </div>
          </div>
          <div class="card-body">
            <div id="cashflowTrendAreaChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 2: DSO&DPO Trend + AR/AP Aging ---- *@
    @if (hasDsoDpo || hasArAp)
    {
      <div class="grid-stack-item"
           data-widget-id="finance-chart-dsodpo"
           data-gs-x="0" data-gs-y="@chartRow2" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">DSO & DPO Trend</h5>
              <p class="card-subtitle">Days Sales Outstanding vs Days Payable Outstanding</p>
            </div>
          </div>
          <div class="card-body">
            <div id="dsoDpoTrendChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="finance-chart-ARAPaging"
           data-gs-x="6" data-gs-y="@chartRow2" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">AR/AP Aging</h5>
              <p class="card-subtitle">Accounts Receivable & Payable by Bucket</p>
            </div>
          </div>
          <div class="card-body">
            <div id="arApAgingStackedChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 3: Collections Performance + Unit Economics ---- *@
    @if (hasCollPerf || hasUnitEcon)
    {
      <div class="grid-stack-item"
           data-widget-id="finance-chart-collections"
           data-gs-x="0" data-gs-y="@chartRow3" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Collections Performance</h5>
              <p class="card-subtitle">Collection Rate by Period</p>
            </div>
          </div>
          <div class="card-body">
            <div id="collectionsPerformanceChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="finance-chart-unit-econ"
           data-gs-x="6" data-gs-y="@chartRow3" data-gs-width="6" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Unit Economics by Channel</h5>
              <p class="card-subtitle">Gross Margin % & Contribution Margin %</p>
            </div>
          </div>
          <div class="card-body">
            <div id="unitEconomicsChart" class="apex-charts" style="height: 280px;"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 4: Customer Profit Scatter (full width) ---- *@
    @if (hasScatter)
    {
      <div class="grid-stack-item"
           data-widget-id="finance-chart-scatter"
           data-gs-x="0" data-gs-y="@chartRow4" data-gs-width="12" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="card-header d-flex justify-content-between">
            <div class="card-title mb-0">
              <h5 class="mb-1 me-2">Customer Revenue vs Profit</h5>
              <p class="card-subtitle">Scatter plot of customer profitability</p>
            </div>
          </div>
          <div class="card-body">
            <div id="customerProfitScatterChart" class="apex-charts" style="height: 300px;"></div>
          </div>
        </div>
      </div>
    }

    @* ---- Chart Row 5: Financial Overview stacked bar + Radial ---- *@
    @if (hasOverview)
    {
      <div class="grid-stack-item"
           data-widget-id="finance-chart-overview"
           data-gs-x="0" data-gs-y="@chartRow5" data-gs-width="8" data-gs-height="8">
        <div class="grid-stack-item-content card h-100">
          <div class="row row-bordered g-0 h-100">
            <div class="col-lg-8">
              <div class="card-header d-flex align-items-center justify-content-between">
                <div class="card-title mb-0">
                  <h5 class="m-0 me-2">Financial Overview</h5>
                </div>
                <div class="dropdown">
                  <button class="btn p-0" type="button" id="financeChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end" aria-labelledby="financeChart">
                    <a class="dropdown-item" href="javascript:void(0);">This Quarter</a>
                    <a class="dropdown-item" href="javascript:void(0);">This Year</a>
                  </div>
                </div>
              </div>
              <div id="totalRevenueChart" class="px-3"></div>
            </div>
            <div class="col-lg-4">
              <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
                <div class="text-center mb-6">
                  <h6 class="mb-0">@Model.ProfitMarginPercent% Profit Margin</h6>
                </div>
                <div id="growthChart"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="finance-kpi-netprofit"
           data-gs-x="8" data-gs-y="@chartRow5" data-gs-width="4" data-gs-height="4">
        <div class="grid-stack-item-content card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Net Profit" class="rounded" />
              </div>
            </div>
            <p class="mb-1">@Model.NetProfit.Title</p>
            <h4 class="card-title mb-3">@Model.NetProfit.Value</h4>
            <small class="text-@(Model.NetProfit.Trend == "up" ? "success" : Model.NetProfit.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.NetProfit.Trend == "up" ? "bx-up-arrow-alt" : Model.NetProfit.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.NetProfit.TrendLabel</small>
          </div>
        </div>
      </div>

      <div class="grid-stack-item"
           data-widget-id="finance-kpi-cashflow"
           data-gs-x="8" data-gs-y="@(chartRow5 + 4)" data-gs-width="4" data-gs-height="4">
        <div class="grid-stack-item-content card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Cash Flow" class="rounded" />
              </div>
            </div>
            <p class="mb-1">@Model.CashFlow.Title</p>
            <h4 class="card-title mb-3">@Model.CashFlow.Value</h4>
            <small class="text-@(Model.CashFlow.Trend == "up" ? "success" : Model.CashFlow.Trend == "down" ? "danger" : "body-secondary") fw-medium"><i class="icon-base bx @(Model.CashFlow.Trend == "up" ? "bx-up-arrow-alt" : Model.CashFlow.Trend == "down" ? "bx-down-arrow-alt" : "bx-minus")"></i> @Model.CashFlow.TrendLabel</small>
          </div>
        </div>
      </div>
    }

    @* ---- Bottom row: Expense Breakdown + Recent Transactions + Monthly Budget ---- *@
    <div class="grid-stack-item"
         data-widget-id="finance-expense-breakdown"
         data-gs-x="0" data-gs-y="@bottomRow" data-gs-width="4" data-gs-height="10">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex justify-content-between">
          <div class="card-title mb-0">
            <h5 class="mb-1 me-2">Expense Breakdown</h5>
            <p class="card-subtitle">By Category</p>
          </div>
        </div>
        <div class="card-body">
          <ul class="p-0 m-0">
            @if (Model.ExpenseBreakdown.Any())
            {
              @foreach (var expense in Model.ExpenseBreakdown.Take(5))
              {
                <li class="d-flex align-items-center mb-5">
                  <div class="avatar flex-shrink-0 me-3">
                    <span class="avatar-initial rounded @expense.IconBgClass"><i class="@expense.IconClass"></i></span>
                  </div>
                  <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                    <div class="me-2">
                      <h6 class="mb-0">@expense.Name</h6>
                      <small>@expense.Subtitle</small>
                    </div>
                    <div class="user-progress">
                      <h6 class="mb-0">@expense.FormattedValue</h6>
                    </div>
                  </div>
                </li>
              }
            }
            else
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-building"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">Operations</h6>
                    <small>35% of expenses</small>
                  </div>
                  <div class="user-progress"><h6 class="mb-0">$404,600</h6></div>
                </div>
              </li>
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-recent-transactions"
         data-gs-x="4" data-gs-y="@bottomRow" data-gs-width="4" data-gs-height="10">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex justify-content-between">
          <div class="card-title mb-0">
            <h5 class="mb-1 me-2">Recent Transactions</h5>
            <p class="card-subtitle">Latest Financial Activity</p>
          </div>
        </div>
        <div class="card-body pt-4">
          <ul class="p-0 m-0">
            @if (Model.RecentTransactions.Any())
            {
              @foreach (var tx in Model.RecentTransactions.Take(5))
              {
                <li class="d-flex align-items-center mb-6">
                  <div class="avatar flex-shrink-0 me-3">
                    <img src="~/img/icons/unicons/wallet.png" alt="Transaction" class="rounded" />
                  </div>
                  <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                    <div class="me-2">
                      <small class="d-block">@tx.Column1</small>
                      <h6 class="fw-normal mb-0">@tx.Column3</h6>
                    </div>
                    <div class="user-progress d-flex align-items-center gap-2">
                      <h6 class="fw-normal mb-0 @tx.TrendClass">@tx.Column4</h6>
                    </div>
                  </div>
                </li>
              }
            }
            else
            {
              <li class="d-flex align-items-center mb-6">
                <div class="avatar flex-shrink-0 me-3">
                  <img src="~/img/icons/unicons/wallet.png" alt="Transaction" class="rounded" />
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <small class="d-block">Invoice #2845</small>
                    <h6 class="fw-normal mb-0">Client Payment</h6>
                  </div>
                  <div class="user-progress d-flex align-items-center gap-2">
                    <h6 class="fw-normal mb-0 text-success">+$12,500</h6>
                  </div>
                </div>
              </li>
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="grid-stack-item"
         data-widget-id="finance-monthly-budget"
         data-gs-x="8" data-gs-y="@bottomRow" data-gs-width="4" data-gs-height="10">
      <div class="grid-stack-item-content card h-100">
        <div class="card-header d-flex justify-content-between">
          <div class="card-title mb-0">
            <h5 class="mb-1 me-2">Monthly Budget</h5>
            <p class="card-subtitle">Budget vs Actual</p>
          </div>
        </div>
        <div class="card-body">
          <ul class="p-0 m-0">
            @if (Model.MonthlyBudgetStatus.Any())
            {
              @foreach (var budget in Model.MonthlyBudgetStatus.Take(5))
              {
                <li class="d-flex align-items-center mb-5">
                  <div class="avatar flex-shrink-0 me-3">
                    <span class="avatar-initial rounded @budget.IconBgClass"><i class="@budget.IconClass"></i></span>
                  </div>
                  <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                    <div class="me-2">
                      <h6 class="mb-0">@budget.Name</h6>
                      <small>@budget.Subtitle</small>
                    </div>
                    <div class="user-progress">
                      <h6 class="mb-0">@budget.FormattedValue</h6>
                    </div>
                  </div>
                </li>
              }
            }
            else
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded bg-label-success"><i class="icon-base bx bx-check-circle"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">Revenue</h6>
                    <small>105% of target</small>
                  </div>
                  <div class="user-progress"><h6 class="mb-0 text-success">On Track</h6></div>
                </div>
              </li>
            }
          </ul>
        </div>
      </div>
    </div>

  </div>@* end grid-stack *@
</div>@* end grid container *@

