            <p class="mb-1">@Model.Dpo.Title</p>
            <h4 class="card-title mb-3">@Model.Dpo.Value</h4>
            <small class="text-primary fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.Dpo.TrendLabel</small>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-lg-4 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-4">
          <div class="avatar flex-shrink-0">
            <img src="~/img/icons/unicons/wallet.png" alt="AR Balance" class="rounded" />
          </div>
          <div class="dropdown">
            <button class="btn p-0" type="button" id="cardArBalance" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardArBalance">
              <a class="dropdown-item" href="javascript:void(0);">View More</a>
            </div>
          </div>
        </div>
