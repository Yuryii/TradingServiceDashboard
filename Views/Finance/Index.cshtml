@model FinanceDashboardViewModel
@{
  ViewData["Title"] = "Finance Dashboard";
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.incomeChart = @Html.Raw(Json.Serialize(Model.FinancialOverviewChart));
window.dashboardCharts.expensesChart = @Html.Raw(Json.Serialize(Model.FinancialOverviewChart));
window.dashboardCharts.profitWaterfall = @Html.Raw(Json.Serialize(Model.ProfitWaterfallChart));
window.dashboardCharts.cashflowTrendArea = @Html.Raw(Json.Serialize(Model.CashflowTrendAreaChart));
window.dashboardCharts.dsoDpoTrend = @Html.Raw(Json.Serialize(Model.DsoDpoTrendChart));
window.dashboardCharts.collectionsPerf = @Html.Raw(Json.Serialize(Model.CollectionsPerformanceChart));
window.dashboardCharts.expenseTreemap = @Html.Raw(Json.Serialize(Model.ExpenseTreemapChart));
window.dashboardCharts.unitEconomics = @Html.Raw(Json.Serialize(Model.UnitEconomicsChart));
window.dashboardCharts.customerProfitScatter = @Html.Raw(Json.Serialize(Model.CustomerProfitScatterChart));
window.dashboardCharts.arApAgingStacked = @Html.Raw(Json.Serialize(Model.ArApAgingStackedChart));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Finance Overview 💰</h5>
            <p class="mb-6">Welcome to the Finance Dashboard. Track expenses and financial health.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Reports</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Finance Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="Income" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspupup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalIncome.Title</p>
            <h4 class="card-title mb-3">@Model.TotalIncome.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalIncome.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="Expenses" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspupup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalExpenses.Title</p>
            <h4 class="card-title mb-3">@Model.TotalExpenses.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalExpenses.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@* New KPI Cards: DSO, DPO, AR Balance *@
