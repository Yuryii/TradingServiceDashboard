<script>
function setRange(type) {
    var today = new Date();
    var toInput = document.querySelector('form[method="get"] input[name="to"]');
    var fromInput = document.querySelector('form[method="get"] input[name="from"]');
    if (!fromInput || !toInput) return;

    var to = new Date(today);
    var from = new Date(today);

    if (type === 'today') {
        from = new Date(today.getFullYear(), today.getMonth(), today.getDate());
        to = from;
    } else if (type === 'week') {
        var day = today.getDay();
        var diff = today.getDate() - day + (day === 0 ? -6 : 1);
        from = new Date(today.getFullYear(), today.getMonth(), diff);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    } else if (type === 'month') {
        from = new Date(today.getFullYear(), today.getMonth(), 1);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    } else if (type === 'ytd') {
        from = new Date(today.getFullYear(), 0, 1);
        to = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    }

    fromInput.value = from.toISOString().split('T')[0];
    toInput.value = to.toISOString().split('T')[0];
    fromInput.closest('form').submit();
}
</script>

