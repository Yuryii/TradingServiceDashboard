@model CustomerServiceDashboardViewModel
@{
  ViewData["Title"] = "Customer Service Dashboard";
  var now = DateTime.Now;
  var defaultFrom = new DateTime(now.Year, 1, 1).ToString("yyyy-MM-dd");
  var defaultTo = now.ToString("yyyy-MM-dd");
  var currentFrom = Context.Request.Query["from"].FirstOrDefault() ?? defaultFrom;
  var currentTo = Context.Request.Query["to"].FirstOrDefault() ?? defaultTo;
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.SupportOverviewChart));
window.dashboardCharts.ticketVolumeLine = @Html.Raw(Json.Serialize(Model.TicketVolumeLineChart));
window.dashboardCharts.slaCompliance = @Html.Raw(Json.Serialize(Model.SlaComplianceChart));
window.dashboardCharts.responseTime = @Html.Raw(Json.Serialize(Model.ResponseTimeChart));
window.dashboardCharts.backlogAging = @Html.Raw(Json.Serialize(Model.BacklogAgingChart));
window.dashboardCharts.channelMixStacked = @Html.Raw(Json.Serialize(Model.ChannelMixStackedChart));
window.dashboardCharts.csatNpsTrend = @Html.Raw(Json.Serialize(Model.CsatNpsTrendChart));
window.dashboardCharts.rootCausePareto = @Html.Raw(Json.Serialize(Model.RootCauseParetoChart));
window.dashboardCharts.churnRiskHeatmap = @Html.Raw(Json.Serialize(Model.ChurnRiskHeatmap));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Customer Service Overview 🎧</h5>
            <p class="mb-6">Welcome to the Customer Service Dashboard. Monitor support metrics.</p>
            <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Tickets</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Customer Service Dashboard" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="Tickets" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.TotalTickets.Title</p>
            <h4 class="card-title mb-3">@Model.TotalTickets.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalTickets.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="Satisfaction" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.Satisfaction.Title</p>
            <h4 class="card-title mb-3">@Model.Satisfaction.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-star"></i> @Model.Satisfaction.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" class="row g-3 align-items-end">
      <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@currentFrom" />
      </div>
      <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@currentTo" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="icon-base bx bx-filter-alt"></i> Apply</button>
      </div>
      <div class="col-auto">
        <a href="/CustomerService" class="btn btn-sm btn-outline-secondary"><i class="icon-base bx bx-reset"></i> Reset</a>
      </div>
      <div class="col-auto ms-auto">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary" onclick="setRange('today')">Today</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('week')">This Week</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('month')">This Month</button>
          <button type="button" class="btn btn-outline-primary" onclick="setRange('ytd')">YTD</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row">
  <div class="col-12 col-xxl-8 order-2 order-md-3 order-xxl-2 mb-6">
    <div class="card">
      <div class="row row-bordered g-0">
        <div class="col-lg-8">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Support Overview</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="supportChart" data-bs-toggle="dropdown" aria-haspup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="supportChart">
                <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
              </div>
            </div>
          </div>
          <div id="totalRevenueChart" class="px-3"></div>
        </div>
        <div class="col-lg-4">
          <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
            <div class="text-center mb-6">
              <h6 class="mb-0">@Model.FirstResponseRatePercent% First Response Rate</h6>
            </div>
            <div id="growthChart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-8 col-lg-12 col-xxl-4 order-3 order-md-2 mb-6">
    <div class="row">
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/paypal.png" alt="Resolved" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.ResolvedTickets.Title</p>
            <h4 class="card-title mb-3">@Model.ResolvedTickets.Value</h4>
            <small class="text-success fw-medium"><i class="icon-base bx bx-check-circle"></i> @Model.ResolvedTickets.TrendLabel</small>
          </div>
        </div>
      </div>
      <div class="col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/cc-primary.png" alt="Pending" class="rounded" />
              </div>
              <div class="dropdown">
                <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspup="true" aria-expanded="false">
                  <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
                </button>
                <div class="dropdown-menu" aria-labelledby="cardOpt4">
                  <a class="dropdown-item" href="javascript:void(0);">View More</a>
                </div>
              </div>
            </div>
            <p class="mb-1">@Model.PendingTickets.Title</p>
            <h4 class="card-title mb-3">@Model.PendingTickets.Value</h4>
            <small class="text-warning fw-medium"><i class="icon-base bx bx-time"></i> @Model.PendingTickets.TrendLabel</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- KPI Cards Row 2: FCR, Avg Response, Avg Resolution, Open Tickets -->
<div class="row">
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/chart-success.png" alt="FCR" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardFcr" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">First Response Rate</p>
        <h4 class="card-title mb-2">@Model.FirstResponseRate.Value</h4>
        <small class="text-success fw-medium"><i class="icon-base bx bx-bolt"></i> @Model.FirstResponseRate.TrendLabel</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/wallet-info.png" alt="Response" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardResp" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">@Model.AvgResponseTime.Title</p>
        <h4 class="card-title mb-2">@Model.AvgResponseTime.Value</h4>
        <small class="text-primary fw-medium"><i class="icon-base bx bx-time"></i> Avg Response</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/paypal.png" alt="Resolution" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardRes" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">@Model.AvgResolutionTime.Title</p>
        <h4 class="card-title mb-2">@Model.AvgResolutionTime.Value</h4>
        <small class="text-warning fw-medium"><i class="icon-base bx bx-check"></i> Resolution Time</small>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6 col-sm-6 mb-6">
    <div class="card h-100">
      <div class="card-body">
        <div class="card-title d-flex align-items-start justify-content-between mb-3"><div class="avatar flex-shrink-0"><img src="~/img/icons/unicons/cc-primary.png" alt="Open" class="rounded" /></div><div class="dropdown"><button class="btn p-0" type="button" id="cardOpen" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">View More</a></div></div></div>
        <p class="mb-1">@Model.OpenTickets.Title</p>
        <h4 class="card-title mb-2">@Model.OpenTickets.Value</h4>
        <small class="text-danger fw-medium"><i class="icon-base bx bx-alert-circle"></i> @Model.OpenTickets.TrendLabel</small>
      </div>
    </div>
  </div>
</div>

<!-- Chart Row 1: Ticket Volume Line + SLA Compliance -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Ticket Volume Trend</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="tvOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="ticketVolumeLineChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">SLA Compliance</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="slaOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="slaComplianceChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Chart Row 2: Response Time Line + Backlog Aging -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Response & Resolution Time</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="rtOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="responseTimeChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Backlog Aging</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="baOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="backlogAgingChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Chart Row 3: Channel Mix Stacked + CSAT/NPS Trend -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Channel Mix</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="cmOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="channelMixStackedChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">CSAT & NPS Trend</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="csatOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="csatNpsTrendChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Chart Row 4: Root Cause Pareto + Churn Risk Heatmap -->
<div class="row">
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Root Cause Pareto (80/20)</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="paretoOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="rootCauseParetoChart" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Churn Risk Signals</h5>
        <div class="dropdown"><button class="btn p-0" type="button" id="churnOpts" data-bs-toggle="dropdown"><i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i></button><div class="dropdown-menu dropdown-menu-end"><a class="dropdown-item" href="javascript:void(0);">Refresh</a></div></div>
      </div>
      <div class="card-body">
        <div id="churnRiskHeatmap" style="min-height: 280px;"></div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6 col-lg-4 order-0 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Ticket Categories</h5>
          <p class="card-subtitle">Issues by Type</p>
        </div>
      </div>
      <div class="card-body">
        <ul class="p-0 m-0">
          @if (Model.TicketCategories.Any())
          {
            @foreach (var cat in Model.TicketCategories.Take(5))
            {
              <li class="d-flex align-items-center mb-5">
                <div class="avatar flex-shrink-0 me-3">
                  <span class="avatar-initial rounded @cat.IconBgClass"><i class="@cat.IconClass"></i></span>
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <h6 class="mb-0">@cat.Name</h6>
                    <small>@cat.Subtitle</small>
                  </div>
                  <div class="user-progress">
                    <h6 class="mb-0">@cat.FormattedValue</h6>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-5">
              <div class="avatar flex-shrink-0 me-3">
                <span class="avatar-initial rounded bg-label-primary"><i class="icon-base bx bx-cog"></i></span>
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <h6 class="mb-0">Technical</h6>
                  <small>428 tickets</small>
                </div>
                <div class="user-progress">
                  <h6 class="mb-0">23%</h6>
                </div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 col-lg-4 order-1 mb-6">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <div class="card-title mb-0">
          <h5 class="mb-1 me-2">Recent Tickets</h5>
          <p class="card-subtitle">Latest Support Requests</p>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="p-0 m-0">
          @if (Model.RecentTickets.Any())
          {
            @foreach (var ticket in Model.RecentTickets.Take(5))
            {
              <li class="d-flex align-items-center mb-6">
                <div class="avatar flex-shrink-0 me-3">
                  <img src="~/img/icons/unicons/wallet.png" alt="@ticket.Column1" class="rounded" />
                </div>
                <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                  <div class="me-2">
                    <small class="d-block">@ticket.Column1</small>
                    <h6 class="fw-normal mb-0">@ticket.Column2</h6>
                  </div>
                  <div class="user-progress d-flex align-items-center gap-2">
                    <span class="badge @ticket.BadgeClass">@ticket.Column3</span>
                  </div>
                </div>
              </li>
            }
          }
          else
          {
            <li class="d-flex align-items-center mb-6">
              <div class="avatar flex-shrink-0 me-3">
                <img src="~/img/icons/unicons/wallet.png" alt="Ticket" class="rounded" />
              </div>
              <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                <div class="me-2">
                  <small class="d-block">Ticket #4582</small>
                  <h6 class="fw-normal mb-0">Login issue</h6>
                </div>
                <div class="user-progress d-flex align-items-center gap-2">
                  <span class="badge bg-label-success">Resolved</span>
                </div>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>

