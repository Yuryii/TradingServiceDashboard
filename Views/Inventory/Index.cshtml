@model InventoryDashboardViewModel
@{
  ViewData["Title"] = "Inventory Dashboard";
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
<link rel="stylesheet" href="~/vendor/libs/gridstack/gridstack.min.css" />
<style>
  .inventory-kpi-row > .inventory-kpi-cell {
    flex: 0 0 auto;
    width: 100%;
    max-width: 100%;
  }
  @@media (min-width: 576px) {
    .inventory-kpi-row > .inventory-kpi-cell { width: 50%; }
  }
  @@media (min-width: 768px) {
    .inventory-kpi-row > .inventory-kpi-cell { width: 25%; }
  }
  @@media (min-width: 1200px) {
    .inventory-kpi-row > .inventory-kpi-cell { width: 12.5%; }
  }
  .inventory-kpi-cell .card-body { padding: 1rem; }
  .inventory-kpi-cell .card-title.mb-4 { margin-bottom: 0.75rem !important; }
  .inventory-kpi-cell h4.card-title { font-size: 1.1rem; word-break: break-word; }
  .inventory-kpi-cell p.mb-1 { font-size: 0.8125rem; }
  .layout-toolbar {
    margin-bottom: 1rem;
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }
  .layout-toolbar .btn {
    display: none;
  }
  .layout-toolbar.edit-mode .btn {
    display: inline-flex;
  }
</style>
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@* Always render chart data - individual guards protect each chart render *@
<script>
window.dashboardCharts = window.dashboardCharts || {};
window.dashboardCharts.orderChart = @Html.Raw(Json.Serialize(Model.StockMovementChart));
window.dashboardCharts.inventoryTrendArea = @Html.Raw(Json.Serialize(Model.InventoryTrendAreaChart));
window.dashboardCharts.abcAnalysis = @Html.Raw(Json.Serialize(Model.AbcAnalysisChart));
window.dashboardCharts.daysOfInventory = @Html.Raw(Json.Serialize(Model.DaysOfInventoryChart));
window.dashboardCharts.stockoutTrend = @Html.Raw(Json.Serialize(Model.StockoutTrendChart));
window.dashboardCharts.reorderPoint = @Html.Raw(Json.Serialize(Model.ReorderPointChart));
window.dashboardCharts.agingInventory = @Html.Raw(Json.Serialize(Model.AgingInventoryChart));
window.dashboardCharts.inboundOutbound = @Html.Raw(Json.Serialize(Model.InboundOutboundChart));
window.dashboardCharts.warehouseProductivity = @Html.Raw(Json.Serialize(Model.WarehouseProductivityChart));
window.dashboardCharts.inventoryAccuracyHeatmap = @Html.Raw(Json.Serialize(Model.InventoryAccuracyHeatmap));
</script>
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
}

<div class="layout-toolbar" id="layout-toolbar">
  <button class="btn btn-primary" id="btn-layout-edit" title="Customize Layout">
    <i class="icon-base bx bx-edit-alt me-1"></i> Customize Layout
  </button>
  <button class="btn btn-success" id="btn-layout-save" title="Save Layout" style="display:none;">
    <i class="icon-base bx bx-save me-1"></i> Save
  </button>
  <button class="btn btn-secondary" id="btn-layout-reset" title="Reset Layout" style="display:none;">
    <i class="icon-base bx bx-reset me-1"></i> Reset
  </button>
</div>

<div id="inventory-dashboard-grid-container" style="position: relative;">
<div id="inventory-dashboard-grid" class="grid-stack">
  <div class="grid-stack-item" data-widget-id="inventory-welcome" data-gs-x="0" data-gs-y="0" data-gs-width="12" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="row mb-6">
      <div class="col-12">
        <div class="card">
          <div class="d-flex align-items-start row">
            <div class="col-sm-7">
              <div class="card-body">
                <h5 class="card-title text-primary mb-3">Inventory Overview 📦</h5>
                <p class="mb-6">Welcome to the Inventory Dashboard. Monitor stock levels and logistics.</p>
                <a href="javascript:;" class="btn btn-sm btn-outline-primary">View Inventory</a>
              </div>
            </div>
            <div class="col-sm-5 text-center text-sm-left">
              <div class="card-body pb-0 px-0 px-md-6">
                <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="Inventory Dashboard" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-stock" data-gs-x="0" data-gs-y="6" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Stock" class="rounded" />
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOpt1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt1">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">@Model.TotalItems.Title</p>
          <h4 class="card-title mb-2">@Model.TotalItems.Value</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.TotalItems.TrendLabel</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-value" data-gs-x="3" data-gs-y="6" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/wallet-info.png" alt="Value" class="rounded" />
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOpt2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt2">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">@Model.StockValue.Title</p>
          <h4 class="card-title mb-2">@Model.StockValue.Value</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.StockValue.TrendLabel</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-turnover" data-gs-x="6" data-gs-y="6" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/chart-success.png" alt="Turnover" class="rounded" />
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOptKpi1" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptKpi1">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">Inventory Turnover</p>
          <h4 class="card-title mb-2">@(Model.InventoryTurnover?.NumericValue > 0 ? Model.InventoryTurnover.FormattedValue : "8.5x")</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> 5.2%</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-fillrate" data-gs-x="9" data-gs-y="6" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <span class="avatar-initial rounded bg-label-success"><i class="icon-base bx bx-bar-chart-alt-2"></i></span>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOptKpi2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptKpi2">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">Fill Rate</p>
          <h4 class="card-title mb-2">@(Model.FillRate?.NumericValue > 0 ? Model.FillRate.FormattedValue : "85%")</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> 2.1%</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-otif" data-gs-x="0" data-gs-y="12" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <span class="avatar-initial rounded bg-label-info"><i class="icon-base bx bx-check-shield"></i></span>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOptKpi3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptKpi3">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">OTIF</p>
          <h4 class="card-title mb-2">85%</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> 3.0%</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-shrinkage" data-gs-x="3" data-gs-y="12" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <span class="avatar-initial rounded bg-label-warning"><i class="icon-base bx bx-trending-down"></i></span>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOptKpi4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOptKpi4">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">Shrinkage</p>
          <h4 class="card-title mb-2">2.5%</h4>
          <small class="text-danger fw-medium"><i class="icon-base bx bx-down-arrow-alt"></i> 0.3%</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-inbound" data-gs-x="6" data-gs-y="12" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/paypal.png" alt="Inbound" class="rounded" />
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOpt3" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="cardOpt3">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">@Model.InboundOrders.Title</p>
          <h4 class="card-title mb-2">@Model.InboundOrders.Value</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.InboundOrders.TrendLabel</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-kpi-outbound" data-gs-x="9" data-gs-y="12" data-gs-width="3" data-gs-height="6"><div class="grid-stack-item-content card">
    <div class="inventory-kpi-cell">
      <div class="card h-100">
        <div class="card-body">
          <div class="card-title d-flex align-items-start justify-content-between mb-4">
            <div class="avatar flex-shrink-0">
              <img src="~/img/icons/unicons/cc-primary.png" alt="Outbound" class="rounded" />
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="cardOpt4" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded text-body-secondary"></i>
              </button>
              <div class="dropdown-menu" aria-labelledby="cardOpt4">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <p class="mb-1">@Model.OutboundOrders.Title</p>
          <h4 class="card-title mb-2">@Model.OutboundOrders.Value</h4>
          <small class="text-success fw-medium"><i class="icon-base bx bx-up-arrow-alt"></i> @Model.OutboundOrders.TrendLabel</small>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-stock-movement" data-gs-x="0" data-gs-y="18" data-gs-width="12" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-12 mb-6">
        <div class="card">
          <div class="row row-bordered g-0">
            <div class="col-lg-8">
              <div class="card-header d-flex align-items-center justify-content-between">
                <div class="card-title mb-0">
                  <h5 class="m-0 me-2">Stock Movement</h5>
                </div>
                <div class="dropdown">
                  <button class="btn p-0" type="button" id="stockChart" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end" aria-labelledby="stockChart">
                    <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                    <a class="dropdown-item" href="javascript:void(0);">This Month</a>
                  </div>
                </div>
              </div>
              <div id="totalRevenueChart" class="px-3"></div>
            </div>
            <div class="col-lg-4">
              <div class="card-body px-xl-9 py-12 d-flex align-items-center flex-column">
                <div class="text-center mb-6">
                  <h6 class="mb-0">@Model.StockUtilizationPercent% Stock Utilization</h6>
                </div>
                <div id="growthChart"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-trend" data-gs-x="0" data-gs-y="26" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-0 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Inventory Level Trend</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="invTrendOpt" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="invTrendOpt">
                <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
              </div>
            </div>
          </div>
          <div class="card-body px-3">
            <div id="inventoryTrendAreaChart" height="280"></div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-days" data-gs-x="6" data-gs-y="26" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-1 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Days of Inventory</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="doiOpt" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="doiOpt">
                <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
              </div>
            </div>
          </div>
          <div class="card-body px-3">
            <div id="daysOfInventoryChart" height="280"></div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-abc" data-gs-x="0" data-gs-y="34" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-0 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">ABC Analysis</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="abcOpt" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="abcOpt">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <div class="card-body px-3">
            <div id="abcAnalysisChart" height="280"></div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-stockout" data-gs-x="6" data-gs-y="34" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-1 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Stockout & Backorder Trend</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="stockoutOpt" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="stockoutOpt">
                <a class="dropdown-item" href="javascript:void(0);">This Week</a>
                <a class="dropdown-item" href="javascript:void(0);">This Month</a>
              </div>
            </div>
          </div>
          <div class="card-body px-3">
            <div id="stockoutTrendChart" height="280"></div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-aging" data-gs-x="0" data-gs-y="42" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-0 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Aging Inventory</h5>
            </div>
            <div class="dropdown">
              <button class="btn p-0" type="button" id="agingOpt" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <i class="icon-base bx bx-dots-vertical-rounded icon-lg text-body-secondary"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end" aria-labelledby="agingOpt">
                <a class="dropdown-item" href="javascript:void(0);">View More</a>
              </div>
            </div>
          </div>
          <div class="card-body px-3">
            <div id="agingInventoryChart" height="280"></div>
          </div>
        </div>
      </div>
    </div>
  </div></div>

  <div class="grid-stack-item" data-widget-id="inventory-chart-inbound" data-gs-x="6" data-gs-y="42" data-gs-width="6" data-gs-height="8"><div class="grid-stack-item-content card">
    <div class="row">
      <div class="col-md-6 col-lg-6 order-1 mb-6">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div class="card-title mb-0">
              <h5 class="m-0 me-2">Inbound vs Outbound</h5>
