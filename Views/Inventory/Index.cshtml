            series: chartData.series || []
          };
          new ApexCharts(chartEl, options).render();
        }
      })();

      // --- Inventory Accuracy Heatmap ---
      (function () {
        var chartEl = document.querySelector('#inventoryAccuracyHeatmap');
        var heatmapData = window.dashboardCharts.inventoryAccuracyHeatmap;
        if (chartEl && typeof ApexCharts !== 'undefined' && heatmapData) {
          var yCats = heatmapData.yCategories || [];
          var options = {
            chart: { height: 300, type: 'heatmap', toolbar: { show: false }, fontFamily: config.fontFamily },
            colors: ['#6965fd'],
            dataLabels: { enabled: false },
            grid: { strokeDashArray: 7, borderColor: borderColor, padding: { top: -10, bottom: -10, left: 20, right: 20 } },
            xaxis: {
              categories: heatmapData.xCategories || [],
              labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } },
              axisTicks: { show: false },
              axisBorder: { show: false }
            },
            yaxis: {
              categories: yCats,
              labels: { style: { fontSize: '13px', fontFamily: config.fontFamily, colors: labelColor } }
            },
            tooltip: { theme: 'light', x: { show: true }, y: { formatter: function (val) { return val !== null && val !== undefined ? val.toFixed(2) + '%' : '0%'; } } },
            legend: { show: true, horizontalAlign: 'left', position: 'top', markers: { size: 4, radius: 12, shape: 'circle', strokeWidth: 0 }, fontSize: '13px', fontFamily: config.fontFamily, labels: { colors: legendColor, useSeriesColors: false }, itemMargin: { horizontal: 10 } },
            plotOptions: {
              heatmap: {
                radius: 4,
                colorScale: {
                  ranges: [
                    { from: 0, to: 90, name: 'Low', color: '#ff3e1d' },
                    { from: 90, to: 97, name: 'Medium', color: '#ffab00' },
                    { from: 97, to: 100, name: 'High', color: '#71dd88' }
                  ]
                }
              }
            },
            series: yCats.map(function (yCat) {
              return {
                name: yCat,
                data: (heatmapData.data || []).filter(function (d) { return d.y === yCat; }).map(function (d) { return d.value || 0; })
              };
            })
          };
          new ApexCharts(chartEl, options).render();
        }
      })();

    });
  </script>
}

